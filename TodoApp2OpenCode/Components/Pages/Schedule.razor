@page "/board/{BoardId}/schedule"
@inject NavigationManager Navigation
@inject IBoardService BoardService
@inject TodoService TodoService
@inject IDialogService DialogService
@inject ISnackbar SnackbarService
@inject IAuthService AuthService

<PageTitle>@Config.AppName - Programación</PageTitle>

<CalendarView Title="@($"Programación del tablero")"
              Subttitle="@($"{currentBoard?.Name}")"
              BackUrl="@($"/board/{BoardId}")"
              ShowSidebar="true"
              Items="allItems"
              Events="allEvents"
              InitialDate="initialDate"
              OnBackClicked="GoBack"
              OnDayClicked="OpenDayDetails"
              OnAddEventClicked="OpenAddEventDialog"
              CanAddEvent="canAddEvent"
              OnEditEventClicked="OpenEditEventDialog"
              CanEditEvent="canModifyEvent"
              OnDeleteEventClicked="ConfirmDeleteEvent"
              CanDeleteEvent="canDeleteEvent"
              OnDateChanged="OnCalendarDateChanged"
              OnOpenDatePickerClicked="OpenDatePickerDialog"
              @ref="calendarView" />

@code {
    [Parameter]
    public string BoardId { get; set; } = string.Empty;

    [SupplyParameterFromQuery(Name = "date")]
    public string? DateParam { get; set; }

    private CalendarView? calendarView;
    private TodoBoard? currentBoard;
    private List<TodoItem> allItems = new();
    private List<CalendarEvent> allEvents = new();
    private DateTime? initialDate;
    private bool isOwner = false;
    private bool canAddEvent = true;
    private bool canModifyEvent = true;
    private bool canDeleteEvent = true;
    private System.Threading.Timer? _permissionCheckTimer;

    protected override async Task OnInitializedAsync()
    {
        initialDate = ParseDateFromString(DateParam);
        await AuthService.CheckAuthStateAsync();
        await LoadData();


    }

    protected override void OnAfterRender(bool firstRender)
    {
        // if (firstRender == false) return;

        // _permissionCheckTimer = new System.Threading.Timer(async _ =>
        // {
        //     await CheckPermissionsChanged();
        // }, null, 10, 5);
    }


    private async Task CheckPermissionsChanged()
    {
        if (string.IsNullOrEmpty(BoardId)) return;

        try
        {
            var board = await BoardService.GetBoardAsync(BoardId);
            if (board == null)
            {
                try { await InvokeAsync(() => Navigation.NavigateTo("/", forceLoad: true)); } catch { }
                return;
            }

            var currentUserId = AuthService.CurrentUser?.Id ?? "";
            var isOwner = board.User == currentUserId;

            if (isOwner) return;

            bool isParticipant = board.Participants.ContainsKey(currentUserId);
            if (!isParticipant)
            {
                try { await InvokeAsync(() => Navigation.NavigateTo("/", forceLoad: true)); } catch { }
                return;
            }

            if (board.ParticipantPermissions != null && 
                board.ParticipantPermissions.TryGetValue(currentUserId, out var perms))
            {
                if (!perms.CanViewCalendar)
                {
                    try { await InvokeAsync(() => Navigation.NavigateTo($"/board/{BoardId}", forceLoad: true)); } catch { }
                    return;
                }
            }
            else
            {
                try { await InvokeAsync(() => Navigation.NavigateTo($"/board/{BoardId}", forceLoad: true)); } catch { }
            }
        }
        catch { }
    }

    protected override async Task OnParametersSetAsync()
    {
        var validDate = ParseDateFromString(DateParam);
        if (validDate.HasValue && calendarView != null)
        {
            initialDate = validDate;
            calendarView.SetCurrentDate(validDate.Value);
        }
    }

    private DateTime? ParseDateFromString(string? dateStr)
    {
        if (string.IsNullOrWhiteSpace(dateStr))
            return DateTime.Today;

        if (DateTime.TryParseExact(dateStr, "dd-MM-yyyy", 
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.None, 
            out var parsedDate))
        {
            if (parsedDate.Year < 1900 || parsedDate.Year > 2100)
                return DateTime.Today;

            return parsedDate;
        }

        return DateTime.Today;
    }

    private async Task LoadData()
    {
        try
        {
            if (AuthService.CurrentUser == null)
            {
                await Task.Delay(500);
                if (AuthService.CurrentUser == null)
                {
                    await InvokeAsync(() => Navigation.NavigateTo("/", forceLoad: true));
                    return;
                }
            }

            currentBoard = await BoardService.GetBoardAsync(BoardId);
            if (currentBoard == null)
            {
                await InvokeAsync(() => Navigation.NavigateTo("/", forceLoad: true));
                return;
            }

            bool isOwner = currentBoard.User == AuthService.CurrentUser.Id;
            bool isParticipant = currentBoard.Participants.ContainsKey(AuthService.CurrentUser.Id);

            if (!isOwner && !isParticipant)
            {
                await InvokeAsync(() => Navigation.NavigateTo("/", forceLoad: true));
                return;
            }

            if (!isOwner)
            {
                if (currentBoard.ParticipantPermissions != null && 
                    currentBoard.ParticipantPermissions.TryGetValue(AuthService.CurrentUser.Id, out var perms))
                {
                    if (!perms.CanViewCalendar)
                    {
                        await InvokeAsync(() => Navigation.NavigateTo($"/board/{BoardId}", forceLoad: true));
                        return;
                    }
                }
                else
                {
                    await InvokeAsync(() => Navigation.NavigateTo($"/board/{BoardId}", forceLoad: true));
                    return;
                }
            }

            allItems = currentBoard.Items.Where(i => i.DueDate.HasValue || i.StartDate.HasValue || i.EndDate.HasValue).ToList();
            allEvents = currentBoard.Events.ToList();

            isOwner = currentBoard.User == AuthService.CurrentUser.Id;
            if (isOwner)
            {
                canAddEvent = true;
                canModifyEvent = true;
                canDeleteEvent = true;
            }
            else if (currentBoard.ParticipantPermissions != null && 
                     currentBoard.ParticipantPermissions.TryGetValue(AuthService.CurrentUser.Id, out var perms))
            {
                canAddEvent = perms.CanAddEvents;
                canModifyEvent = perms.CanModifyEvents;
                canDeleteEvent = perms.CanDeleteEvents;
            }
            else
            {
                canAddEvent = false;
                canModifyEvent = false;
                canDeleteEvent = false;
            }
        }
        catch (NavigationException)
        {
        }
    }

    private async Task<bool> CheckCanAddEvent()
    {
        var board = await BoardService.GetBoardAsync(BoardId);
        if (board == null) return false;

        var currentUserId = AuthService.CurrentUser?.Id ?? "";
        var isOwner = board.User == currentUserId;

        if (isOwner) return true;

        if (board.ParticipantPermissions != null && 
            board.ParticipantPermissions.TryGetValue(currentUserId, out var perms))
        {
            if (!perms.CanAddEvents)
            {
                SnackbarService.Add("No tienes permiso para añadir eventos", Severity.Warning);
                return false;
            }
            return true;
        }

        SnackbarService.Add("No tienes permiso para añadir eventos", Severity.Warning);
        return false;
    }

    private async Task<bool> CheckCanModifyEvent()
    {
        var board = await BoardService.GetBoardAsync(BoardId);
        if (board == null) return false;

        var currentUserId = AuthService.CurrentUser?.Id ?? "";
        var isOwner = board.User == currentUserId;

        if (isOwner) return true;

        if (board.ParticipantPermissions != null && 
            board.ParticipantPermissions.TryGetValue(currentUserId, out var perms))
        {
            if (!perms.CanModifyEvents)
            {
                SnackbarService.Add("No tienes permiso para modificar eventos", Severity.Warning);
                return false;
            }
            return true;
        }

        SnackbarService.Add("No tienes permiso para modificar eventos", Severity.Warning);
        return false;
    }

    private async Task<bool> CheckCanDeleteEvent()
    {
        var board = await BoardService.GetBoardAsync(BoardId);
        if (board == null) return false;

        var currentUserId = AuthService.CurrentUser?.Id ?? "";
        var isOwner = board.User == currentUserId;

        if (isOwner) return true;

        if (board.ParticipantPermissions != null && 
            board.ParticipantPermissions.TryGetValue(currentUserId, out var perms))
        {
            if (!perms.CanDeleteEvents)
            {
                SnackbarService.Add("No tienes permiso para eliminar eventos", Severity.Warning);
                return false;
            }
            return true;
        }

        SnackbarService.Add("No tienes permiso para eliminar eventos", Severity.Warning);
        return false;
    }

    private void GoBack()
    {
        Navigation.NavigateTo($"/board/{BoardId}");
    }

    private async Task OnCalendarDateChanged(DateTime date)
    {
        var uri = new Uri(Navigation.Uri);
        var queryParams = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        var newUri = Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(
            Navigation.BaseUri.TrimEnd('/') + $"/board/{BoardId}/schedule",
            "date",
            date.ToString("dd-MM-yyyy"));

        Navigation.NavigateTo(newUri, replace: true);
    }

    private async Task OpenDatePickerDialog()
    {
        var parameters = new DialogParameters<DatePickerDialog>();
        parameters.Add(x => x.InitialDate, calendarView?.GetCurrentDate() ?? DateTime.Today);

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small
        };

        var dialog = await DialogService.ShowAsync<DatePickerDialog>("Ir a fecha", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: DateTime selectedDate })
        {
            calendarView?.SetCurrentDate(selectedDate);
        }
    }

    private async Task OpenDayDetails(DateTime date)
    {
        var dayItems = allItems.Where(i => 
            i.DueDate?.Date == date.Date ||
            (i.StartDate.HasValue && i.EndDate.HasValue && date >= i.StartDate.Value.Date && date <= i.EndDate.Value.Date) ||
            (i.StartDate.HasValue && !i.EndDate.HasValue && date >= i.StartDate.Value.Date) ||
            (!i.StartDate.HasValue && i.EndDate.HasValue && date <= i.EndDate.Value.Date)
        ).ToList();

        var dayEvents = allEvents.Where(e => e.EventDate.Date == date.Date).ToList();

        if (!dayItems.Any() && !dayEvents.Any())
        {
            await OpenAddEventDialogWithDate(date);
            return;
        }

        var parameters = new DialogParameters<DayDetailsDialog>();
        parameters.Add(x => x.SelectedDate, date);
        parameters.Add(x => x.Events, dayEvents);
        parameters.Add(x => x.Items, dayItems);
        parameters.Add(x => x.OnAddEvent, EventCallback.Factory.Create<DateTime>(this, OpenAddEventDialogWithDate));
        parameters.Add(x => x.OnEditEvent, EventCallback.Factory.Create<CalendarEvent>(this, OpenEditEventDialog));
        parameters.Add(x => x.OnDeleteEvent, EventCallback.Factory.Create<CalendarEvent>(this, ConfirmDeleteEvent));

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        await DialogService.ShowAsync<DayDetailsDialog>(
            date.ToString("dddd, dd 'de' MMMM", new System.Globalization.CultureInfo("es-ES")), 
            parameters, 
            options);

        await LoadData();
    }

    private async Task OpenAddEventDialog(DateTime preselectedDate)
    {
        if (!await CheckCanAddEvent()) return;

        var participants = new Dictionary<string, string>();
        if (currentBoard != null)
        {
            participants[currentBoard.User] = currentBoard.OwnerName ?? "Propietario";
            foreach (var p in currentBoard.Participants)
            {
                participants[p.Key] = p.Value;
            }
        }

        var parameters = new DialogParameters<AddEventDialog>();
        parameters.Add(x => x.PreSelectedDate, preselectedDate);
        parameters.Add(x => x.AvailableParticipants, participants);

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small
        };

        var dialog = await DialogService.ShowAsync<AddEventDialog>("Añadir evento", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: AddEventDialog.AddEventResult addResult })
        {
            var (msg, newEvent) = await BoardService.AddEventAsync(BoardId, addResult.Title, addResult.Description, addResult.EventDate, addResult.Participants);
            if (newEvent != null)
            {
                await LoadData();
            }
            SnackbarService.Add(msg, newEvent != null ? Severity.Success : Severity.Error);
        }
    }

    private async Task OpenEditEventDialog(CalendarEvent evt)
    {
        if (!await CheckCanModifyEvent()) return;

        var participants = new Dictionary<string, string>();
        if (currentBoard != null)
        {
            participants[currentBoard.User] = currentBoard.OwnerName ?? "Propietario";
            foreach (var p in currentBoard.Participants)
            {
                participants[p.Key] = p.Value;
            }
        }

        var parameters = new DialogParameters<AddEventDialog>();
        parameters.Add(x => x.EditEvent, evt);
        parameters.Add(x => x.AvailableParticipants, participants);

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small
        };

        var dialog = await DialogService.ShowAsync<AddEventDialog>("Editar evento", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: AddEventDialog.AddEventResult addResult })
        {
            var (msg, success) = await BoardService.UpdateEventAsync(BoardId, evt.Id, addResult.Title, addResult.Description, addResult.EventDate, addResult.Participants);
            if (success)
            {
                await LoadData();

                if (addResult.OriginalEventDate.HasValue && addResult.OriginalEventDate.Value.Date != addResult.EventDate.Date)
                {
                    SnackbarService.Add($"Evento actualizado. Fecha cambiada a {addResult.EventDate:dd/MM/yyyy}", Severity.Success);
                }
                else if (addResult.AddedParticipants.Any() || addResult.RemovedParticipants.Any())
                {
                    var messages = new List<string>();
                    if (addResult.AddedParticipants.Any())
                    {
                        var names = addResult.AddedParticipants
                            .Where(id => addResult.Participants.ContainsKey(id))
                            .Select(id => addResult.Participants[id]);
                        messages.Add($"Participantes añadidos: {string.Join(", ", names)}");
                    }
                    if (addResult.RemovedParticipants.Any())
                    {
                        var removedNames = addResult.RemovedParticipants
                            .Where(id => evt.Participants.ContainsKey(id))
                            .Select(id => evt.Participants[id]);
                        messages.Add($"Participantes eliminados: {string.Join(", ", removedNames)}");
                    }
                    SnackbarService.Add(string.Join(". ", messages), Severity.Success);
                }
                else
                {
                    SnackbarService.Add("Evento actualizado", Severity.Success);
                }
                return;
            }
            SnackbarService.Add(msg, success ? Severity.Success : Severity.Error);
        }
    }

    private async Task DeleteEvent(CalendarEvent evt)
    {
        if (!await CheckCanDeleteEvent()) return;
        
        var (msg, success) = await BoardService.DeleteEventAsync(BoardId, evt.Id);
        if (success)
        {
            await LoadData();
        }
        SnackbarService.Add(msg, success ? Severity.Success : Severity.Error);
    }

    private async Task ConfirmDeleteEvent(CalendarEvent evt)
    {
        var parameters = new DialogParameters<DeletionConfirmDialog>();
        parameters.Add(x => x.ContentText, $"¿Eliminar el evento '{evt.Title}'?");
        parameters.Add(x => x.ButtonText, "Eliminar");
        parameters.Add(x => x.Color, Color.Error);

        var dialog = await DialogService.ShowAsync<DeletionConfirmDialog>("Confirmar", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: true })
        {
            await DeleteEvent(evt);
        }
    }

    private async Task OpenAddEventDialogWithDate(DateTime date)
    {
        if (!await CheckCanAddEvent()) return;
        
        var participants = new Dictionary<string, string>();
        if (currentBoard != null)
        {
            participants[currentBoard.User] = currentBoard.OwnerName ?? "Propietario";
            foreach (var p in currentBoard.Participants)
            {
                participants[p.Key] = p.Value;
            }
        }

        var parameters = new DialogParameters<AddEventDialog>();
        parameters.Add(x => x.PreSelectedDate, date);
        parameters.Add(x => x.AvailableParticipants, participants);
        
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small
        };

        var dialog = await DialogService.ShowAsync<AddEventDialog>("Añadir evento", parameters, options);
        var result = await dialog.Result;
        
        if (result is { Canceled: false, Data: AddEventDialog.AddEventResult addResult })
        {
            var (msg, newEvent) = await BoardService.AddEventAsync(BoardId, addResult.Title, addResult.Description, addResult.EventDate, addResult.Participants);
            if (newEvent != null)
            {
                await LoadData();
            }
            SnackbarService.Add(msg, newEvent != null ? Severity.Success : Severity.Error);
        }
    }

    public void Dispose()
    {
        _permissionCheckTimer?.Dispose();
    }
}
