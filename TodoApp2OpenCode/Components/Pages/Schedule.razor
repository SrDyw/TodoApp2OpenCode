@code {
    [Parameter]
    public string BoardId { get; set; } = string.Empty;

    private TodoBoard? currentBoard;
    private List<TodoItem> allItems = new();
    private List<CalendarEvent> allEvents = new();
    private List<CalendarEvent> monthEvents = new();
    
    private DateTime currentDate = DateTime.Today;
    
    private readonly string[] weekdays = { "Lun", "Mar", "Mié", "Jue", "Vie", "Sáb", "Dom" };
    private readonly string[] weekDayNames = { "Domingo", "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado" };
    
    private List<CalendarDay> calendarDays = new();

    private struct CalendarDay
    {
        public DateTime Date { get; set; }
        public int Day { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        GenerateCalendarDays();
    }

    private async Task LoadData()
    {
        try
        {
            if (!AuthService.IsAuthenticated || AuthService.CurrentUser == null)
            {
                await InvokeAsync(() => Navigation.NavigateTo("/", forceLoad: true));
                return;
            }

            currentBoard = await BoardService.GetBoardAsync(BoardId);
            if (currentBoard == null)
            {
                await InvokeAsync(() => Navigation.NavigateTo("/", forceLoad: true));
                return;
            }

            bool isOwner = currentBoard.User == AuthService.CurrentUser.Id;
            bool isParticipant = currentBoard.Participants.ContainsKey(AuthService.CurrentUser.Id);
            
            if (!isOwner && !isParticipant)
            {
                await InvokeAsync(() => Navigation.NavigateTo("/", forceLoad: true));
                return;
            }

            allItems = currentBoard.Items.Where(i => i.DueDate.HasValue || i.StartDate.HasValue || i.EndDate.HasValue).ToList();
            allEvents = currentBoard.Events.ToList();
            monthEvents = allEvents.Where(e => e.EventDate.Year == currentDate.Year && e.EventDate.Month == currentDate.Month)
                                   .OrderBy(e => e.EventDate)
                                   .ToList();
        }
        catch (NavigationException)
        {
        }
    }

    private void GenerateCalendarDays()
    {
        calendarDays.Clear();
        
        var firstDayOfMonth = new DateTime(currentDate.Year, currentDate.Month, 1);
        var lastDayOfMonth = firstDayOfMonth.AddMonths(1).AddDays(-1);
        
        int startDayOfWeek = ((int)firstDayOfMonth.DayOfWeek + 6) % 7;
        
        var startDate = firstDayOfMonth.AddDays(-startDayOfWeek);
        
        for (int i = 0; i < 42; i++)
        {
            var date = startDate.AddDays(i);
            calendarDays.Add(new CalendarDay { Date = date, Day = date.Day });
        }
    }

    private string GetPeriodTitle()
    {
        return currentDate.ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-ES"));
    }

    private string GetMonthName()
    {
        return currentDate.ToString("MMMM", new System.Globalization.CultureInfo("es-ES"));
    }

    private string GetWeekdayShort(DateTime date)
    {
        return weekDayNames[(int)date.DayOfWeek].Substring(0, 3);
    }

    private bool IsEventToday(CalendarEvent evt)
    {
        return evt.EventDate.Date == DateTime.Today;
    }

    private void NavigateToDay(DateTime date)
    {
        currentDate = date;
        GenerateCalendarDays();
    }

    private List<TodoItem> GetItemsForDay(DateTime date)
    {
        return allItems.Where(i => 
            i.DueDate?.Date == date.Date ||
            (i.StartDate.HasValue && i.EndDate.HasValue && date.Date >= i.StartDate.Value.Date && date.Date <= i.EndDate.Value.Date) ||
            (i.StartDate.HasValue && !i.EndDate.HasValue && date.Date >= i.StartDate.Value.Date) ||
            (!i.StartDate.HasValue && i.EndDate.HasValue && date.Date <= i.EndDate.Value.Date)
        ).ToList();
    }

    private List<CalendarEvent> GetEventsForDay(DateTime date)
    {
        return allEvents.Where(e => e.EventDate.Date == date.Date).ToList();
    }

    private void PreviousPeriod()
    {
        currentDate = currentDate.AddMonths(-1);
        GenerateCalendarDays();
        UpdateMonthEvents();
    }

    private void NextPeriod()
    {
        currentDate = currentDate.AddMonths(1);
        GenerateCalendarDays();
        UpdateMonthEvents();
    }

    private void GoToToday()
    {
        currentDate = DateTime.Today;
        GenerateCalendarDays();
        UpdateMonthEvents();
    }

    private void UpdateMonthEvents()
    {
        monthEvents = allEvents.Where(e => e.EventDate.Year == currentDate.Year && e.EventDate.Month == currentDate.Month)
                               .OrderBy(e => e.EventDate)
                               .ToList();
    }

    private async Task OpenDatePickerDialog()
    {
        var parameters = new DialogParameters<DatePickerDialog>();
        parameters.Add(x => x.InitialDate, currentDate);
        
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small
        };

        var dialog = await DialogService.ShowAsync<DatePickerDialog>("Ir a fecha", parameters, options);
        var result = await dialog.Result;
        
        if (result is { Canceled: false, Data: DateTime selectedDate })
        {
            currentDate = selectedDate;
            GenerateCalendarDays();
            UpdateMonthEvents();
        }
    }

    private async Task OpenDayDetails(CalendarDay day)
    {
        while (true)
        {
            var dayItems = GetItemsForDay(day.Date);
            var dayEvents = GetEventsForDay(day.Date);

            var parameters = new DialogParameters<DayDetailsDialog>();
            parameters.Add(x => x.SelectedDate, day.Date);
            parameters.Add(x => x.Events, dayEvents);
            parameters.Add(x => x.Items, dayItems);
            parameters.Add(x => x.OnAddEvent, EventCallback.Factory.Create<DateTime>(this, OpenAddEventDialogWithDate));
            parameters.Add(x => x.OnAddTask, EventCallback.Factory.Create<DateTime>(this, OpenNewTaskDialogForDate));
            parameters.Add(x => x.OnDeleteEvent, EventCallback.Factory.Create<CalendarEvent>(this, ConfirmDeleteEvent));
            
            var options = new DialogOptions
            {
                CloseOnEscapeKey = true,
                MaxWidth = MaxWidth.Medium,
                FullWidth = true
            };

            var dialog = await DialogService.ShowAsync<DayDetailsDialog>(
                day.Date.ToString("dddd, dd 'de' MMMM", new System.Globalization.CultureInfo("es-ES")), 
                parameters, 
                options);
            
            var result = await dialog.Result;

            if (result is { Canceled: true, Data: "refresh" })
            {
                continue;
            }
            break;
        }
    }

    private async Task OpenAddEventDialog(DateTime? preselectedDate = null)
    {
        var parameters = new DialogParameters<AddEventDialog>();
        parameters.Add(x => x.PreSelectedDate, preselectedDate);
        
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small
        };

        var dialog = await DialogService.ShowAsync<AddEventDialog>("Añadir evento", parameters, options);
        var result = await dialog.Result;
        
        if (result is { Canceled: false, Data: AddEventDialog.AddEventResult addResult })
        {
            var newEvent = await BoardService.AddEventAsync(BoardId, addResult.Title, addResult.Description, addResult.EventDate);
            if (newEvent != null)
            {
                await LoadData();
                GenerateCalendarDays();
                UpdateMonthEvents();
                SnackbarService.Add("Evento creado", Severity.Success);
            }
        }
    }

    private async Task DeleteEvent(CalendarEvent evt)
    {
        var success = await BoardService.DeleteEventAsync(evt.Id);
        if (success)
        {
            await LoadData();
            GenerateCalendarDays();
            UpdateMonthEvents();
            SnackbarService.Add("Evento eliminado", Severity.Success);
        }
    }

    private async Task ConfirmDeleteEvent(CalendarEvent evt)
    {
        var parameters = new DialogParameters<DeletionConfirmDialog>();
        parameters.Add(x => x.ContentText, $"¿Eliminar el evento '{evt.Title}'?");
        parameters.Add(x => x.ButtonText, "Eliminar");
        parameters.Add(x => x.Color, Color.Error);

        var dialog = await DialogService.ShowAsync<DeletionConfirmDialog>("Confirmar", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: true })
        {
            await DeleteEvent(evt);
        }
    }

    private async Task OpenAddEventDialogWithDate(DateTime date)
    {
        await OpenAddEventDialog(date);
    }

    private async Task OpenNewTaskDialogForDate(DateTime date)
    {
        if (currentBoard == null || !currentBoard.Columns.Any())
        {
            SnackbarService.Add("Primero crea una columna", Severity.Warning);
            return;
        }

        var parameters = new DialogParameters<NewTaskDialog>();
        parameters.Add(x => x.PreselectedDueDate, date);
        parameters.Add(x => x.Columns, currentBoard.Columns);
        parameters.Add(x => x.Participants, currentBoard.Participants);
        
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Medium
        };

        var dialog = await DialogService.ShowAsync<NewTaskDialog>("Nueva tarea", parameters, options);
        var result = await dialog.Result;
        
        if (result is { Canceled: false, Data: TodoItem newItem })
        {
            var success = await TodoService.AddItemAsync(BoardId, newItem);
            if (success)
            {
                await LoadData();
                SnackbarService.Add("Tarea creada", Severity.Success);
            }
        }
    }

    private async Task OpenItemDetails(TodoItem item)
    {
    }
}
