@page "/profile"

<PageTitle>Mi Perfil - TodoPila</PageTitle>

@using SixLabors.ImageSharp
@using SixLabors.ImageSharp.Processing
@using SixLabors.ImageSharp.Formats.Jpeg
@using Color = MudBlazor.Color
@using Size = MudBlazor.Size

@inject IAuthService AuthService
@inject ISnackbar SnackbarService
@inject IDialogService DialogService
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Elevation="2" Class="pa-6" Style="border-radius: 16px;">
        <MudStack Spacing="4" AlignItems="AlignItems.Center">
            <div class="avatar-container">
                <MudAvatar Color="Color.Primary" Class="profile-avatar">
                    @if (!string.IsNullOrEmpty(_profileImageBase64))
                    {
                        <img src="@($"data:image/jpeg;base64,{_profileImageBase64}")" class="profile-image" />
                    }
                    else
                    {
                        @GetAvatarInitial()
                    }
                </MudAvatar>
                
                <MudStack Row="true" Spacing="0" Class="avatar-action-buttons">
                    @if (!string.IsNullOrEmpty(_profileImageBase64))
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                       Color="Color.Error" 
                                       Size="Size.Medium"
                                       Class="avatar-delete-btn"
                                       OnClick="DeleteProfileImage" />
                    }
                    <MudFileUpload T="IBrowserFile" 
                                   FilesChanged="OnImageSelected"
                                   Accept=".jpg,.jpeg,.png,.gif,.webp"
                                   MaximumFileCount="1">
                        <ActivatorContent>
                            <MudIconButton Icon="@Icons.Material.Filled.CameraAlt" 
                                           Color="Color.Primary" 
                                           Size="Size.Medium"
                                           Class="avatar-edit-btn" />
                        </ActivatorContent>
                    </MudFileUpload>
                </MudStack>
            </div>

            <MudStack Spacing="0" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.h5" Class="font-weight-bold">
                    @(string.IsNullOrWhiteSpace(AuthService.CurrentUser?.Name) ? "Añadir nombre" : AuthService.CurrentUser?.Name)
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Primary">
                    @@@AuthService.CurrentUser?.Username
                </MudText>
            </MudStack>

            <MudDivider Class="w-100 my-2" />

            <MudStack Spacing="2" Style="width:100%">
                <MudText Typo="Typo.subtitle2" Color="Color.Primary">Nombre</MudText>
                <MudTextField @bind-Value="_editingName" 
                             Placeholder="Escribe tu nombre" 
                             FullWidth
                             Immediate="true"
                             AutoFocus="true"
                             Adornment="Adornment.End"
                             AdornmentIcon="@Icons.Material.Filled.Edit"
                             MaxLength="100" />
            </MudStack>

            <MudButton Color="Color.Primary" 
                       Variant="Variant.Filled" 
                       FullWidth="true"
                       OnClick="SaveName"
                       Disabled="_isSaving">
                @if (_isSaving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Guardar
            </MudButton>

            <MudStack Row="true" Spacing="1" Class="w-100 mt-4">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Email:</MudText>
                <MudText Typo="Typo.caption">@AuthService.CurrentUser?.Email</MudText>
            </MudStack>

            <MudText Typo="Typo.caption" Color="Color.Tertiary">
                Miembro desde @AuthService.CurrentUser?.CreatedAt.ToString("dd/MM/yyyy")
            </MudText>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    private string _editingName = string.Empty;
    private bool _isSaving = false;
    private string? _profileImageBase64;
    private const int MAX_IMAGE_SIZE_BYTES = 2 * 1024 * 1024;

    protected override async Task OnInitializedAsync()
    {
        _editingName = AuthService.CurrentUser?.Name ?? string.Empty;
        if (AuthService.CurrentUser != null)
        {
            _profileImageBase64 = await AuthService.GetUserProfileImageAsync(AuthService.CurrentUser.Id);
        }
    }

    private string GetAvatarInitial()
    {
        var name = AuthService.CurrentUser?.Name ?? AuthService.CurrentUser?.Username ?? "?";
        return name.Length > 0 ? name[0].ToString().ToUpper() : "?";
    }

    private async Task OnImageSelected(IBrowserFile? file)
    {
        if (file == null) return;

        if (file.Size > MAX_IMAGE_SIZE_BYTES)
        {
            SnackbarService.Add("La imagen debe ser menor a 2MB", Severity.Warning);
            return;
        }

        _isSaving = true;

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: MAX_IMAGE_SIZE_BYTES);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var bytes = memoryStream.ToArray();

            var compressedBase64 = await CompressImageAsync(bytes);
            
            if (AuthService.CurrentUser != null)
            {
                await AuthService.SaveUserProfileImageAsync(AuthService.CurrentUser.Id, compressedBase64);
            }
            
            _profileImageBase64 = compressedBase64;
            SnackbarService.Add("Foto de perfil actualizada", Severity.Success);
        }
        catch (Exception ex)
        {
            SnackbarService.Add("Error al procesar la imagen", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task<string> CompressImageAsync(byte[] imageBytes)
    {
        var originalBytes = imageBytes.Length;
        Console.WriteLine($"[ImageCompression] Original: {originalBytes:N0} bytes ({originalBytes / 1024.0:F1} KB)");
        
        using var inputStream = new MemoryStream(imageBytes);
        using var outputStream = new MemoryStream();
        
        using var image = await SixLabors.ImageSharp.Image.LoadAsync(inputStream);
        
        var newWidth = image.Width / 2;
        var newHeight = image.Height / 2;
        
        if (newWidth < 50) newWidth = 50;
        if (newHeight < 50) newHeight = 50;
        
        image.Mutate(x => x.Resize(newWidth, newHeight));
        
        await image.SaveAsJpegAsync(outputStream, new SixLabors.ImageSharp.Formats.Jpeg.JpegEncoder { Quality = 80 });
        
        var compressedBytes = outputStream.Length;
        var savings = ((double)(originalBytes - compressedBytes) / originalBytes * 100);
        Console.WriteLine($"[ImageCompression] Comprimido: {compressedBytes:N0} bytes ({compressedBytes / 1024.0:F1} KB)");
        Console.WriteLine($"[ImageCompression] Reducción: {savings:F1}% ({originalBytes - compressedBytes:N0} bytes)");
        
        return Convert.ToBase64String(outputStream.ToArray());
    }

    private async Task DeleteProfileImage()
    {
        if (AuthService.CurrentUser == null) return;

        var parameters = new DialogParameters<DeletionConfirmDialog>();
        parameters.Add(x => x.ContentText, "¿Eliminar tu foto de perfil?");
        parameters.Add(x => x.ButtonText, "Eliminar");
        parameters.Add(x => x.Color, Color.Error);

        var dialog = await DialogService.ShowAsync<DeletionConfirmDialog>("Confirmar", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: true })
        {
            _isSaving = true;
            var success = await AuthService.DeleteUserProfileImageAsync(AuthService.CurrentUser.Id);
            _isSaving = false;

            if (success)
            {
                _profileImageBase64 = null;
                SnackbarService.Add("Foto de perfil eliminada", Severity.Success);
            }
            else
            {
                SnackbarService.Add("Error al eliminar la foto", Severity.Error);
            }
        }
    }

    private async Task SaveName()
    {
        if (string.IsNullOrWhiteSpace(_editingName) && string.IsNullOrWhiteSpace(AuthService.CurrentUser?.Name))
        {
            SnackbarService.Add("Escribe un nombre", Severity.Warning);
            return;
        }

        _isSaving = true;

        var success = await AuthService.UpdateUserNameAsync(
            AuthService.CurrentUser!.Id, 
            _editingName);

        _isSaving = false;

        if (success)
        {
            SnackbarService.Add("Nombre actualizado", Severity.Success);
            Navigation.NavigateTo("/profile");
        }
        else
        {
            SnackbarService.Add("Error al guardar", Severity.Error);
        }
    }
}

<style>
    .mud-stack > .mud-typography {
        text-align: center;
    }
    
    .avatar-container {
        position: relative;
        display: inline-block;
    }
    
    .profile-avatar {
        width: 120px !important;
        height: 120px !important;
        font-size: 3rem !important;
        border-radius: 50% !important;
    }
    
    .profile-image {
        width: 120px !important;
        height: 120px !important;
        object-fit: cover !important;
        border-radius: 50% !important;
    }
    
    .avatar-action-buttons {
        position: absolute;
        bottom: -5px;
        right: -5px;
        gap: 2px !important;
    }
    
    .avatar-edit-btn, .avatar-delete-btn {
        background: var(--mud-palette-surface) !important;
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        width: 32px;
        height: 32px;
    }
    
    .avatar-edit-btn:hover {
        background: var(--mud-palette-primary) !important;
        color: white !important;
    }
    
    .avatar-delete-btn:hover {
        background: var(--mud-palette-error) !important;
        color: white !important;
    }
</style>
