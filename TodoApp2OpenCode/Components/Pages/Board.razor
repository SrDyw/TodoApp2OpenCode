@page "/board/{BoardId}"

@inject IDialogService DialogService
@inject ISnackbar SnackbarService
@inject TodoService TodoService
@inject BoardParticipantsService ParticipantsService
@inject IBoardService BoardService
@inject IAuthService AuthService
@inject BottomNavService BottomNavService
@inject NavigationManager Navigation
@inject ILogService LogService
@inject IRealtimeService RealtimeService

<PageTitle>@Config.AppName | Tablero @_currentBoard?.Name</PageTitle>

<SyncIndicator SyncStatus="_syncStatus" />

<MudStack Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
	@if (_boardLoading)
	{
		<MudSkeleton Width="100%" Height="40px" />
		<MudSkeleton Width="50%" Height="20px" />
	}
	else
	{
		<MudText Typo="Typo.h4">
			<MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="mr-2" />
			@_currentBoard!.Name
		</MudText>
		<MudText Color="Color.Primary" Typo="Typo.h5">
			@_currentBoard?.Description
		</MudText>
	}
</MudStack>

@if (_boardLoading)
{
    
}
else
{
    <div class="columns-wrapper">
        <div class="vertical-action-bar column-item">
            <MudTooltip Text="Añadir nueva tarea">
                <MudIconButton Icon="@Icons.Material.Filled.Add" OnClick="OpenNewTaskDialogAsync" Disabled="!_perms.CanAddTasks" />
            </MudTooltip>
            <MudTooltip Text="Participantes">
                <MudMenu Color="Color.Default" Icon="@Icons.Material.Filled.People">
                    <MudMenuItem Disabled="_currentBoard?.OwnerName != AuthService.CurrentUser?.Username">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <UserAvatar Username="@_currentBoard?.OwnerName" UserProfileImage="@_participantImages[_currentBoard?.User ?? ""]" />

                            @_currentBoard?.OwnerName
                            @if (_currentBoard?.OwnerName == AuthService.CurrentUser?.Username)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Primary">(Tú)</MudText>
                            }
                        </MudStack>
                    </MudMenuItem>
                    @if (_currentBoard?.Participants.Any() == true)
                    {
                        <MudDivider />
                        @foreach (var participant in _currentBoard.Participants)
                        {
                            <MudMenuItem OnClick="@(() => ShowUserDetails(participant.Value, participant.Key))" Disabled="_currentBoard?.OwnerName != AuthService.CurrentUser?.Username">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <UserAvatar Username="@participant.Value" UserProfileImage="@_participantImages[participant.Key ?? ""]" />

                                    @participant.Value
                                    @if (participant.Value == AuthService.CurrentUser?.Username)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Primary">(Tú)</MudText>
                                    }
                                    <MudSpacer/>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small" OnClick="@(() => RemoveParticipant(participant.Key))"/>
                                </MudStack>
                            </MudMenuItem>
                        }
                    }
                    @if (isOwner)
                    {
                        <MudDivider />
                        <MudMenuItem OnClick="OpenAddParticipantsDialog">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Small" Color="Color.Primary" />
                                <MudText Color="Color.Primary">Añadir participante</MudText>
                            </MudStack>
                        </MudMenuItem>
                    }
                </MudMenu>
            </MudTooltip>
            @if (_perms.CanViewCalendar || isOwner)
            {
                <MudTooltip Text="Calendario">
                    <MudIconButton Color="Color.Default"
                                   Icon="@Icons.Material.Filled.CalendarMonth"
                                   OnClick="NavigateToSchedule"
                                   @onmousedown:stopPropagation="true" />
                </MudTooltip>
            }
            @if (isOwner)
            {
                <MudTooltip Text="Ajustes">
                    <MudIconButton Color="Color.Default"
                                   Icon="@Icons.Material.Filled.Settings"
                                   OnClick="NavigateToSettings"
                                   @onmousedown:stopPropagation="true" />
                </MudTooltip>
            }
            <MudTooltip Text="Registros">
                <MudIconButton Color="Color.Default"
                               Icon="@Icons.Material.Filled.History"
                               OnClick="NavigateToLogs"
                               @onmousedown:stopPropagation="true" />
            </MudTooltip>
            <MudSpacer />
            <MudDivider />
            @if (isOwner)
            {
                <MudTooltip Text="Borrar tablero">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="OnDeleteBoardButtonClick" />
                </MudTooltip>
            }
        </div>
        <MudDropContainer ItemDisabled="x => _perms.CanModifyTasks" T="TodoItem" Items="_items" @ref="_mudDropContainerRef" ItemsSelector="@((item, dropzone) => item.ColumnId == dropzone)" CanDropClass="mud-border-success" ItemPicked="ItemPicked" ItemDropped="ItemUpdated" Class="board-container columns-list column-item">
            <ChildContent>
                @foreach (var column in _columns)
                {
                    <MudDropZone ItemDisabled="x => _perms.CanModifyTasks == false" T="TodoItem" AllowReorder Identifier="@column.Id" Class="board-column" >
                        <div class="column-header">
                            <div class="column-title-area">
                                
                                <div class="column-color-dot" style="background-color: @column.Color;"></div>
                                <MudText Typo="Typo.h6" Style="font-size: 1rem;" Class="column-title">@column.Name</MudText>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="ml-1">
                                    @(_currentBoard?.Items.Where(x => x.ColumnId == column.Id).Count() ?? 0)
                                </MudChip>
                            </div>

                            @if (_perms.CanEditColumn)
                            {
                                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Dense="true" Edge="Edge.End">
                                        <MudMenuItem OnClick="@(() => EditColumnAsync(column))">
                                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                                <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                                                <span>Editar</span>
                                            </MudStack>
                                        </MudMenuItem>
                                        @if (column.Order > 0)
                                        {
                                        <MudMenuItem OnClick="@(() => MoveColumnAsync(column, direction: -1))">
                                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                                    <MudIcon Icon="@Icons.Material.Filled.ArrowLeft" Size="Size.Small" />
                                                    <span>Mover a la izquerda</span>
                                                </MudStack>
                                            </MudMenuItem>
                                        }
                                        @if (column.Order < (_currentBoard?.Columns.Count - 1 ?? 0))
                                        {
                                            <MudMenuItem OnClick="@(() => MoveColumnAsync(column, direction: 1))">
                                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                                    <MudIcon Icon="@Icons.Material.Filled.ArrowRight" Size="Size.Small" />
                                                    <span>Mover a la derecha</span>
                                                </MudStack>
                                            </MudMenuItem>
                                        }
                                </MudMenu>
                            }
                            @if (_perms.CanDeleteColumn)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Medium" Color="Color.Error" OnClick="@(() => DeleteColumnAsync(column))" />
                            }
                        </div>
                        <div style="width: 100%; margin-top: 12px"/>
                    </MudDropZone>
                }
                @if (_perms.CanAddColumn || isOwner)
                {
                    <div class="board-column add-column-trigger" @onclick="AddColumnAsync">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Large" Class="add-column-icon" />
                        <MudText>Nueva Columna</MudText>
                    </div>
                }
            </ChildContent>
            <ItemRenderer>
                <TodoCard BoardId="@BoardId"
                          Item="@context"
                          CanModify="@_perms.CanModifyTasks"
                          CanDelete="@_perms.CanModifyTasks"
                          ItemUpdated="RefreshItems"
                          ItemDeleted="OnItemDelete"
                          CanShowOnHoverTooltip="_currentPickedItem != null"
                          />
            </ItemRenderer>
        </MudDropContainer>
    </div>
}
<style>
    .add-column-trigger {
        flex: 0 0 320px;
        max-width: 320px;
        background: transparent;
        border: 2px dashed var(--mud-palette-lines-default);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        opacity: 0.6;
        transition: opacity 0.2s, background 0.2s;
        min-height: 200px;
    }

        .add-column-trigger:hover {
            opacity: 1;
            background: var(--mud-palette-surface);
            border-color: var(--mud-palette-primary);
        }
    .board-column {
        flex: 0 0 320px;
        max-width: 320px;
        background: var(--mud-palette-surface);
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        max-height: 100%;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        transition: transform 0.2s, box-shadow 0.2s;
    }


    .action-bar {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 8px 12px;
        margin-bottom: 12px;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .vertical-action-bar {
        display: flex;
        flex-direction: column;
        height: 100%;
        align-items: center;
        gap: 12px;
        padding: 8px 12px;
        margin-bottom: 12px;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .columns-wrapper {
        display: grid;
        grid-template-columns: 64px 1fr;
        height: 100%;
        min-height: 600px;
        padding: 4px;
    }
    .columns-list {
        display: flex;
        gap: 16px;
        height: 100%;
        min-height: 500px;
        padding: 4px;
        overflow-x: scroll;
        border-radius: 16px;
    }

    .column-item {
        margin-right: 8px;
    }
    .board-container {
        width: 100%;
        height: calc(100vh - 150px);
        overflow-x: auto;
        overflow-y: hidden;
        padding-bottom: 20px;
        display: flex;
        gap: 8px;
    }

    .board-column {
        flex: 0 0 320px;
        max-width: 320px;
        background: var(--mud-palette-surface);
        border-radius: 12px;
        padding: 0 8px;
        display: flex;
        flex-direction: column;
        max-height: 100%;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        transition: transform 0.2s, box-shadow 0.2s;
        overflow-y: auto;
    }

    .board-column.drop-zone-hover {
        background: color-mix(in srgb, var(--mud-palette-primary) 10%, transparent);
    }

    .column-header {
        padding: 16px;
        border-bottom: 1px solid var(--mud-palette-divider);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--mud-palette-surface);
        border-radius: 12px 12px 0 0;
        position: sticky;
        z-index: 50;
        left: 0;
        top: 0;
    }

    .column-drag-handle {
        cursor: grab;
    }

        .column-drag-handle:active {
            cursor: grabbing;
        }

    .column-title-area {
        display: flex;
        align-items: center;
        gap: 8px;
        flex: 1;
        min-width: 0;
    }

    .column-color-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .column-title {
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .column-drag-icon {
        opacity: 0.5;
        cursor: grab;
    }

    .column-header:hover .column-drag-icon {
        opacity: 1;
    }

    .column-content {
        flex: 1;
        overflow-y: auto;
        padding: 12px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        min-height: 100px;
        height: 100%;
    }
</style>
@code {
    [Parameter]
    public string? BoardId { get; set; }

    private TodoBoard? _currentBoard;
    private bool _boardLoading = true;

    private int ItemCount { get; set; }

    private List<TodoItem> _items = [];

    private TodoItem? _currentPickedItem = null;

    private BoardPermissions? _perms;
    private bool isOwner = false;

    private List<TodoColumn> _columns = [];
    private Dictionary<string, string?> _participantImages = new();

    private MudDropContainer<TodoItem>? _mudDropContainerRef;

    private SyncIndicator.OperationSyncStatus _syncStatus;

    private System.Threading.Timer? _membershipCheckTimer;
    private bool _isStillMember = true;


    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(BoardId))
        {
            NotFound();
            return;
        }
        _currentBoard = await BoardService.GetBoardAsync(BoardId);

        if (_currentBoard == null)
        {
            NotFound();
            return;
        }

        await AuthService.CheckAuthStateAsync();
        if (AuthService.CurrentUser == null)
        {
            Navigation.NavigateTo("/");
            return;
        }

        if (!BoardUtils.IsUserOwnerOrParticipant(_currentBoard, AuthService.CurrentUser.Id))
        {
            SnackbarService.Add($"Has sido eliminado del tablero '{_currentBoard.Name}'", Severity.Warning);
            Navigation.NavigateTo("/");
            return;
        }

        _items = _currentBoard.Items.OrderBy(x => x.Order).ToList();
        _perms = BoardUtils.GetUserPermissions(_currentBoard, AuthService.CurrentUser.Id);
        isOwner = _currentBoard.User == AuthService.CurrentUser.Id;
        _columns = _currentBoard.Columns;
        _boardLoading = false;
        _isStillMember = true;

        await LoadParticipantImagesAsync();

        _membershipCheckTimer?.Dispose();
        _membershipCheckTimer = new System.Threading.Timer(
            async _ => await CheckMembershipAsync(),
            null,
            TimeSpan.FromSeconds(10),
            TimeSpan.FromSeconds(10)
        );

        await InvokeAsync(StateHasChanged);
    }

    private async Task CheckMembershipAsync()
    {
        if (string.IsNullOrEmpty(BoardId) || AuthService.CurrentUser == null) return;

        var board = await BoardService.GetBoardAsync(BoardId);
        if (board == null)
        {
            _membershipCheckTimer?.Dispose();
            SnackbarService.Add("El tablero ya no existe", Severity.Warning);
            Navigation.NavigateTo("/");
            return;
        }

        if (!BoardUtils.IsUserOwnerOrParticipant(board, AuthService.CurrentUser.Id))
        {
            _membershipCheckTimer?.Dispose();
            _isStillMember = false;
            SnackbarService.Add($"Has sido eliminado del tablero '{board.Name}'", Severity.Warning);
            Navigation.NavigateTo("/");
            return;
        }

        _currentBoard = board;
        _perms = BoardUtils.GetUserPermissions(board, AuthService.CurrentUser.Id);
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _membershipCheckTimer?.Dispose();
    }

    private async Task RefreshItems(TodoItem item)
    {
        if (!_isStillMember) return;
        _items[_items.IndexOf(_items.First(x => x.Id == item.Id))] = item;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnItemDelete(TodoItem item)
    {
        if (!_isStillMember) return;
        _items.Remove(item);
        await InvokeAsync(StateHasChanged);
    }
    private async Task AddColumnAsync()
    {
        if (!_isStillMember) return;
        if (_syncStatus == SyncIndicator.OperationSyncStatus.Syncing)
        {
            SnackbarService.Add(SystemMessages.PENDING_OPERATION, Severity.Info);
            return;
        }
        if (_perms == null || !_perms.CanAddColumn && !isOwner)
        {
            SnackbarService.Add(SystemMessages.ADD_COLUMN_DENIED, Severity.Warning);
            return;
        }

        var parameters = new DialogParameters<InputDialog>();
        parameters.Add(x => x.Title, "Nueva Columna");
        parameters.Add(x => x.ContentText, "Nombre de la columna:");
        parameters.Add(x => x.Placeholder, "Nombre...");
        parameters.Add(x => x.ButtonText, "Crear");

        var dialog = await DialogService.ShowAsync<InputDialog>("Nueva Columna", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: string name } && !string.IsNullOrWhiteSpace(name))
        {
            _syncStatus = SyncIndicator.OperationSyncStatus.Syncing;

            var column = new TodoColumn
            {
                Id = Guid.NewGuid().ToString(),
                Name = name.Trim(),
                BoardId = BoardId,
                Color = "#7e6fff",
                Order = _currentBoard.Columns.Count,
                CreatedAt = DateTime.Now,
                UpdatedAt = DateTime.Now
            };

            var (msg, success) = await BoardService.AddColumnAsync(BoardId, column);
            if (success != null && (bool)success)
            {
                _columns.Add(column);
                _syncStatus = SyncIndicator.OperationSyncStatus.Success;
                SnackbarService.Add(msg, Severity.Success);
            }
            else
            {
                _syncStatus = SyncIndicator.OperationSyncStatus.Error;
                SnackbarService.Add(msg, Severity.Error);
            }
        }
    }
    private async Task EditColumnAsync(TodoColumn Column)
    {
        if (!_isStillMember) return;
        if (_syncStatus == SyncIndicator.OperationSyncStatus.Syncing)
        {
            SnackbarService.Add(SystemMessages.PENDING_OPERATION, Severity.Info);
            return;
        }
        if (string.IsNullOrEmpty(BoardId)) return;

        var defaultColumnName = Column.Name;

        var editing = new TodoColumn { Id = Column.Id, Name = Column.Name, Color = Column.Color, CreatedAt = Column.CreatedAt, UpdatedAt = Column.UpdatedAt };
        var parameters = new DialogParameters<EditColumnDialog>();
        parameters.Add(x => x.Column, editing);

        var dialog = await DialogService.ShowAsync<EditColumnDialog>("Editar Columna", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: EditColumnDialog.EditColumnResult editResult })
        {
            _syncStatus = SyncIndicator.OperationSyncStatus.Syncing;


            var (msg, success) = await BoardService.UpdateColumnAsync(BoardId, editing);
            if (success)
            {
                var targetColumnIndex = _columns.IndexOf(_columns.FirstOrDefault(x => x.Id == editing.Id) ?? new());
                if (targetColumnIndex != -1)
                {
                    _columns[targetColumnIndex] = editing;
                }

                if (string.IsNullOrWhiteSpace(editResult.NewName) == false)
                {
                    await LogService.AddLogAsync(new LogItem
                    {
                        Action = DatabaseAction.Actualizar,
                        BoardId = BoardId,
                        Message = $"Actualiza columna {defaultColumnName} -> {editResult.NewName}",
                        User = AuthService.CurrentUser?.Username ?? ""
                    });
                }
                if (string.IsNullOrWhiteSpace(editResult.NewColor) == false)
                {
                    await LogService.AddLogAsync(new LogItem
                    {
                        Action = DatabaseAction.Actualizar,
                        BoardId = BoardId,
                        Message = $"Actualiza color de la columna a {editResult.NewColor}",
                        User = AuthService.CurrentUser?.Username ?? ""
                    });
                }
                _syncStatus = SyncIndicator.OperationSyncStatus.Success;
                SnackbarService.Add("Columna actualizada", Severity.Success);
            }
            else
            {
                _syncStatus = SyncIndicator.OperationSyncStatus.Error;
                SnackbarService.Add(msg, Severity.Error);
            }
        }
    }

    private async Task DeleteColumnAsync(TodoColumn Column)
    {
        if (!_isStillMember) return;
        if (_syncStatus == SyncIndicator.OperationSyncStatus.Syncing)
        {
            SnackbarService.Add(SystemMessages.PENDING_OPERATION, Severity.Info);
            return;
        }
        if (string.IsNullOrEmpty(BoardId)) return;

        var count = _items.Count(x => x.ColumnId == Column.Id);
        var msg = count > 0 ? $"¿Eliminar '{Column.Name}' y sus {count} tareas?" : $"¿Eliminar '{Column.Name}'?";
        var parameters = new DialogParameters<DeletionConfirmDialog>();
        parameters.Add(x => x.ContentText, msg);
        parameters.Add(x => x.ButtonText, "Eliminar");
        parameters.Add(x => x.Color, Color.Error);

        var dialog = await DialogService.ShowAsync<DeletionConfirmDialog>("Confirmar", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: true })
        {
            _syncStatus = SyncIndicator.OperationSyncStatus.Syncing;

            var (deleteMsg, success) = await BoardService.DeleteColumnAsync(BoardId, Column.Id);
            if (success != null && (bool)success)
            {
                _columns.Remove(_columns.FirstOrDefault(x => x.Id == Column.Id) ?? new());
                _syncStatus = SyncIndicator.OperationSyncStatus.Success;
                SnackbarService.Add("Columna eliminada", Severity.Success);
            }
            else
            {
                _syncStatus = SyncIndicator.OperationSyncStatus.Error;
                SnackbarService.Add(deleteMsg, Severity.Error);
            }
        }
    }
    private async Task OpenNewTaskDialogAsync()
    {
        if (!_isStillMember) return;
        if (_syncStatus == SyncIndicator.OperationSyncStatus.Syncing)
        {
            SnackbarService.Add(SystemMessages.PENDING_OPERATION, Severity.Info);
            return;
        }
        if(_currentBoard == null)
        {
            return;
        }

        if (!_currentBoard.Columns.Any())
        {
            SnackbarService.Add("Primero crea una columna", Severity.Warning);
            return;
        }

        var parameters = new DialogParameters<NewTaskDialog>();
        parameters.Add(x => x.Columns, _currentBoard.Columns);
        parameters.Add(x => x.Participants, BoardUtils.GetParticipantsDictionary(_currentBoard));

        var dialog = await DialogService.ShowAsync<NewTaskDialog>("Nueva Tarea", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: TodoItem newItem })
        {
            _syncStatus = SyncIndicator.OperationSyncStatus.Syncing;

            var (msg, success) = await TodoService.AddItemAsync(BoardId!, newItem);
            if (success)
            {
                await LogService.AddLogAsync(new LogItem
                {
                    Action = DatabaseAction.Crear,
                    BoardId = BoardId!,
                    Message = $"Añade tarea {newItem.Title}",
                    User = AuthService.CurrentUser!.Username
                });
                _items.Add(newItem);
                _syncStatus = SyncIndicator.OperationSyncStatus.Success;
                SnackbarService.Add(msg, Severity.Success);
            }
            else
            {
                _syncStatus = SyncIndicator.OperationSyncStatus.Error;
                SnackbarService.Add(msg, Severity.Error);
            }
        }
    }

    private async Task ShowUserDetails(string userName, string userId)
    {
        if (!_isStillMember) return;
        BoardPermissions? permissions = null;
        if (_currentBoard?.ParticipantPermissions != null &&
            _currentBoard.ParticipantPermissions.TryGetValue(userId, out var perms))
        {
            permissions = perms;
        }

        var parameters = new DialogParameters<UserDetailsDialog>
        {
            { x => x.UserName, userName },
            { x => x.UserId, userId },
            { x => x.BoardId, BoardId },
            { x => x.CurrentPermissions, permissions },
            {x => x.UserProfileImage, _participantImages[userId]}
        };

        var dialog = await DialogService.ShowAsync<UserDetailsDialog>("", parameters);
        var result = await dialog.Result;
    }

    private async Task OpenAddParticipantsDialog()
    {
        if (!_isStillMember) return;
        if (_syncStatus == SyncIndicator.OperationSyncStatus.Syncing)
        {
            SnackbarService.Add(SystemMessages.PENDING_OPERATION, Severity.Info);
            return;
        }
        if (!isOwner || string.IsNullOrEmpty(BoardId) || _currentBoard == null) return;

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small
        };

        var parameters = new DialogParameters<AddParticipantsDialog>();
        parameters.Add(x => x.ExistingParticipantIds, _currentBoard.Participants.Keys.ToList());

        var dialog = await DialogService.ShowAsync<AddParticipantsDialog>("Añadir participantes", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: List<(string Id, string Name)> selectedParticipants })
        {
            if (selectedParticipants.Count == 0) return;

            _syncStatus = SyncIndicator.OperationSyncStatus.Syncing;

            var (msg, success) = await ParticipantsService.AddParticipantsAsync(BoardId, _currentBoard, selectedParticipants, AuthService.CurrentUser?.Username ?? "");
            if (success)
            {
                _syncStatus = SyncIndicator.OperationSyncStatus.Success;
                Navigation.Refresh(forceReload: true);
                return;
            }

            _syncStatus = SyncIndicator.OperationSyncStatus.Error;
            SnackbarService.Add(msg, Severity.Error);

        }
    }

    private async Task RemoveParticipant(string participantId)
    {
        if (!_isStillMember) return;
        if (_syncStatus == SyncIndicator.OperationSyncStatus.Syncing)
        {
            SnackbarService.Add(SystemMessages.PENDING_OPERATION, Severity.Info);
            return;
        }
        if (!isOwner || string.IsNullOrEmpty(BoardId) || _currentBoard == null) return;


        var parameters = new DialogParameters<DeletionConfirmDialog>();
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small
        };
        parameters.Add(x => x.ContentText, $"Seguro deseas remover del tablero a {_currentBoard.Participants[participantId]}");
        var dialog = await DialogService.ShowAsync<DeletionConfirmDialog>($"Remover participante", parameters, options);
        var result = await dialog.Result;

        if (result is {Data: true})
        {
            if (ParticipantsService.HasIncompleteSteps(participantId, _items))
            {
                SnackbarService.Add("El usuario no se puede quitar del tablero porque tiene tareas asignadas sin completar", Severity.Error);
                return;
            }

            _syncStatus = SyncIndicator.OperationSyncStatus.Syncing;

            var (msg, success) = await BoardService.RemoveParticipantAsync(BoardId, participantId);
            if (success != null && (bool)success)
            {
                await ParticipantsService.RemoveParticipantAsync(BoardId, _currentBoard, participantId, _items, StateHasChanged);
                _syncStatus = SyncIndicator.OperationSyncStatus.Success;
                SnackbarService.Add("Participante removido", Severity.Info);
            }
            else
            {
                _syncStatus = SyncIndicator.OperationSyncStatus.Error;
                SnackbarService.Add(msg, Severity.Error);
            }
        }
    }

    private async Task ConfirmRemoveParticipant(string participantId, string participantName)
    {
        if (!_isStillMember) return;
        if (!isOwner) return;


        if (ParticipantsService.HasIncompleteSteps(participantId, _items))
        {
            SnackbarService.Add("El usuario no se puede quitar del tablero porque tiene tareas asignadas sin completar", Severity.Error);
            return;
        }

        var parameters = new DialogParameters<DeletionConfirmDialog>();
        parameters.Add(x => x.ContentText, $"¿Estás seguro de que deseas remover a {participantName} del tablero?");
        parameters.Add(x => x.ButtonText, "Remover");
        parameters.Add(x => x.Color, Color.Error);

        var dialog = await DialogService.ShowAsync<DeletionConfirmDialog>("Remover participante", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await RemoveParticipant(participantId);
            
        }
    }
