    private async Task LoadParticipantImagesAsync()
    {
        if (_currentBoard == null) return;

        var userIds = _currentBoard.Participants.Keys.ToList();
        if (!string.IsNullOrEmpty(_currentBoard.User))
        {
            userIds.Add(_currentBoard.User);
        }

        foreach (var userId in userIds)
        {
            if (!_participantImages.ContainsKey(userId))
            {
                var image = await AuthService.GetUserProfileImageAsync(userId);
                _participantImages[userId] = image;
            }
        }
    }
