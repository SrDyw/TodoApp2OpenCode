    private async Task OnDeleteBoardButtonClick()
    {
        if (!_isStillMember) return;
        if (_syncStatus == SyncIndicator.OperationSyncStatus.Syncing)
        {
            SnackbarService.Add(SystemMessages.PENDING_OPERATION, Severity.Info);
            return;
        }
        if (_currentBoard == null) return;

        var dialogParams = new DialogParameters<SecureDeletionConfirmDialog>();
        dialogParams.Add(x => x.ContentText, "¿Seguro que desea borrar el tablero con todo su contenido? La accion es irreversible.");
        dialogParams.Add(x => x.RequestedItem, _currentBoard.Name);
        dialogParams.Add(x => x.ButtonText, "Borrar tablero");

        var dialog = await DialogService.ShowAsync<SecureDeletionConfirmDialog>("Borrar el tablero", dialogParams, new DialogOptions
        {
            CloseOnEscapeKey = false
        });
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: true })
        {
            _syncStatus = SyncIndicator.OperationSyncStatus.Syncing;

            var (msg, deletionResult) = await BoardService.DeleteBoardAsync(_currentBoard.Id);
            if (deletionResult != null && (bool)deletionResult)
            {
                _syncStatus = SyncIndicator.OperationSyncStatus.Success;
                Navigation.NavigateTo("/", forceLoad: true);
            }
            else
            {
                _syncStatus = SyncIndicator.OperationSyncStatus.Error;
                SnackbarService.Add(msg, Severity.Error);
            }
        }
    }
    private void ItemPicked(MudDragAndDropItemTransaction<TodoItem> dropItem)
    {
        if (dropItem.Item == null)
        {
            SnackbarService.Add(SystemMessages.ITEM_UPDATE_ERROR);
            return;
        }
        _currentPickedItem = dropItem.Item;
    }

    private async Task ItemUpdated(MudItemDropInfo<TodoItem> dropItem)
    {
        if (!_isStillMember) return;
        if (dropItem.Item == null || _currentBoard == null) return;

        var item = dropItem.Item;
        var targetIndexInZone = dropItem.IndexInZone;
        var targetColumnId = dropItem.DropzoneIdentifier;

        if (item.ColumnId == dropItem.DropzoneIdentifier)
        {
            var itemCount = _currentBoard.Items
                .Where(x => x.ColumnId == item.ColumnId)
                .Count();

            if (itemCount <= 1 || item.Order == targetIndexInZone)
                return;
        }


        if (_syncStatus == SyncIndicator.OperationSyncStatus.Syncing)
        {
            SnackbarService.Add(SystemMessages.PENDING_OPERATION, Severity.Info);
            return;
        }

        if (dropItem.Item == null || _currentBoard == null || string.IsNullOrWhiteSpace(BoardId))
        {
            SnackbarService.Add(SystemMessages.ITEM_UPDATE_ERROR);
            return;
        }
        _syncStatus = SyncIndicator.OperationSyncStatus.Syncing;



        _currentPickedItem = null;
        var (updatedBoard, msg) = await TodoService.MoveItemAsync(item.Id, BoardId, targetIndexInZone, targetColumnId);


        if (updatedBoard == null)
        {
            SnackbarService.Add(msg, Severity.Error);
            _syncStatus = SyncIndicator.OperationSyncStatus.Error;

            return;
        }

        _syncStatus = SyncIndicator.OperationSyncStatus.Success;
        item.ColumnId = dropItem.DropzoneIdentifier;
    }

    private async Task MoveColumnAsync(TodoColumn column, int direction)
    {
        if (!_isStillMember) return;
        if (_syncStatus == SyncIndicator.OperationSyncStatus.Syncing)
        {
            SnackbarService.Add(SystemMessages.PENDING_OPERATION, Severity.Info);
            return;
        }
        if (_currentBoard == null) return;

        _syncStatus = SyncIndicator.OperationSyncStatus.Syncing;

        var (msg, success) = await BoardService.SwapColumnAsync(_currentBoard.Id, column.Id, _currentBoard.Columns[column.Order + Math.Sign(direction)].Id);
        if (success != null && (bool)success)
        {
            _syncStatus = SyncIndicator.OperationSyncStatus.Success;
            Navigation.Refresh(forceReload: true);
        }
        else
        {
            _syncStatus = SyncIndicator.OperationSyncStatus.Error;
            SnackbarService.Add(msg, Severity.Error);
        }
    }


