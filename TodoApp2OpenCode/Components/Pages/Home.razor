@page "/"
@inject NavigationManager Navigation
@inject IAuthService AuthService
@inject IBoardService BoardService
@inject IDialogService DialogService

<style>
    .landing-container {
        min-height: 100vh;
        background: linear-gradient(135deg, var(--mud-palette-background) 0%, var(--mud-palette-surface) 100%);
    }

    .hero-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 80px 20px;
        text-align: center;
    }

    .hero-title {
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 16px;
        background: linear-gradient(135deg, var(--mud-palette-primary) 0%, #a78bfa 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-subtitle {
        font-size: 1.25rem;
        color: var(--mud-palette-text-secondary);
        max-width: 600px;
        margin-bottom: 32px;
        line-height: 1.6;
    }

    .hero-buttons {
        display: flex;
        gap: 16px;
        margin-bottom: 60px;
    }

    .btn-primary {
        padding: 14px 32px;
        border-radius: 8px;
        background: var(--mud-palette-primary);
        color: white;
        font-weight: 600;
        font-size: 1rem;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-primary:hover {
        background: var(--mud-palette-primary-hover);
        transform: translateY(-2px);
    }

    .btn-secondary {
        padding: 14px 32px;
        border-radius: 8px;
        background: transparent;
        color: var(--mud-palette-text-primary);
        font-weight: 600;
        font-size: 1rem;
        border: 2px solid var(--mud-palette-lines-default);
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-secondary:hover {
        border-color: var(--mud-palette-primary);
        color: var(--mud-palette-primary);
    }

    .mockup-section {
        max-width: 900px;
        margin: 0 auto 60px;
        padding: 0 20px;
    }

    .mockup-container {
        background: var(--mud-palette-surface);
        border-radius: 16px;
        padding: 24px;
        border: 1px solid var(--mud-palette-lines-default);
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    }

    .mockup-header {
        display: flex;
        gap: 12px;
        margin-bottom: 20px;
    }

    .mockup-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
    }

    .mockup-columns {
        display: flex;
        gap: 16px;
        overflow-x: auto;
        padding-bottom: 12px;
    }

    .mockup-column {
        flex: 0 0 200px;
        background: var(--mud-palette-background);
        border-radius: 12px;
        padding: 16px;
    }

    .mockup-column-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 12px;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .mockup-card {
        background: var(--mud-palette-surface);
        border-radius: 8px;
        padding: 12px;
        margin-bottom: 8px;
        border: 1px solid var(--mud-palette-lines-default);
    }

    .mockup-card-title {
        font-size: 0.85rem;
        margin-bottom: 4px;
    }

    .mockup-card-desc {
        font-size: 0.75rem;
        color: var(--mud-palette-text-secondary);
    }

    .footer {
        text-align: center;
        padding: 40px 20px;
        border-top: 1px solid var(--mud-palette-lines-default);
        color: var(--mud-palette-text-secondary);
    }

    .landing-section {
        max-width: 1200px;
        margin: 0 auto;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 24px;
        margin-bottom: 60px;
    }

    .feature-card {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 16px;
        padding: 32px 24px;
        transition: all 0.3s ease;
    }

        .feature-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 16px 48px rgba(126, 111, 255, 0.12);
            border-color: var(--mud-palette-primary);
        }

    .feature-icon-wrapper {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        background: linear-gradient(135deg, rgba(126, 111, 255, 0.15) 0%, rgba(126, 111, 255, 0.05) 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
    }

    .feature-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--mud-palette-text-primary);
        margin-bottom: 12px;
    }

    .feature-description {
        color: var(--mud-palette-text-secondary);
        font-size: 0.95rem;
        line-height: 1.6;
    }

    .cta-section {
        background: linear-gradient(135deg, var(--mud-palette-primary) 0%, #9f85ff 100%);
        border-radius: 24px;
        padding: 48px;
        text-align: center;
        color: white;
    }

    .cta-title {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 16px;
    }

    .cta-description {
        font-size: 1.1rem;
        opacity: 0.9;
        margin-bottom: 32px;
        line-height: 1.6;
    }

    .cta-button {
        background: white !important;
        color: var(--mud-palette-primary) !important;
        font-weight: 600;
        padding: 12px 32px;
        border-radius: 12px;
    }

    .section-label {
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--mud-palette-primary);
        margin-bottom: 12px;
    }
</style>

<div class="landing-container">
    <section class="hero-section">
        <h1 class="hero-title">@Config.AppName</h1>
        <p class="hero-subtitle">
            Organiza tus tareas de forma visual e intuitiva. 
            Crea tableros, arrastra tareas entre columnas y mantén tu productividad al máximo.
        </p>
        <div class="hero-buttons">
            <button class="btn-primary" @onclick="OpenRegisterDialog">Crear cuenta</button>
            @if (!AuthService.IsAuthenticated)
            {
                <button class="btn-secondary" @onclick="OpenLoginDialog">Iniciar sesión</button>
            }
        </div>
    </section>

    <section class="mockup-section">
        <div class="mockup-container">
            <div class="mockup-header">
                <div class="mockup-dot" style="background: #ff5f56;"></div>
                <div class="mockup-dot" style="background: #ffbd2e;"></div>
                <div class="mockup-dot" style="background: #27ca40;"></div>
            </div>
            <div class="mockup-columns">
                <div class="mockup-column">
                    <div class="mockup-column-header">
                        <div style="width: 8px; height: 8px; border-radius: 50%; background: #ff6b6b;"></div>
                        Por hacer
                    </div>
                    <div class="mockup-card">
                        <div class="mockup-card-title">Diseñar landing page</div>
                        <div class="mockup-card-desc">Crear mockups y wireframes</div>
                    </div>
                    <div class="mockup-card">
                        <div class="mockup-card-title">Implementar auth</div>
                        <div class="mockup-card-desc">Sistema de login y registro</div>
                    </div>
                </div>
                <div class="mockup-column">
                    <div class="mockup-column-header">
                        <div style="width: 8px; height: 8px; border-radius: 50%; background: #ffb545;"></div>
                        En progreso
                    </div>
                    <div class="mockup-card">
                        <div class="mockup-card-title">Desarrollar API</div>
                        <div class="mockup-card-desc">Endpoints REST para el board</div>
                    </div>
                </div>
                <div class="mockup-column">
                    <div class="mockup-column-header">
                        <div style="width: 8px; height: 8px; border-radius: 50%; background: #3dcb6c;"></div>
                        Completado
                    </div>
                    <div class="mockup-card">
                        <div class="mockup-card-title">Setup proyecto</div>
                        <div class="mockup-card-desc">Configurar Blazor y MudBlazor</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="landing-section">
        <MudText Typo="Typo.h4" Style="text-align:center; margin-bottom: 16px">Funcionalidades</MudText>

        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon-wrapper">
                    <MudIcon Icon="@Icons.Material.Filled.ViewKanban" Size="Size.Large" Color="Color.Primary" />
                </div>
                <div class="feature-title">Tableros Visuales</div>
                <div class="feature-description">
                    Crea tableros ilimitados para organizar tus proyectos. Cada tablero tiene columnas personalizables que puedes nombrar y colorizar.
                </div>
            </div>

            <div class="feature-card">
                <div class="feature-icon-wrapper">
                    <MudIcon Icon="@Icons.Material.Filled.SwapVert" Size="Size.Large" Color="Color.Primary" />
                </div>
                <div class="feature-title">Drag & Drop</div>
                <div class="feature-description">
                    Arrastra tareas entre columnas con un clic. Reordena tus columnas y tareas de forma fluida e intuitiva.
                </div>
            </div>

            <div class="feature-card">
                <div class="feature-icon-wrapper">
                    <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Color="Color.Primary" />
                </div>
                <div class="feature-title">Colaboración</div>
                <div class="feature-description">
                    Añade participantes a tus tableros. Asigna tareas, sigue el progreso y trabaja en equipo en tiempo real.
                </div>
            </div>

            <div class="feature-card">
                <div class="feature-icon-wrapper">
                    <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Large" Color="Color.Primary" />
                </div>
                <div class="feature-title">Calendario</div>
                <div class="feature-description">
                    Programa eventos y tareas con fechas. Visualiza tu agenda en el calendario integrado de cada tablero.
                </div>
            </div>

            <div class="feature-card">
                <div class="feature-icon-wrapper">
                    <MudIcon Icon="@Icons.Material.Filled.Notifications" Size="Size.Large" Color="Color.Primary" />
                </div>
                <div class="feature-title">Notificaciones</div>
                <div class="feature-description">
                    Recibe alertas cuando te añadan a un tablero o evento. Mantente informado de todo lo que pasa.
                </div>
            </div>

            <div class="feature-card">
                <div class="feature-icon-wrapper">
                    <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Size="Size.Large" Color="Color.Primary" />
                </div>
                <div class="feature-title">Permisos Granulares</div>
                <div class="feature-description">
                    Controla qué pueden hacer cada participante. Define quién puede añadir, editar o eliminar tareas y columnas.
                </div>
            </div>
        </div>

        <div class="cta-section">
            <div class="cta-title">¿Listo para empezar?</div>
            <div class="cta-description">
                Inicia sesión comienza a organizar tus proyectos de forma visual
            </div>
            <MudButton Variant="Variant.Filled" Class="cta-button" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenLoginDialog">
                Iniciar sesión
            </MudButton>
        </div>
    </div>

    <footer class="footer">
        <p>@Config.AppName © 2024 - Organiza tu flujo de trabajo</p>
    </footer>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await AuthService.CheckAuthStateAsync();
        
        if (AuthService.IsAuthenticated && AuthService.CurrentUser != null)
        {
            Navigation.NavigateTo("/board", forceLoad: true);
        }
    }

    private async Task OpenRegisterDialog()
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<RegisterDialog>("Crear Cuenta", options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: true })
        {
            Navigation.NavigateTo("/board", forceLoad: true);
        }
    }

    private async Task OpenLoginDialog()
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<LoginDialog>("Iniciar Sesión", options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: true })
        {
            Navigation.NavigateTo("/board", forceLoad: true);
        }
    }
}
