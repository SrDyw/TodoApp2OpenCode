@page "/"
@inject NavigationManager Navigation
@inject IAuthService AuthService
@inject IBoardService BoardService
@inject IDialogService DialogService

<style>
    .landing-container {
        min-height: 100vh;
        background: linear-gradient(135deg, var(--mud-palette-background) 0%, var(--mud-palette-surface) 100%);
    }

    .hero-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 80px 20px;
        text-align: center;
    }

    .hero-title {
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 16px;
        background: linear-gradient(135deg, var(--mud-palette-primary) 0%, #a78bfa 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-subtitle {
        font-size: 1.25rem;
        color: var(--mud-palette-text-secondary);
        max-width: 600px;
        margin-bottom: 32px;
        line-height: 1.6;
    }

    .hero-buttons {
        display: flex;
        gap: 16px;
        margin-bottom: 60px;
    }

    .btn-primary {
        padding: 14px 32px;
        border-radius: 8px;
        background: var(--mud-palette-primary);
        color: white;
        font-weight: 600;
        font-size: 1rem;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-primary:hover {
        background: var(--mud-palette-primary-hover);
        transform: translateY(-2px);
    }

    .btn-secondary {
        padding: 14px 32px;
        border-radius: 8px;
        background: transparent;
        color: var(--mud-palette-text-primary);
        font-weight: 600;
        font-size: 1rem;
        border: 2px solid var(--mud-palette-lines-default);
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-secondary:hover {
        border-color: var(--mud-palette-primary);
        color: var(--mud-palette-primary);
    }

    .features-section {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 24px;
        max-width: 1000px;
        margin: 0 auto;
        padding: 40px 20px 80px;
    }

    .feature-card {
        background: var(--mud-palette-surface);
        border-radius: 16px;
        padding: 32px;
        border: 1px solid var(--mud-palette-lines-default);
        transition: all 0.3s;
    }

    .feature-card:hover {
        transform: translateY(-4px);
        border-color: var(--mud-palette-primary);
        box-shadow: 0 8px 30px rgba(126, 111, 255, 0.15);
    }

    .feature-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--mud-palette-primary) 0%, #a78bfa 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        font-size: 24px;
    }

    .feature-title {
        font-size: 1.25rem;
        font-weight: 600;
        margin-bottom: 12px;
        color: var(--mud-palette-text-primary);
    }

    .feature-description {
        color: var(--mud-palette-text-secondary);
        line-height: 1.6;
    }

    .mockup-section {
        max-width: 900px;
        margin: 0 auto 60px;
        padding: 0 20px;
    }

    .mockup-container {
        background: var(--mud-palette-surface);
        border-radius: 16px;
        padding: 24px;
        border: 1px solid var(--mud-palette-lines-default);
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    }

    .mockup-header {
        display: flex;
        gap: 12px;
        margin-bottom: 20px;
    }

    .mockup-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
    }

    .mockup-columns {
        display: flex;
        gap: 16px;
        overflow-x: auto;
        padding-bottom: 12px;
    }

    .mockup-column {
        flex: 0 0 200px;
        background: var(--mud-palette-background);
        border-radius: 12px;
        padding: 16px;
    }

    .mockup-column-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 12px;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .mockup-card {
        background: var(--mud-palette-surface);
        border-radius: 8px;
        padding: 12px;
        margin-bottom: 8px;
        border: 1px solid var(--mud-palette-lines-default);
    }

    .mockup-card-title {
        font-size: 0.85rem;
        margin-bottom: 4px;
    }

    .mockup-card-desc {
        font-size: 0.75rem;
        color: var(--mud-palette-text-secondary);
    }

    .footer {
        text-align: center;
        padding: 40px 20px;
        border-top: 1px solid var(--mud-palette-lines-default);
        color: var(--mud-palette-text-secondary);
    }
</style>

<div class="landing-container">
    <section class="hero-section">
        <h1 class="hero-title">FlowBoard</h1>
        <p class="hero-subtitle">
            Organiza tus tareas de forma visual e intuitiva. 
            Crea tableros, arrastra tareas entre columnas y mantén tu productividad al máximo.
        </p>
        <div class="hero-buttons">
            <button class="btn-primary" @onclick="OpenRegisterDialog">Comenzar gratis</button>
            <button class="btn-secondary" @onclick="OpenLoginDialog">Iniciar sesión</button>
        </div>
    </section>

    <section class="mockup-section">
        <div class="mockup-container">
            <div class="mockup-header">
                <div class="mockup-dot" style="background: #ff5f56;"></div>
                <div class="mockup-dot" style="background: #ffbd2e;"></div>
                <div class="mockup-dot" style="background: #27ca40;"></div>
            </div>
            <div class="mockup-columns">
                <div class="mockup-column">
                    <div class="mockup-column-header">
                        <div style="width: 8px; height: 8px; border-radius: 50%; background: #ff6b6b;"></div>
                        Por hacer
                    </div>
                    <div class="mockup-card">
                        <div class="mockup-card-title">Diseñar landing page</div>
                        <div class="mockup-card-desc">Crear mockups y wireframes</div>
                    </div>
                    <div class="mockup-card">
                        <div class="mockup-card-title">Implementar auth</div>
                        <div class="mockup-card-desc">Sistema de login y registro</div>
                    </div>
                </div>
                <div class="mockup-column">
                    <div class="mockup-column-header">
                        <div style="width: 8px; height: 8px; border-radius: 50%; background: #ffb545;"></div>
                        En progreso
                    </div>
                    <div class="mockup-card">
                        <div class="mockup-card-title">Desarrollar API</div>
                        <div class="mockup-card-desc">Endpoints REST para el board</div>
                    </div>
                </div>
                <div class="mockup-column">
                    <div class="mockup-column-header">
                        <div style="width: 8px; height: 8px; border-radius: 50%; background: #3dcb6c;"></div>
                        Completado
                    </div>
                    <div class="mockup-card">
                        <div class="mockup-card-title">Setup proyecto</div>
                        <div class="mockup-card-desc">Configurar Blazor y MudBlazor</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="features-section">
        <div class="feature-card">
            <div class="feature-icon">📋</div>
            <h3 class="feature-title">Tableros personalizados</h3>
            <p class="feature-description">
                Crea tantos tableros como necesites. Cada uno con sus propias columnas y tareas, organizado a tu manera.
            </p>
        </div>
        <div class="feature-card">
            <div class="feature-icon">🔄</div>
            <h3 class="feature-title">Drag & Drop</h3>
            <p class="feature-description">
                Mueve tareas entre columnas con un simple arrastre. Reorganiza tus columnas también de forma intuitiva.
            </p>
        </div>
        <div class="feature-card">
            <div class="feature-icon">⚡</div>
            <h3 class="feature-title">Sincronización en tiempo real</h3>
            <p class="feature-description">
                Tus cambios se guardan instantáneamente. Interfaz fluida con actualizaciones optimistas.
            </p>
        </div>
        <div class="feature-card">
            <div class="feature-icon">🌙</div>
            <h3 class="feature-title">Modo oscuro</h3>
            <p class="feature-description">
                Trabaja cómodamente con el tema que prefieras. Cambio automático según tu sistema.
            </p>
        </div>
        <div class="feature-card">
            <div class="feature-icon">📱</div>
            <h3 class="feature-title">Responsive</h3>
            <p class="feature-description">
                Accede desde cualquier dispositivo. Tu tablero siempre contigo, en cualquier lugar.
            </p>
        </div>
        <div class="feature-card">
            <div class="feature-icon">🔒</div>
            <h3 class="feature-title">Datos seguros</h3>
            <p class="feature-description">
                Tu información se guarda de forma segura. Solo tú tienes acceso a tus tableros.
            </p>
        </div>
    </section>

    <footer class="footer">
        <p>FlowBoard © 2024 - Organiza tu flujo de trabajo</p>
    </footer>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await AuthService.CheckAuthStateAsync();
    }

    private async Task OpenRegisterDialog()
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.ExtraSmall
        };

        var dialog = await DialogService.ShowAsync<RegisterDialog>("Crear Cuenta", options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: true })
        {
            await GoToDashboardAsync();
        }
    }

    private async Task OpenLoginDialog()
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.ExtraSmall
        };

        var dialog = await DialogService.ShowAsync<LoginDialog>("Iniciar Sesión", options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: true })
        {
            await GoToDashboardAsync();
        }
    }

    private async Task GoToDashboardAsync()
    {
        if (AuthService.IsAuthenticated && AuthService.CurrentUser != null)
        {
            var boards = await BoardService.GetUserBoardsAsync(AuthService.CurrentUser.Id);
            if (boards.Any())
            {
                var lastBoard = AuthService.GetLastVisitedBoard();
                var boardToNavigate = boards.FirstOrDefault(b => b.Id == lastBoard) ?? boards.First();
                Navigation.NavigateTo($"/board/{boardToNavigate.Id}", forceLoad: true);
            }
            else
            {
                var newBoard = await BoardService.CreateBoardAsync(AuthService.CurrentUser.Id, "Mi Tablero");
                if (newBoard != null)
                {
                    Navigation.NavigateTo($"/board/{newBoard.Id}", forceLoad: true);
                }
            }
        }
    }
}
