    private async Task OpenEditItemDialog(TodoItem item)
    {
        if (!await CheckCanModifyTask()) return;
        
        if (string.IsNullOrEmpty(BoardId) || currentBoard == null) return;

        var editing = new TodoItem { 
            Id = item.Id, 
            Title = item.Title, 
            Description = item.Description, 
            Priority = item.Priority, 
            ColumnId = item.ColumnId, 
            IsCompleted = item.IsCompleted, 
            Order = item.Order, 
            CreatedAt = item.CreatedAt, 
            UpdatedAt = item.UpdatedAt,
            StartDate = item.StartDate,
            EndDate = item.EndDate,
            DueDate = item.DueDate,
            AssignedUsers = item.AssignedUsers != null ? new Dictionary<string, string>(item.AssignedUsers) : new Dictionary<string, string>(),
            Steps = item.Steps?.Select(s => new TodoStep { Id = s.Id, Name = s.Name, IsCompleted = s.IsCompleted, Order = s.Order }).ToList(),
            CurrentStepIndex = item.CurrentStepIndex
        };
        var parameters = new DialogParameters<EditItemDialog>();
        parameters.Add(x => x.Item, editing);
        parameters.Add(x => x.Columns, columns);
        parameters.Add(x => x.Participants, boardParticipants);


        var dialog = await DialogService.ShowAsync<EditItemDialog>("Editar Tarea", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: EditItemDialog.EditItemResult editResult })
        {
            var usersAddedToTodo = editResult.AddedUsers
                .Select(x => currentBoard.Participants.ContainsKey(x) ? currentBoard.Participants[x] : currentBoard.OwnerName);
            var usersRemovedFromTodo = editResult.RemovedUsers
                .Select(x => currentBoard.Participants.ContainsKey(x) ? currentBoard.Participants[x] : currentBoard.OwnerName);


            if (usersAddedToTodo.Any())
            {
                await LogService.AddLogAsync(new LogItem
                {
                    Action = DatabaseAction.Crear,
                    BoardId = BoardId,
                    Message = $"Añade {string.Join(',', usersAddedToTodo)} a la tarea {item.Title}",
                    User = AuthService.CurrentUser!.Username
                });
            }

            if (usersRemovedFromTodo.Any())
            {
                await LogService.AddLogAsync(new LogItem
                {
                    Action = DatabaseAction.Remover,
                    BoardId = BoardId,
                    Message = $"Remueve {string.Join(',', usersRemovedFromTodo)} de la tarea {item.Title}",
                    User = AuthService.CurrentUser!.Username
                });
            }

            if (editResult.StepsChanged)
            {
                var completedCount = editResult.Item.Steps?.Count(s => s.IsCompleted) ?? 0;
                var totalCount = editResult.Item.Steps?.Count ?? 0;
                var percentage = totalCount > 0 ? (int)((double)completedCount / totalCount * 100) : 0;

                await LogService.AddLogAsync(new LogItem
                {
                    Action = DatabaseAction.Actualizar,
                    BoardId = BoardId,
                    Message = $"Actualiza pasos de '{editResult.Item.Title}': {completedCount}/{totalCount} ({percentage}%)",
                    User = AuthService.CurrentUser!.Username
                });
            }

            await TodoService.UpdateItemAsync(BoardId, editResult.Item);

            if (editResult.ColumnChanged)
            {
                await TodoService.MoveItemToColumnAsync(BoardId, editResult.Item.Id, null, editResult.NewColumnId);
                itemsByColumn[editResult.Item.ColumnId]?.RemoveAll(i => i.Id == editResult.Item.Id);
                if (!itemsByColumn.ContainsKey(editResult.NewColumnId))
                {
                    itemsByColumn[editResult.NewColumnId] = new List<TodoItem>();
                }
                itemsByColumn[editResult.NewColumnId].Add(editResult.Item);
            }
            else
            {
                var itemList = itemsByColumn[editResult.Item.ColumnId];
                var itemIndex = itemList.FindIndex(i => i.Id == editResult.Item.Id);
                if (itemIndex >= 0)
                {
                    itemList[itemIndex] = editResult.Item;
                }
            }
            StateHasChanged();
            SnackbarService.Add("Tarea actualizada", Severity.Success);
        }
    }

