@code {
    // ============================================
    // PROPIEDADES
    // ============================================
    [CascadingParameter]
    private EventCallback<string>? BottomNavCallback { get; set; }

    [Parameter]
    public string? BoardId { get; set; }

    private enum SyncStatus { Idle, Syncing, Success, Error }
    private SyncStatus _syncStatus = SyncStatus.Idle;
    private int _pendingOperations = 0;
    private System.Timers.Timer? _syncTimer;

    private bool isDraggingItem = false;
    private TodoItem? draggedItem;
    private string? sourceColumnId;

    private bool isDraggingColumn = false;
    private TodoColumn? draggedColumn;
    private int draggedColumnIndex;
    private (double X, double Y) dragPosition;
    private string? hoveredColumnId;
    private string? _targetColumnIdForDrop;
    private double dragOffsetX = 0;
    private double dragOffsetY = 0;

    private List<TodoColumn> columns = new();
    private Dictionary<string, List<TodoItem>> itemsByColumn = new();
    private bool isLoading = true;
    private TodoBoard? currentBoard;
    private bool isOwner = false;
    private bool isParticipant = false;
    private Dictionary<string, string> boardParticipants = new();
    private bool showLogsView = false;
    private IEnumerable<LogItem> boardLogs = [];
    private bool logsLoading = false;

    private bool columnLoading = true;

    private string newColumnColor = "#7e6fff";

    // ============================================
    // CICLO DE VIDA
    // ============================================
    private bool _hasLoadedBoard = false;
    private bool _isRealtimeConnected = false;
    private string? _previousBoardId;

    protected override async Task OnParametersSetAsync()
    {
        showLogsView = false;
        if (BoardId != _previousBoardId)
        {
            if (!string.IsNullOrEmpty(_previousBoardId))
            {
                UnsubscribeRealtimeEvents();
                await RealtimeService.LeaveBoardAsync(_previousBoardId);
            }
            
            _hasLoadedBoard = false;
            _isRealtimeConnected = false;
            _previousBoardId = BoardId;
        }

        if (!string.IsNullOrEmpty(BoardId) && !_hasLoadedBoard)
        {
            await AuthService.CheckAuthStateAsync();
            await LoadBoardAsync();
            _hasLoadedBoard = true;
        }

    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {   
        if (firstRender == false) return;

        BottomNavService.OnBottomNavAction += HandleBottomNavAction;

        if (!string.IsNullOrEmpty(BoardId) && !_isRealtimeConnected)
        {
            _isRealtimeConnected = true;
            RealtimeService.SetCurrentUserId(AuthService.CurrentUser?.Id);
            await RealtimeService.ConnectAsync();
            await RealtimeService.JoinBoardAsync(BoardId);
            SubscribeRealtimeEvents();
        }

        columnLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        BottomNavService.OnBottomNavAction -= HandleBottomNavAction;
        UnsubscribeRealtimeEvents();
    }

    // ============================================
    // REAL-TIME SYNC
    // ============================================
    private void SubscribeRealtimeEvents()
    {
        if (RealtimeService == null) return;

        RealtimeService.OnBoardUpdated += HandleBoardUpdated;
        RealtimeService.OnBoardDeleted += HandleBoardDeleted;
        RealtimeService.OnColumnAdded += HandleColumnAdded;
        RealtimeService.OnColumnUpdated += HandleColumnUpdated;
        RealtimeService.OnColumnDeleted += HandleColumnDeleted;
        RealtimeService.OnItemAdded += HandleItemAdded;
        RealtimeService.OnItemUpdated += HandleItemUpdated;
        RealtimeService.OnItemDeleted += HandleItemDeleted;
    }

    private void UnsubscribeRealtimeEvents()
    {
        if (RealtimeService == null) return;

        RealtimeService.OnBoardUpdated -= HandleBoardUpdated;
        RealtimeService.OnBoardDeleted -= HandleBoardDeleted;
        RealtimeService.OnColumnAdded -= HandleColumnAdded;
        RealtimeService.OnColumnUpdated -= HandleColumnUpdated;
        RealtimeService.OnColumnDeleted -= HandleColumnDeleted;
        RealtimeService.OnItemAdded -= HandleItemAdded;
        RealtimeService.OnItemUpdated -= HandleItemUpdated;
        RealtimeService.OnItemDeleted -= HandleItemDeleted;
    }

    private async void HandleBoardUpdated(string boardId, string? excludeUserId)
    {
        if (boardId != BoardId) return;
        await LoadBoardAsync();
        SnackbarService.Add("El tablero ha sido actualizado", Severity.Info);
    }

    private async void HandleBoardDeleted(string boardId)
    {
        SnackbarService.Add("Este tablero ha sido eliminado", Severity.Warning);
        Navigation.NavigateTo("/", forceLoad: true);
    }

    private async void HandleColumnAdded(string boardId, string columnJson, string? excludeUserId)
    {
        if (boardId != BoardId) return;
        if (excludeUserId == AuthService.CurrentUser?.Id) return;
        
        try
        {
            var column = System.Text.Json.JsonSerializer.Deserialize<TodoColumn>(columnJson, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (column != null)
            {
                var columnExists = columns.Any(c => c.Id == column.Id);
                if (columnExists) return;
                
                columns.Add(column);
                itemsByColumn[column.Id] = new List<TodoItem>();
                await InvokeAsync(StateHasChanged);
                SnackbarService.Add("Nueva columna añadida", Severity.Info);
            }
        }
        catch
        {
            _ = LoadBoardAsync();
        }
    }

    private async void HandleColumnUpdated(string boardId, string columnJson, string? excludeUserId)
    {
        if (boardId != BoardId) return;
        
        var currentUserId = AuthService.CurrentUser?.Id;
        Console.WriteLine($"HandleColumnUpdated: excludeUserId={excludeUserId}, currentUserId={currentUserId}");
        if (excludeUserId == currentUserId) return;
        
        try
        {
            var column = System.Text.Json.JsonSerializer.Deserialize<TodoColumn>(columnJson, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (column != null)
            {
                Console.WriteLine($"HandleColumnUpdated: updating column {column.Name}, Order={column.Order}");
                var existingColumn = columns.FirstOrDefault(c => c.Id == column.Id);
                if (existingColumn != null)
                {
                    var index = columns.IndexOf(existingColumn);
                    columns[index] = column;
                    columns = columns.OrderBy(c => c.Order).ToList();
                    Console.WriteLine($"HandleColumnUpdated: columns reordered, count={columns.Count}");
                }
                StateHasChanged();
            }
        }
        catch
        {
            _ = LoadBoardAsync();
        }
    }

    private async void HandleColumnDeleted(string boardId, string columnId)
    {
        if (boardId != BoardId) return;
        columns.RemoveAll(c => c.Id == columnId);
        itemsByColumn.Remove(columnId);
        await InvokeAsync(StateHasChanged);
        SnackbarService.Add("Una columna ha sido eliminada", Severity.Info);
    }

    private async void HandleItemAdded(string boardId, string columnId, string itemJson, string? excludeUserId)
    {
        if (boardId != BoardId) return;
        if (excludeUserId == AuthService.CurrentUser?.Id) return;
        
        try
        {
            var item = System.Text.Json.JsonSerializer.Deserialize<TodoItem>(itemJson, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (item != null)
            {
                var itemAlreadyExists = itemsByColumn.Values.Any(list => list.Any(i => i.Id == item.Id));
                if (itemAlreadyExists) return;
                
                if (!itemsByColumn.ContainsKey(columnId))
                {
                    itemsByColumn[columnId] = new List<TodoItem>();
                }
                itemsByColumn[columnId].Add(item);
                await InvokeAsync(StateHasChanged);
                SnackbarService.Add($"Nueva tarea añadida: {item.Title}", Severity.Info);
            }
        }
        catch
        {
            _ = LoadBoardAsync();
        }
    }

    private async void HandleItemUpdated(string boardId, string itemJson, string? excludeUserId)
    {
        if (boardId != BoardId) return;
        if (excludeUserId == AuthService.CurrentUser?.Id) return;
        
        try
        {
            var item = System.Text.Json.JsonSerializer.Deserialize<TodoItem>(itemJson, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (item != null)
            {
                foreach (var colId in itemsByColumn.Keys.ToList())
                {
                    var existingItem = itemsByColumn[colId].FirstOrDefault(i => i.Id == item.Id);
                    if (existingItem != null)
                    {
                        var index = itemsByColumn[colId].IndexOf(existingItem);
                        
                        if (existingItem.ColumnId != item.ColumnId)
                        {
                            itemsByColumn[colId].RemoveAt(index);
                            if (!itemsByColumn.ContainsKey(item.ColumnId))
                            {
                                itemsByColumn[item.ColumnId] = new List<TodoItem>();
                            }
                            itemsByColumn[item.ColumnId].Add(item);
                        }
                        else
                        {
                            itemsByColumn[colId][index] = item;
                        }
                        break;
                    }
                }
                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
            _ = LoadBoardAsync();
        }
    }

    private async void HandleItemDeleted(string boardId, string itemId)
    {
        if (boardId != BoardId) return;
        foreach (var columnId in itemsByColumn.Keys.ToList())
        {
            var item = itemsByColumn[columnId].FirstOrDefault(i => i.Id == itemId);
            if (item != null)
            {
                itemsByColumn[columnId].Remove(item);
                break;
            }
        }
        await InvokeAsync(StateHasChanged);
        SnackbarService.Add("Una tarea ha sido eliminada", Severity.Info);
    }

    private async Task HandleBottomNavAction(string action)
    {
        switch (action)
        {
            case "newtask":
                await OpenNewTaskDialogAsync();
                break;
            case "boards":
                SnackbarService.Add("Tableros - proximamente", Severity.Info);
                break;
        }
    }

    // ============================================
    // MÉTODOS DE CARGA
    // ============================================
    private async Task LoadBoardAsync()
    {
        if (string.IsNullOrEmpty(BoardId)) return;

        columnLoading = true;
        isLoading = true;
        columns = new List<TodoColumn>();
        itemsByColumn.Clear();
        await InvokeAsync(StateHasChanged);

        try
        {
            if (!AuthService.IsAuthenticated || AuthService.CurrentUser == null)
            {
                Navigation.NavigateTo("/", forceLoad: true);
                return;
            }

            await Task.Delay(500);

            currentBoard = await BoardService.GetBoardAsync(BoardId);
            isOwner = currentBoard?.User == AuthService.CurrentUser.Id;
            bool isParticipant = currentBoard?.ParticipantIds.Contains(AuthService.CurrentUser.Id) ?? false;
            if (currentBoard == null || (!isOwner && !isParticipant))
            {
                Navigation.NavigateTo("/board/not-found", forceLoad: true);
                return;
            }

            if (isOwner && string.IsNullOrEmpty(currentBoard.OwnerName))
            {
                currentBoard.OwnerName = AuthService.CurrentUser.Username;
                await BoardService.UpdateBoardAsync(currentBoard);
            }

            AuthService.SetLastVisitedBoard(BoardId);

            boardParticipants = new Dictionary<string, string>();
            if (!string.IsNullOrEmpty(currentBoard.OwnerName))
            {
                boardParticipants[currentBoard.User] = currentBoard.OwnerName;
            }
            foreach (var participant in currentBoard.ParticipantNames)
            {
                boardParticipants[participant.Key] = participant.Value;
            }

            columns = new List<TodoColumn>(currentBoard.Columns);
            itemsByColumn.Clear();
            foreach (var column in columns)
            {
                var columnItems = currentBoard.Items.Where(i => i.ColumnId == column.Id).OrderBy(i => i.Order).ToList();
                itemsByColumn[column.Id] = new List<TodoItem>(columnItems);
            }

        }
        catch (Exception ex)
        {
            SnackbarService.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
            columnLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private List<TodoItem> GetColumnItems(string columnId) =>
        itemsByColumn.TryGetValue(columnId, out var items) ? items : new List<TodoItem>();

    private int GetColumnItemCount(string columnId) => GetColumnItems(columnId).Count;

    // ============================================
    // DRAG & DROP DE TAREAS
    // ============================================
    private void StartItemDrag(MouseEventArgs e, TodoItem item)
    {
        Console.WriteLine($"StartItemDrag called for: {item.Title}");
        if (isLoading) return;
        isDraggingItem = true;
        draggedItem = item;
        sourceColumnId = item.ColumnId;
        dragOffsetX = 80;
        dragOffsetY = 20;
        dragPosition = (e.ClientX - dragOffsetX, e.ClientY - dragOffsetY);
        StateHasChanged();
    }

    // ============================================
    // DRAG & DROP DE COLUMNAS
    // ============================================
    private void StartColumnDrag(MouseEventArgs e, TodoColumn column)
    {
        if (isLoading) return;
        isDraggingColumn = true;
        draggedColumn = column;
        draggedColumnIndex = columns.FindIndex(c => c.Id == column.Id);
        dragOffsetX = 160;
        dragOffsetY = 40;
        dragPosition = (e.ClientX - dragOffsetX, e.ClientY - dragOffsetY);
    }

    private void HandleColumnHover(string columnId)
    {
        hoveredColumnId = columnId;
        _targetColumnIdForDrop = columnId;
    }

    private void HandleColumnLeave()
    {
        // No limpiamos hoveredColumnId aquí - se limpia en HandleMouseUp
    }

    private void HandleMouseMove(MouseEventArgs e)
    {
        if (isDraggingItem || isDraggingColumn)
        {
            dragPosition = (e.ClientX - dragOffsetX, e.ClientY - dragOffsetY);
            StateHasChanged();
        }
    }

    private async Task HandleMouseUp(MouseEventArgs e)
    {
        var targetColumnId = _targetColumnIdForDrop ?? hoveredColumnId;

        if (isDraggingItem && draggedItem != null)
        {
            if (!string.IsNullOrEmpty(targetColumnId) && targetColumnId != sourceColumnId)
            {
                MoveItemOptimistic(draggedItem, sourceColumnId!, targetColumnId);
                _ = MoveItemBackgroundAsync(draggedItem.Id, targetColumnId);
                SnackbarService.Add("Tarea movida", Severity.Info);
            }
            isDraggingItem = false;
            draggedItem = null;
            sourceColumnId = null;
        }
        else if (isDraggingColumn && draggedColumn != null && !string.IsNullOrEmpty(targetColumnId))
        {
            if (targetColumnId != draggedColumn.Id)
            {
                var targetIndex = columns.FindIndex(c => c.Id == targetColumnId);
                if (targetIndex >= 0)
                {
                    SwapColumnsOptimistic(draggedColumnIndex, targetIndex);
                    _ = SwapColumnsBackgroundAsync(draggedColumnIndex, targetIndex);
                }
            }
        }
        isDraggingColumn = false;
        draggedColumn = null;
        hoveredColumnId = null;
        _targetColumnIdForDrop = null;
        StateHasChanged();
    }

    private async Task SwapColumnsAsync(int from, int to)
    {
        if (string.IsNullOrEmpty(BoardId)) return;
        if (from < 0 || to < 0 || from >= columns.Count || to >= columns.Count) return;
        try
        {
            await TodoService.SwapColumnsAsync(BoardId, from, to);
            await LoadBoardAsync();
            SnackbarService.Add("Columnas intercambiadas", Severity.Info);
        }
        catch (Exception ex)
        {
            SnackbarService.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private void MoveItemOptimistic(TodoItem item, string fromColumnId, string toColumnId)
    {
        var itemRemoved = false;

        if (itemsByColumn.TryGetValue(fromColumnId, out var sourceList))
        {
            itemRemoved = sourceList.Remove(item);
        }

        if (!itemsByColumn.ContainsKey(toColumnId))
        {
            itemsByColumn[toColumnId] = new List<TodoItem>();
        }

        itemsByColumn[toColumnId].Add(item);
        item.ColumnId = toColumnId;

        StateHasChanged();
    }

    private async Task MoveItemBackgroundAsync(string itemId, string targetColumnId)
    {
        if (string.IsNullOrEmpty(BoardId)) return;
        try
        {
            _pendingOperations++;
            _syncStatus = SyncStatus.Syncing;
            StateHasChanged();

            await Task.Delay(600);
            await TodoService.MoveItemToColumnAsync(BoardId, itemId, targetColumnId);

            OnOperationComplete(true);
        }
        catch
        {
            await LoadBoardAsync();
            OnOperationComplete(false);
        }
    }

    private void SwapColumnsOptimistic(int from, int to)
    {
        (columns[from], columns[to]) = (columns[to], columns[from]);
        StateHasChanged();
    }

    private async Task SwapColumnsBackgroundAsync(int from, int to)
    {
        if (string.IsNullOrEmpty(BoardId)) return;
        try
        {
            _pendingOperations++;
            _syncStatus = SyncStatus.Syncing;
            StateHasChanged();

            await Task.Delay(600);
            await TodoService.SwapColumnsAsync(BoardId, from, to);

            OnOperationComplete(true);
        }
        catch
        {
            (columns[from], columns[to]) = (columns[to], columns[from]);
            StateHasChanged();
            OnOperationComplete(false);
        }
    }

    private void OnOperationComplete(bool success)
    {
        _pendingOperations--;
        if (_pendingOperations <= 0)
        {
            _pendingOperations = 0;
            _syncStatus = success ? SyncStatus.Success : SyncStatus.Error;
            StateHasChanged();

            _syncTimer?.Stop();
            _syncTimer?.Dispose();
            _syncTimer = new System.Timers.Timer(2000);
            _syncTimer.Elapsed += (s, e) =>
            {
                _syncTimer?.Stop();
                _syncTimer?.Dispose();
                _syncTimer = null;
                InvokeAsync(() => {
                    _syncStatus = SyncStatus.Idle;
                    StateHasChanged();
                });
            };
            _syncTimer.AutoReset = false;
            _syncTimer.Start();
        }
    }

    // ============================================
    // OPERACIONES DE PARTICIPANTES
    // ============================================
    private async Task OpenAddParticipantsDialog()
    {
        if (!isOwner || string.IsNullOrEmpty(BoardId) || currentBoard == null) return;

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small
        };

        var parameters = new DialogParameters<AddParticipantsDialog>();
        parameters.Add(x => x.ExistingParticipantIds, currentBoard.ParticipantIds);

        var dialog = await DialogService.ShowAsync<AddParticipantsDialog>("Añadir participantes", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: List<(string Id, string Name)> selectedParticipants })
        {
            if (selectedParticipants.Count == 0) return;

            foreach (var (id, name) in selectedParticipants)
            {
                if (!currentBoard.ParticipantIds.Contains(id))
                {
                    currentBoard.ParticipantIds.Add(id);
                    currentBoard.ParticipantNames[id] = name;
                }
            }
            await BoardService.UpdateBoardAsync(currentBoard);
            await LogService.AddLogAsync(new LogItem
            {
                Message = $"Añade participantes {string.Join(", ", selectedParticipants.Select(x => x.Name))} del tablero {currentBoard.Name}",
                Action = DatabaseAction.Crear,
                BoardId = currentBoard.Id,
                User = AuthService.CurrentUser!.Username
            });
            StateHasChanged();
            SnackbarService.Add("Participantes añadidos", Severity.Success);
        }
    }

    private async Task RemoveParticipant(string participantId)
    {
        if (!isOwner || string.IsNullOrEmpty(BoardId) || currentBoard == null) return;

        await BoardService.RemoveParticipantAsync(BoardId, participantId);
        currentBoard.ParticipantIds.Remove(participantId);
        currentBoard.ParticipantNames.Remove(participantId);
        StateHasChanged();
        SnackbarService.Add("Participante removido", Severity.Info);
    }

    private async Task ConfirmRemoveParticipant(string participantId, string participantName)
    {
        if (!isOwner) return;

        var parameters = new DialogParameters<DeletionConfirmDialog>();
        parameters.Add(x => x.ContentText, $"¿Estás seguro de que deseas remover a {participantName} del tablero?");
        parameters.Add(x => x.ButtonText, "Remover");
        parameters.Add(x => x.Color, Color.Error);

        var dialog = await DialogService.ShowAsync<DeletionConfirmDialog>("Remover participante", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await RemoveParticipant(participantId);
        }
    }

    // ============================================
    // VISTA DE LOGS
    // ============================================
    private async Task ToggleLogsView()
    {
        try
        {
            showLogsView = !showLogsView;
            if (showLogsView)
            {
                logsLoading = true;
                await InvokeAsync(StateHasChanged);

                boardLogs = await LogService.GetLogsByBoardId(BoardId);

                logsLoading = false;
            }
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            logsLoading = false;
            SnackbarService.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    // ============================================
    // OPERACIONES DE COLUMNAS
    // ============================================
    private async Task AddColumnAsync()
    {
        if (string.IsNullOrEmpty(BoardId)) return;

        var parameters = new DialogParameters<InputDialog>();
        parameters.Add(x => x.Title, "Nueva Columna");
        parameters.Add(x => x.ContentText, "Nombre de la columna:");
        parameters.Add(x => x.Placeholder, "Nombre...");
        parameters.Add(x => x.ButtonText, "Crear");

        var dialog = await DialogService.ShowAsync<InputDialog>("Nueva Columna", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: string name } && !string.IsNullOrWhiteSpace(name))
        {
            var col = await TodoService.AddColumnAsync(BoardId, name, newColumnColor);
            if (col != null)
            {
                columns.Add(col);
                itemsByColumn[col.Id] = new List<TodoItem>();
                StateHasChanged();
                SnackbarService.Add($"Columna '{col.Name}' creada", Severity.Success);
            }
        }
    }

    private async Task OpenEditColumnDialog(TodoColumn column)
    {
        if (string.IsNullOrEmpty(BoardId)) return;

        var defaultColumnName = column.Name;

        var editing = new TodoColumn { Id = column.Id, Name = column.Name, Color = column.Color, CreatedAt = column.CreatedAt, UpdatedAt = column.UpdatedAt };
        var parameters = new DialogParameters<EditColumnDialog>();
        parameters.Add(x => x.Column, editing);

        var dialog = await DialogService.ShowAsync<EditColumnDialog>("Editar Columna", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: EditColumnDialog.EditColumnResult editResult })
        {
            if (string.IsNullOrWhiteSpace(editResult.NewName) == false)
            {
                await LogService.AddLogAsync(new LogItem
                {
                    Action = DatabaseAction.Actualizar,
                    BoardId = BoardId,
                    Message = $"Actualiza columna {defaultColumnName} -> {editResult.NewName}",
                    User = AuthService.CurrentUser!.Username
                });
            }
            if (string.IsNullOrWhiteSpace(editResult.NewColor) == false)
            {
                await LogService.AddLogAsync(new LogItem
                {
                    Action = DatabaseAction.Actualizar,
                    BoardId = BoardId,
                    Message = $"Actualiza color de la columna a {editResult.NewColor}",
                    User = AuthService.CurrentUser!.Username
                });
            }

            await TodoService.UpdateColumnAsync(BoardId, editing);
            var index = columns.FindIndex(c => c.Id == editing.Id);
            if (index >= 0)
            {
                columns[index] = editing;
                StateHasChanged();
            }
            SnackbarService.Add("Columna actualizada", Severity.Success);
        }
    }

    private async Task DeleteColumnAsync(TodoColumn column)
    {
        if (string.IsNullOrEmpty(BoardId)) return;

        var count = GetColumnItemCount(column.Id);
        var msg = count > 0 ? $"¿Eliminar '{column.Name}' y sus {count} tareas?" : $"¿Eliminar '{column.Name}'?";
        var parameters = new DialogParameters<DeletionConfirmDialog>();
        parameters.Add(x => x.ContentText, msg);
        parameters.Add(x => x.ButtonText, "Eliminar");
        parameters.Add(x => x.Color, Color.Error);

        var dialog = await DialogService.ShowAsync<DeletionConfirmDialog>("Confirmar", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: true })
        {
            await TodoService.DeleteColumnAsync(BoardId, column.Id);
            columns.RemoveAll(c => c.Id == column.Id);
            itemsByColumn.Remove(column.Id);
            StateHasChanged();
            SnackbarService.Add("Columna eliminada", Severity.Success);
        }
    }

    private async Task OpenNewTaskDialogAsync()
    {
        if (string.IsNullOrEmpty(BoardId) || !columns.Any())
        {
            SnackbarService.Add("Primero crea una columna", Severity.Warning);
            return;
        }

        var parameters = new DialogParameters<NewTaskDialog>();
        parameters.Add(x => x.Columns, columns);
        parameters.Add(x => x.Participants, boardParticipants);

        var dialog = await DialogService.ShowAsync<NewTaskDialog>("Nueva Tarea", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: TodoItem newItem })
        {
            var success = await TodoService.AddItemAsync(BoardId, newItem);
            if (success)
            {
                if (!itemsByColumn.ContainsKey(newItem.ColumnId))
                {
                    itemsByColumn[newItem.ColumnId] = new List<TodoItem>();
                }
                itemsByColumn[newItem.ColumnId].Add(newItem);
                StateHasChanged();
                SnackbarService.Add("Tarea agregada", Severity.Success);
            }
        }
    }

    private async Task OpenEditItemDialog(TodoItem item)
    {
        if (string.IsNullOrEmpty(BoardId) || currentBoard == null) return;

        var editing = new TodoItem { 
            Id = item.Id, 
            Title = item.Title, 
            Description = item.Description, 
            Priority = item.Priority, 
            ColumnId = item.ColumnId, 
            IsCompleted = item.IsCompleted, 
            Order = item.Order, 
            CreatedAt = item.CreatedAt, 
            UpdatedAt = item.UpdatedAt,
            AssignedUsers = item.AssignedUsers != null ? new Dictionary<string, string>(item.AssignedUsers) : new Dictionary<string, string>(),
            Steps = item.Steps?.Select(s => new TodoStep { Id = s.Id, Name = s.Name, IsCompleted = s.IsCompleted }).ToList(),
            CurrentStepIndex = item.CurrentStepIndex
        };
        var parameters = new DialogParameters<EditItemDialog>();
        parameters.Add(x => x.Item, editing);
        parameters.Add(x => x.Columns, columns);
        parameters.Add(x => x.Participants, boardParticipants);


        var dialog = await DialogService.ShowAsync<EditItemDialog>("Editar Tarea", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: EditItemDialog.EditItemResult editResult })
        {
            var usersAddedToTodo = editResult.AddedUsers
                .Select(x => currentBoard.ParticipantNames.ContainsKey(x) ? currentBoard.ParticipantNames[x] : currentBoard.OwnerName);
            var usersRemovedFromTodo = editResult.RemovedUsers
                .Select(x => currentBoard.ParticipantNames.ContainsKey(x) ? currentBoard.ParticipantNames[x] : currentBoard.OwnerName);


            if (usersAddedToTodo.Any())
            {
                await LogService.AddLogAsync(new LogItem
                {
                    Action = DatabaseAction.Crear,
                    BoardId = BoardId,
                    Message = $"Añade {string.Join(',', usersAddedToTodo)} a la tarea {item.Title}",
                    User = AuthService.CurrentUser!.Username
                });
            }

            if (usersRemovedFromTodo.Any())
            {
                await LogService.AddLogAsync(new LogItem
                {
                    Action = DatabaseAction.Remover,
                    BoardId = BoardId,
                    Message = $"Remueve {string.Join(',', usersRemovedFromTodo)} de la tarea {item.Title}",
                    User = AuthService.CurrentUser!.Username
                });
            }

            if (editResult.StepsChanged)
            {
                var completedCount = editResult.Item.Steps?.Count(s => s.IsCompleted) ?? 0;
                var totalCount = editResult.Item.Steps?.Count ?? 0;
                var percentage = totalCount > 0 ? (int)((double)completedCount / totalCount * 100) : 0;
                
                await LogService.AddLogAsync(new LogItem
                {
                    Action = DatabaseAction.Actualizar,
                    BoardId = BoardId,
                    Message = $"Actualiza pasos de '{editResult.Item.Title}': {completedCount}/{totalCount} ({percentage}%)",
                    User = AuthService.CurrentUser!.Username
                });
            }

            await TodoService.UpdateItemAsync(BoardId, editResult.Item);

            if (editResult.ColumnChanged)
            {
                await TodoService.MoveItemToColumnAsync(BoardId, editResult.Item.Id, editResult.NewColumnId);
                itemsByColumn[editResult.Item.ColumnId]?.RemoveAll(i => i.Id == editResult.Item.Id);
                if (!itemsByColumn.ContainsKey(editResult.NewColumnId))
                {
                    itemsByColumn[editResult.NewColumnId] = new List<TodoItem>();
                }
                itemsByColumn[editResult.NewColumnId].Add(editResult.Item);
            }
            else
            {
                var itemList = itemsByColumn[editResult.Item.ColumnId];
                var itemIndex = itemList.FindIndex(i => i.Id == editResult.Item.Id);
                if (itemIndex >= 0)
                {
                    itemList[itemIndex] = editResult.Item;
                }
            }
            StateHasChanged();
            SnackbarService.Add("Tarea actualizada", Severity.Success);
        }
    }

    private async Task DeleteItemAsync(TodoItem item)
    {
        if (string.IsNullOrEmpty(BoardId)) return;

        var parameters = new DialogParameters<DeletionConfirmDialog>();
        parameters.Add(x => x.ContentText, $"¿Eliminar '{item.Title}'?");
        parameters.Add(x => x.ButtonText, "Eliminar");
        parameters.Add(x => x.Color, Color.Error);

        var dialog = await DialogService.ShowAsync<DeletionConfirmDialog>("Confirmar", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: true })
        {
            await TodoService.DeleteItemAsync(BoardId, item.Id);
            itemsByColumn[item.ColumnId]?.RemoveAll(i => i.Id == item.Id);
            StateHasChanged();
            SnackbarService.Add("Tarea eliminada", Severity.Success);
        }
    }
}

