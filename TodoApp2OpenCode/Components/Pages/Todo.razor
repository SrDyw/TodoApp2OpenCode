@page "/board/{BoardId}"
@inject IDialogService DialogService
@inject ISnackbar SnackbarService
@inject TodoService TodoService
@inject IBoardService BoardService
@inject IAuthService AuthService
@inject BottomNavService BottomNavService
@inject NavigationManager Navigation
@inject ILogService LogService
@inject IRealtimeService RealtimeService

<PageTitle>FlowBoard - Organiza tu flujo</PageTitle>

<!-- Elemento que sigue el cursor durante el arrastre de tareas -->
@if (isDraggingItem && draggedItem != null)
{
    <div class="drag-ghost" 
         style="@($"left: {dragPosition.X}px; top: {dragPosition.Y}px;")">
        <MudCard Class="todo-card-dragging">
            <MudCardContent Class="pa-3">
                <MudText Typo="Typo.body1" Style="word-break: break-word;">
                    @draggedItem.Title
                </MudText>
            </MudCardContent>
        </MudCard>
    </div>
}

<!-- Elemento que sigue el cursor durante el arrastre de columnas -->
@if (isDraggingColumn && draggedColumn != null)
{
    <div class="drag-ghost-column" 
         style="@($"left: {dragPosition.X}px; top: {dragPosition.Y}px;")">
        <div class="column-header-dragging">
            <div class="column-color-dot" style="background-color: @draggedColumn.Color;"></div>
            <MudText Typo="Typo.h6" Class="column-title">@draggedColumn.Name</MudText>
        </div>
    </div>
}

<!-- Encabezado de la página -->
<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    @if (currentBoard == null || columnLoading)
    {
        <MudSkeleton Width="50%" Height="40px" />
    }
    else 
    {
        <MudText Typo="Typo.h4">
            <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="mr-2" />
            @currentBoard.Name
        </MudText>
    }
</MudStack>

<!-- Barra de acciones flotante estilo Win11 -->
<div class="action-bar">
    @if (columnLoading)
    {
        <MudSkeleton Width="100%" Height=" 40px"/>
    }
    else 
    {
        <MudButton Color="Color.Primary" 
               Variant="Variant.Filled" 
               Size="Size.Medium"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenNewTaskDialogAsync">
            Nueva Tarea
        </MudButton>

        @if (currentBoard != null)
        {
            <MudMenu Label="Participantes" Color="Color.Default" Variant="Variant.Outlined" Class="ml-2" EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
                <div class="px-3 py-2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                        <MudText>
                            @if (!string.IsNullOrEmpty(currentBoard.OwnerName))
                            {
                                @currentBoard.OwnerName
                            }
                            else
                            {
                                @:Propietario
                            }
                            @if (isOwner)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Primary">(Tú)</MudText>
                            }
                        </MudText>
                    </MudStack>
                </div>
                @if (currentBoard.ParticipantNames.Any())
                {
                    <MudDivider />
                    @foreach (var participant in currentBoard.ParticipantNames)
                    {
                        <div class="px-3 py-2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                                <MudText>
                                    @participant.Value
                                    @if (AuthService.CurrentUser != null && participant.Key == AuthService.CurrentUser.Id)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Primary">(Tú)</MudText>
                                    }
                                </MudText>
                                @if (isOwner)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" 
                                                   Size="Size.Small" 
                                                   Color="Color.Error"
                                                   OnClick="@(() => ConfirmRemoveParticipant(participant.Key, participant.Value))" />
                                }
                            </MudStack>
                        </div>
                    }
                }
                @if (isOwner)
                {
                    <MudDivider />
                    <MudMenuItem OnClick="OpenAddParticipantsDialog">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Small" Color="Color.Primary" />
                            <MudText Color="Color.Primary">Añadir participante</MudText>
                        </MudStack>
                    </MudMenuItem>
                }
            </MudMenu>

            <MudButton Color="Color.Default" 
                       Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.History"
                       OnClick="ToggleLogsView"
                       @onmousedown:stopPropagation="true">
                @(showLogsView ? "Ver Board" : "Ver Logs")
            </MudButton>
        }
    }
</div>

<!-- Barra de estado de sincronización -->
@if (_syncStatus != SyncStatus.Idle)
{
    <div class="sync-status-bar visible">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            @if (_syncStatus == SyncStatus.Syncing)
            {
                <MudProgressCircular Size="Size.Small" Color="Color.Primary" Indeterminate="true" />
                <MudText Typo="Typo.body2">Guardando cambios...</MudText>
            }
            else if (_syncStatus == SyncStatus.Success)
            {
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                <MudText Typo="Typo.body2" Color="Color.Success">Tablero actualizado</MudText>
            }
            else if (_syncStatus == SyncStatus.Error)
            {
                <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small" />
                <MudText Typo="Typo.body2" Color="Color.Error">Error al guardar</MudText>
            }
        </MudStack>
    </div>
}


@if (showLogsView)
{
    <div class="logs-container">
        @if (logsLoading)
        {
            <MudSkeleton Height="40px" Width="100%" Class="mb-4" />
            <MudSkeleton Height="40px" Width="100%" Class="mb-2" />
            <MudSkeleton Height="40px" Width="100%" Class="mb-2" />
            <MudSkeleton Height="40px" Width="100%" Class="mb-2" />
            <MudSkeleton Height="40px" Width="100%" Class="mb-2" />
        }
        else
        {
            <MudDataGrid T="LogItem" Items="boardLogs" Sortable="true" Hover="true">
                <Columns>
                    <PropertyColumn Property="x => x.Id" Title="ID" />
                    <PropertyColumn Property="x => x.User" />
                    <PropertyColumn Property="x => x.Action" Title="Acción">
                        <CellTemplate>
                            @switch (context.Item.Action)
                            {
                                case DatabaseAction.Actualizar:
                                    <MudChip Color="Color.Info">@context.Item.Action.ToString()</MudChip>
                                    break;
                                case DatabaseAction.Remover:
                                    <MudChip Color="Color.Error">@context.Item.Action.ToString()</MudChip>
                                    break;
                                case DatabaseAction.Crear:
                                    <MudChip Color="Color.Success">@context.Item.Action.ToString()</MudChip>
                                    break;
                                case DatabaseAction.Leer:
                                    <MudChip Color="Color.Default">@context.Item.Action.ToString()</MudChip>
                                    break;
                            }
                        </CellTemplate>
                    </PropertyColumn>
                    <PropertyColumn Property="x => x.Message" Title="Mensaje" />
                    <PropertyColumn Property="x => x.CreatedAt" Title="Fecha" />
                </Columns>
            </MudDataGrid>
        }
    </div>
}
else
{
<div class="board-container @((isDraggingItem || isDraggingColumn) ? "no-select" : "")" @onmousemove="HandleMouseMove" @onmouseup="HandleMouseUp">
    @if (columnLoading)
    {
        <div class="columns-wrapper">
            @for (int i = 0; i < 3; i++)
            {
                <div class="board-column skeleton-column">
                    <div class="column-header">
                        <div class="column-title-area">
                            <MudSkeleton Width="16px" Height="16px" Class="mr-1" />
                            <MudSkeleton Width="8px" Height="8px" Class="mr-1" />
                            <MudSkeleton Width="100px" Height="24px" />
                        </div>
                    </div>
                    <div class="column-content">
                        @for (int j = 0; j < 3; j++)
                        {
                            <MudCard Class="todo-card-skeleton mb-3">
                                <MudCardContent Class="pa-3">
                                    <MudSkeleton Width="80%" Height="18px" Class="mb-2" />
                                    <MudSkeleton Width="60%" Height="14px" />
                                </MudCardContent>
                            </MudCard>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="columns-wrapper">
            @foreach (var column in columns)
            {
                <div class="board-column @(hoveredColumnId == column.Id && isDraggingItem ? "drop-zone-hover" : "") @(isDraggingColumn && draggedColumn?.Id == column.Id ? "column-being-dragged" : "") @(hoveredColumnId == column.Id && isDraggingColumn && draggedColumn?.Id != column.Id ? "column-drop-target" : "")" 
                     style="--column-color: @column.Color;"
                     data-column-id="@column.Id"
                     @onmouseenter="() => HandleColumnHover(column.Id)"
                     @onmouseleave="() => HandleColumnLeave()">
                    <div class="column-header column-drag-handle" >
                        <div class="column-title-area" @onmousedown="(e) => StartColumnDrag(e, column)">
                            <MudIcon Icon="@Icons.Material.Filled.DragIndicator" Size="Size.Small" Class="mr-1 column-drag-icon" />
                            <div class="column-color-dot" style="background-color: @column.Color;"></div>
                            <MudText Typo="Typo.h6" Class="column-title">@column.Name</MudText>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="ml-1">
                                @GetColumnItemCount(column.Id)
                            </MudChip>
                        </div>
                        
                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Dense="true" edge="Edge.End">
                            <MudMenuItem OnClick="() => OpenEditColumnDialog(column)">
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                                    <span>Editar</span>
                                </MudStack>
                            </MudMenuItem>
                            <MudDivider />
                            <MudMenuItem OnClick="() => DeleteColumnAsync(column)" Class="text-danger">
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" />
                                    <span>Eliminar</span>
                                </MudStack>
                            </MudMenuItem>
                        </MudMenu>
                    </div>
                    
                     <div class="column-content"
                          >
                          @foreach (var item in GetColumnItems(column.Id))
                          {
                              <MudTooltip Text="" Placement="Placement.Right" ShowOnHover="true">
                                  <ChildContent>
                                      <div class="todo-card-wrapper @(item.IsCompleted ? "completed" : "")"
                                           draggable="false"
                                           @onmousedown="@(e => StartItemDrag(e, item))"
                                           style="@(item.Priority == TodoPriority.High && !item.IsCompleted ? "border-left: 3px solid var(--mud-palette-error);" : "")">
                                          <MudCard Class="@($"todo-card{(item.IsCompleted ? " completed" : "")}")">
                                              <MudCardContent Class="pa-3">
                                                  <MudStack Spacing="2">
                                                      <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
                                                          <MudStack Spacing="0" Style="flex: 1;">
                                                              <MudText Typo="Typo.body1" 
                                                                       Class="@(item.IsCompleted ? "text-strikethrough" : null)"
                                                                       Style="word-break: break-word;">
                                                                  @item.Title
                                                              </MudText>
                                                          </MudStack>
                                                          <MudIcon Icon="@Icons.Material.Filled.DragIndicator" Size="Size.Small" Color="Color.Default" Class="drag-handle" />
                                                      </MudStack>
                                                      
                                                      @if (!string.IsNullOrEmpty(item.Description))
                                                      {
                                                          <MudText Typo="Typo.body2" Color="Color.Secondary" Class="@(item.IsCompleted ? "text-strikethrough" : "")" Style="word-break: break-word;">
                                                              @item.Description
                                                          </MudText>
                                                      }

                                                      @if (item.AssignedUsers != null && item.AssignedUsers.Any())
                                                      {
                                                          <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                              <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" Color="Color.Primary" />
                                                              <MudText Typo="Typo.caption" Color="Color.Primary">
                                                                  @string.Join(", ", item.AssignedUsers.Values)
                                                              </MudText>
                                                          </MudStack>
                                                      }

                                                      @if (item.Steps != null && item.Steps.Any())
                                                      {
                                                          <div class="item-steps-progress">
                                                              <MudProgressLinear Value="@item.ProgressPercentage" Color="Color.Primary" Size="Size.Small" />
                                                              @if (!string.IsNullOrEmpty(item.CurrentStepName))
                                                              {
                                                                  <MudText Typo="Typo.caption" Color="Color.Primary">
                                                                      @item.CurrentStepName
                                                                  </MudText>
                                                              }
                                                          </div>
                                                      }
                                                      
                                                      <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                                          @if (item.Priority != TodoPriority.Normal)
                                                          {
                                                              <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@(item.Priority == TodoPriority.High ? Color.Error : Color.Default)">
                                                                  @(item.Priority == TodoPriority.High ? "🔴 Alta" : "⚪ Baja")
                                                              </MudChip>
                                                          }
                                                          else
                                                          {
                                                              <div></div>
                                                          }
                                                          
                                                          <MudStack Row="true" Spacing="0">
                                                              <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="() => OpenEditItemDialog(item)" @onmousedown:stopPropagation="true" aria-label="Editar" />
                                                              <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteItemAsync(item)" @onmousedown:stopPropagation="true" aria-label="Eliminar" />
                                                          </MudStack>
                                                      </MudStack>
                                                  </MudStack>
                                              </MudCardContent>
                                          </MudCard>
                                      </div>
                                  </ChildContent>
                                  <TooltipContent>
                                      <MudPaper Class="pa-3" Elevation="4" Style="min-width: 280px; max-width: 350px;">
                                          <MudText Typo="Typo.h6" Class="mb-2">@item.Title</MudText>
                                          
                                          @if (!string.IsNullOrEmpty(item.Description))
                                          {
                                              <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">@item.Description</MudText>
                                          }

                                          <MudDivider Class="my-2" />

                                          <MudStack Spacing="1">
                                              <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                  <MudIcon Icon="@Icons.Material.Filled.Flag" Size="Size.Small" Color="Color.Default" />
                                                  <MudText Typo="Typo.caption">
                                                      Prioridad: 
                                                      <MudChip T="string" Size="Size.Small" Color="@(item.Priority == TodoPriority.High ? Color.Error : item.Priority == TodoPriority.Low ? Color.Default : Color.Info)">
                                                          @(item.Priority == TodoPriority.High ? "Alta" : item.Priority == TodoPriority.Low ? "Baja" : "Normal")
                                                      </MudChip>
                                                  </MudText>
                                              </MudStack>

                                              @if (item.AssignedUsers != null && item.AssignedUsers.Any())
                                              {
                                                  <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                      <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" Color="Color.Primary" />
                                                      <MudText Typo="Typo.caption">
                                                          Asignados: @string.Join(", ", item.AssignedUsers.Values)
                                                      </MudText>
                                                  </MudStack>
                                              }

                                              <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                  <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Color="Color.Default" />
                                                  <MudText Typo="Typo.caption">
                                                      Creada: @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                                  </MudText>
                                              </MudStack>

                                              @if (item.UpdatedAt != item.CreatedAt)
                                              {
                                                  <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                      <MudIcon Icon="@Icons.Material.Filled.Update" Size="Size.Small" Color="Color.Default" />
                                                      <MudText Typo="Typo.caption">
                                                          Actualizada: @item.UpdatedAt.ToString("dd/MM/yyyy HH:mm")
                                                      </MudText>
                                                  </MudStack>
                                              }
                                          </MudStack>

                                          @if (item.Steps != null && item.Steps.Any())
                                          {
                                              <MudDivider Class="my-2" />
                                              <MudText Typo="Typo.subtitle2" Class="mb-1">Pasos (@item.CompletedStepsCount/@item.TotalStepsCount)</MudText>
                                              <MudProgressLinear Value="@item.ProgressPercentage" Color="Color.Primary" Size="Size.Small" Class="mb-2" />
                                              <MudList T="string" Dense="true">
                                                  @foreach (var step in item.Steps)
                                                  {
                                                      <MudListItem Icon="@(step.IsCompleted ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)" 
                                                                   IconColor="@(step.IsCompleted ? Color.Success : Color.Default)">
                                                          <MudText Typo="Typo.body2" Class="@(step.IsCompleted ? "text-strikethrough" : "")">@step.Name</MudText>
                                                      </MudListItem>
                                                  }
                                              </MudList>
                                          }
                                      </MudPaper>
                                  </TooltipContent>
                              </MudTooltip>
                          }
                     </div>
                </div>
            }
            
            <div class="board-column add-column-trigger" @onclick="AddColumnAsync">
                <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Large" Class="add-column-icon" />
                <MudText>Nueva Columna</MudText>
            </div>
        </div>
    }


</div>
    
}
<!-- Tablero de columnas estilo Kanban -->

<style>
    .drag-ghost {
        position: fixed;
        z-index: 9999;
        pointer-events: none;
        transform: rotate(25deg) scale(1.05);
        opacity: 0.95;
        filter: drop-shadow(0 8px 24px rgba(0,0,0,0.3));
        cursor: grabbing;
    }
    
    .todo-card-dragging {
        background: var(--mud-palette-surface);
        border-radius: 8px;
        max-width: 300px;
    }
    
    .drag-ghost-column {
        position: fixed;
        z-index: 9999;
        pointer-events: none;
        transform: rotate(5deg) scale(1.02);
        opacity: 0.9;
        filter: drop-shadow(0 12px 32px rgba(0,0,0,0.3));
        cursor: grabbing;
        width: 320px;
    }
    
    .column-header-dragging {
        padding: 16px;
        background: var(--mud-palette-surface);
        border-radius: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.2);
    }
    
    .board-container {
        width: 100%;
        height: calc(100vh - 200px);
        overflow-x: auto;
        overflow-y: hidden;
        padding-bottom: 20px;
    }
    
    .columns-wrapper {
        display: flex;
        gap: 16px;
        height: 100%;
        min-height: 500px;
        padding: 4px;
    }
    
    .board-column {
        flex: 0 0 320px;
        max-width: 320px;
        background: var(--mud-palette-surface);
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        max-height: 100%;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        transition: transform 0.2s, box-shadow 0.2s;
    }
    
    .board-column.drop-zone-hover {
        background: color-mix(in srgb, var(--mud-palette-primary) 10%, transparent);
    }
    
    .board-column.column-being-dragged {
        opacity: 0.4;
        transform: scale(0.95);
    }
    
    .board-column.column-drop-target {
        outline: 3px dashed var(--mud-palette-primary);
        outline-offset: -3px;
    }
    
    .column-header {
        padding: 16px;
        border-bottom: 1px solid var(--mud-palette-divider);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: linear-gradient(to right, var(--column-color) 4px, transparent 4px);
        border-radius: 12px 12px 0 0;
    }
    
    .column-drag-handle { cursor: grab; }
    .column-drag-handle:active { cursor: grabbing; }
    
    .column-title-area {
        display: flex;
        align-items: center;
        gap: 8px;
        flex: 1;
        min-width: 0;
    }
    
    .column-color-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    
    .column-title {
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    
    .column-drag-icon { opacity: 0.5; cursor: grab; }
    .column-header:hover .column-drag-icon { opacity: 1; }
    
    .column-content {
        flex: 1;
        overflow-y: auto;
        padding: 12px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        min-height: 100px;
    }
    
    .todo-card-wrapper {
        border-radius: 8px;
        transition: transform 0.2s, opacity 0.2s;
        cursor: grab;
    }
    
    .todo-card-wrapper:hover { transform: scale(1.02); }
    .todo-card-wrapper:active { cursor: grabbing; }
    .todo-card-wrapper.completed { opacity: 0.6; }
    
    .todo-card {
        background: var(--mud-palette-background);
        border-radius: 8px;
    }
    
    .drag-handle { opacity: 0.4; transition: opacity 0.2s; cursor: grab; }
    .todo-card-wrapper:hover .drag-handle { opacity: 1; }
    
    .todo-card-wrapper .mud-icon-button {
        pointer-events: auto;
    }
    
    .text-strikethrough { text-decoration: line-through; color: var(--mud-palette-text-disabled); }
    
    .add-item-form { margin-top: auto; padding-top: 8px; }

    .skeleton-column {
        background: var(--mud-palette-surface);
        border-radius: 12px;
        flex: 0 0 320px;
        max-width: 320px;
    }

    .todo-card-skeleton {
        background: var(--mud-palette-background);
        border-radius: 8px;
    }

    .add-column-trigger {
        flex: 0 0 320px;
        max-width: 320px;
        background: transparent;
        border: 2px dashed var(--mud-palette-lines-default);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        opacity: 0.6;
        transition: opacity 0.2s, background 0.2s;
        min-height: 200px;
    }
    
    .add-column-trigger:hover { opacity: 1; background: var(--mud-palette-surface); border-color: var(--mud-palette-primary); }
    .add-column-icon { font-size: 48px; margin-bottom: 8px; color: var(--mud-palette-primary); }

    .column-content::-webkit-scrollbar { width: 6px; }
    .column-content::-webkit-scrollbar-track { background: transparent; }
    .column-content::-webkit-scrollbar-thumb { background: var(--mud-palette-primary); border-radius: 3px; }
    .column-content::-webkit-scrollbar-thumb:hover { background: var(--mud-palette-primary); filter: brightness(1.1); }
    .column-content::-webkit-scrollbar-button { display: none; }
    .column-content::-webkit-scrollbar-corner { background: transparent; }

    .board-container::-webkit-scrollbar { height: 6px; }
    .board-container::-webkit-scrollbar-track { background: rgba(0, 0, 0, 0.05); border-radius: 3px; }
    .board-container::-webkit-scrollbar-thumb { background: var(--mud-palette-primary); border-radius: 3px; transition: filter 0.2s; }
