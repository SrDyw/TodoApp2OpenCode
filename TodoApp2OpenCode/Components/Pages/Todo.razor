    {
        BoardPermissions? permissions = null;
        if (currentBoard?.ParticipantPermissions != null &&
            currentBoard.ParticipantPermissions.TryGetValue(userId, out var perms))
        {
            permissions = perms;
        }

        var parameters = new DialogParameters<UserDetailsDialog>
