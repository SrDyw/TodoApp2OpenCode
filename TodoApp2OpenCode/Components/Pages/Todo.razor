        {
            SnackbarService.Add("No tienes permisos para mover columnas", Severity.Warning);
            return;
        }
        isDraggingColumn = true;
        draggedColumn = column;
        draggedColumnIndex = columns.FindIndex(c => c.Id == column.Id);
        dragOffsetX = 160;
