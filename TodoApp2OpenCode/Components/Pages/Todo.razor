        var result = await dialog.Result;

        if (result is { Canceled: false, Data: TodoItem newItem })
        {
            var success = await TodoService.AddItemAsync(BoardId, newItem);
            if (success)
            {
                await LogService.AddLogAsync(new LogItem
                {
                    Action = DatabaseAction.Crear, 
                    BoardId = BoardId,
