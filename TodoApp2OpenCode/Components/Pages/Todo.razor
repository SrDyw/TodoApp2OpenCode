    // ============================================
    // MÉTODOS DE CARGA
    // ============================================
    private async Task LoadBoardAsync()
    {
        if (string.IsNullOrEmpty(BoardId)) return;

        void NotFound()
        {
            Navigation.NavigateTo("/board/not-found", forceLoad: true);
            return;            
        }

        columnLoading = true;
        isLoading = true;
        columns = new List<TodoColumn>();
        itemsByColumn.Clear();
        await InvokeAsync(StateHasChanged);

        try
        {
            if (!AuthService.IsAuthenticated || AuthService.CurrentUser == null)
            {
                Navigation.NavigateTo("/", forceLoad: true);
                return;
            }

            // await Task.Delay(500);

            currentBoard = await BoardService.GetBoardAsync(BoardId);
            if (currentBoard == null)
            {
                NotFound();
                return;
            }

            isOwner = currentBoard?.User == AuthService.CurrentUser.Id;

            bool isParticipant = currentBoard?.Participants.ContainsKey(AuthService.CurrentUser.Id) ?? false;
            if (!isOwner && !isParticipant)
            {
                NotFound();
                return;
            }

            if (isOwner)
            {
                canAddTask = true;
                canModifyTask = true;
                canDeleteTask = true;
                canViewCalendar = true;
                canAddColumn = true;
                canEditColumn = true;
                canDeleteColumn = true;
            }
            else if (currentBoard?.ParticipantPermissions != null && 
                     currentBoard.ParticipantPermissions.TryGetValue(AuthService.CurrentUser.Id, out var perms))
            {
                canAddTask = perms.CanAddTasks;
                canModifyTask = perms.CanModifyTasks;
                canDeleteTask = perms.CanDeleteTasks;
                canViewCalendar = perms.CanViewCalendar;
                canAddColumn = perms.CanAddColumn;
                canEditColumn = perms.CanEditColumn;
                canDeleteColumn = perms.CanDeleteColumn;
            }
            else
            {
                canAddTask = false;
                canModifyTask = false;
                canDeleteTask = false;
                canViewCalendar = false;
                canAddColumn = false;
                canEditColumn = false;
                canDeleteColumn = false;
            }



            if (isOwner && string.IsNullOrEmpty(currentBoard.OwnerName))
            {
                currentBoard.OwnerName = AuthService.CurrentUser.Username;
                await BoardService.UpdateBoardAsync(currentBoard);
            }

            AuthService.SetLastVisitedBoard(BoardId);

            boardParticipants = new Dictionary<string, string>();
            if (!string.IsNullOrEmpty(currentBoard.OwnerName))
            {
                boardParticipants[currentBoard.User] = currentBoard.OwnerName;
            }
            foreach (var participant in currentBoard.Participants)
            {
                boardParticipants[participant.Key] = participant.Value;
            }

            columns = new List<TodoColumn>(currentBoard.Columns);
            itemsByColumn.Clear();
            foreach (var column in columns)
            {
                var columnItems = currentBoard.Items.Where(i => i.ColumnId == column.Id).OrderBy(i => i.Order).ToList();
                itemsByColumn[column.Id] = new List<TodoItem>(columnItems);
            }

            todayEvents = currentBoard.Events
                .Where(e => e.EventDate.Date == DateTime.Today)
                .ToList();

        }
        catch (Exception ex)
        {
            SnackbarService.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
            columnLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private List<TodoItem> GetColumnItems(string columnId) =>
