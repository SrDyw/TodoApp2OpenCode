@page "/board/{BoardId}"
@inject IDialogService DialogService
@inject ISnackbar SnackbarService
@inject TodoService TodoService
@inject BoardParticipantsService ParticipantsService
@inject IBoardService BoardService
@inject IAuthService AuthService
@inject BottomNavService BottomNavService
@inject NavigationManager Navigation
@inject ILogService LogService
@inject IRealtimeService RealtimeService

<PageTitle>@Config.AppName | Tablero @currentBoard?.Name</PageTitle>

<!-- Encabezado de la página -->
<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
    @if (currentBoard == null || columnLoading)
    {
        <MudSkeleton Width="50%" Height="40px" />
    }
    else 
    {
        <MudText Typo="Typo.h4">
            <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="mr-2" />
            @currentBoard.Name
        </MudText>
    }
</MudStack>
<MudText Color="Color.Primary" Typo="Typo.h5">
    @currentBoard?.Description
</MudText>


<!-- Eventos de hoy -->
@if (todayEvents.Any())
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4" NoIcon="true">
        <div class="today-events-alert">
            <div class="today-events-header">
                <MudText Typo="Typo.body2" Class="mr-2">
                    <strong>Eventos de hoy:</strong>
                </MudText>
            </div>
            <div class="today-events-list">
                @foreach (var evt in todayEvents)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="mr-1 mb-1">
                        @evt.Title
                    </MudChip>
                }
            </div>
            <MudButton Size="Size.Small" 
                       Variant="Variant.Text" 
                       Color="Color.Default"
                       Class="ml-auto"
                       OnClick="NavigateToSchedule">
                Ver calendario
            </MudButton>
        </div>
    </MudAlert>
}
<div style="margin-bottom: 8px"/>
<MudDivider />

<div class="board-container">
    @if (columnLoading)
    {
        <div class="columns-wrapper">
            <!-- Skeleton barra vertical -->
            <div class="vertical-action-bar column-item">
                <MudSkeleton Width="40px" Height="40px" Class="mb-2" />
                <MudSkeleton Width="40px" Height="40px" Class="mb-2" />
                <MudSkeleton Width="40px" Height="40px" Class="mb-2" />
                <MudSkeleton Width="40px" Height="40px" Class="mb-2" />
            </div>
            <div class="columns-list">
                <!-- Skeleton columnas -->
                @for (int i = 0; i < 3; i++)
                {
                    <div class="board-column skeleton-column">
                        <div class="column-header">
                            <div class="column-title-area">
                                <MudSkeleton Width="16px" Height="16px" Class="mr-1" />
                                <MudSkeleton Width="8px" Height="8px" Class="mr-1" />
                                <MudSkeleton Width="100px" Height="24px" />
                            </div>
                        </div>
                        <div class="column-content">
                            @for (int j = 0; j < 3; j++)
                            {
                                <MudCard Class="todo-card-skeleton mb-3">
                                    <MudCardContent Class="pa-3">
                                        <MudSkeleton Width="80%" Height="18px" Class="mb-2" />
                                        <MudSkeleton Width="60%" Height="14px" />
                                    </MudCardContent>
                                </MudCard>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="columns-wrapper">
                <div class="vertical-action-bar column-item">
                <MudTooltip Text="Añadir nueva tarea">
                    <MudIconButton Icon="@Icons.Material.Filled.Add" OnClick="OpenNewTaskDialogAsync" Disabled="!canAddTask" />
                </MudTooltip>
                <MudTooltip Text="Participantes">
                    <MudMenu Color="Color.Default" Icon="@Icons.Material.Filled.People">
                        <MudMenuItem Disabled="currentBoard?.OwnerName != AuthService.CurrentUser?.Username">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Primary" />
                                @currentBoard?.OwnerName
                                @if (currentBoard?.OwnerName == AuthService.CurrentUser?.Username)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Primary">(Tú)</MudText>
                                }
                            </MudStack>
                        </MudMenuItem>
                        @if (currentBoard?.Participants.Any() == true)
                        {
                            <MudDivider />
                            @foreach (var participant in currentBoard.Participants)
                            {
                                <MudMenuItem OnClick="@(() => ShowUserDetails(participant.Value, participant.Key))" Disabled="currentBoard?.OwnerName != AuthService.CurrentUser?.Username">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudIcon Icon="@Icons.Material.Outlined.Person" Size="Size.Small" Color="Color.Primary" />
                                        @participant.Value
                                        @if (participant.Value == AuthService.CurrentUser?.Username)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Primary">(Tú)</MudText>
                                        }
                                    </MudStack>
                                </MudMenuItem>
                            }
                        }
                        @if (isOwner)
                        {
                            <MudDivider />
                            <MudMenuItem OnClick="OpenAddParticipantsDialog">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Small" Color="Color.Primary" />
                                    <MudText Color="Color.Primary">Añadir participante</MudText>
                                </MudStack>
                            </MudMenuItem>
                        }
                    </MudMenu>
                </MudTooltip>
                @if (canViewCalendar || isOwner)
                {
                    <MudTooltip Text="Calendario">
                        <MudIconButton Color="Color.Default"
                                    Icon="@Icons.Material.Filled.CalendarMonth"
                                    OnClick="NavigateToSchedule"
                                    @onmousedown:stopPropagation="true"/>
                    </MudTooltip>
                }
                @if (isOwner)
                {
                    <MudTooltip Text="Ajustes">
                            <MudIconButton Color="Color.Default"
                                       Icon="@Icons.Material.Filled.Settings"
                                       OnClick="NavigateToSettings"
                                       @onmousedown:stopPropagation="true"/>
                    </MudTooltip>
                }
                <MudTooltip Text="Registros">
                    <MudIconButton Color="Color.Default"
                                Icon="@Icons.Material.Filled.History"
                                OnClick="NavigateToLogs"
                                @onmousedown:stopPropagation="true"/>
                </MudTooltip>
                <MudSpacer />
                <MudDivider/>
                @if (isOwner)
                {
                    <MudTooltip Text="Borrar tablero">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="OnDeleteBoardButtonClick" />
                    </MudTooltip>
                }
            </div>
                <div class="columns-list column-item">

            @foreach (var column in columns)
            {
                <BoardColumn 
                    BoardId="@BoardId"
                    Column="@column"
                    Items="@GetColumnItems(column.Id)"
                    CanEdit="@canEditColumn"
                    CanDelete="@canDeleteColumn"
                    CanModifyItems="@canModifyTask"
                    CanDeleteItems="@canDeleteTask"
                    ColumnUpdated="LoadBoardAsync"
                    ColumnDeleted="LoadBoardAsync"
                    ItemUpdated="LoadBoardAsync"
                    ItemDeleted="LoadBoardAsync" />
            }
              
              @if (canAddColumn || isOwner)
             {
                 <div class="board-column add-column-trigger" @onclick="AddColumnAsync">
                     <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Large" Class="add-column-icon" />
                     <MudText>Nueva Columna</MudText>
                 </div>
             }
            </div>
         </div>
     }


</div>
    

<!-- Tablero de columnas estilo Kanban -->

<style>
    .board-container {
        width: 100%;
        height: calc(100vh - 150px);
        overflow-x: auto;
        overflow-y: hidden;
        padding-bottom: 20px;
    }
    
    .columns-wrapper {
        display: grid;
        grid-template-columns: 64px 1fr;
        height: 100%;
        min-height: 600px;
        padding: 4px;
    }

    .columns-list {
        display: flex;
        gap: 16px;
        height: 100%;
        min-height: 500px;
        padding: 4px;
        overflow-x: scroll;
        border-radius: 16px;
    }

    .column-item {
        margin-right: 8px;
    }
    
    .board-column {
        flex: 0 0 320px;
        max-width: 320px;
        background: var(--mud-palette-surface);
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        max-height: 100%;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        transition: transform 0.2s, box-shadow 0.2s;
    }
    
    .column-header {
        padding: 16px;
        border-bottom: 1px solid var(--mud-palette-divider);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: linear-gradient(to right, var(--column-color) 4px, transparent 4px);
        border-radius: 12px 12px 0 0;
    }
    
    .column-drag-handle { cursor: grab; }
    .column-drag-handle:active { cursor: grabbing; }
    
    .column-title-area {
        display: flex;
        align-items: center;
        gap: 8px;
        flex: 1;
        min-width: 0;
    }
    
    .column-color-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    
    .column-title {
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    
    .column-drag-icon { opacity: 0.5; cursor: grab; }
    .column-header:hover .column-drag-icon { opacity: 1; }
    
    .column-content {
        flex: 1;
        overflow-y: auto;
        padding: 12px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        min-height: 100px;
    }
    
    .text-strikethrough { text-decoration: line-through; color: var(--mud-palette-text-disabled); }
    
    .skeleton-column {
        background: var(--mud-palette-surface);
        border-radius: 12px;
        flex: 0 0 320px;
        max-width: 320px;
    }

    .todo-card-skeleton {
        background: var(--mud-palette-background);
        border-radius: 8px;
    }

    .add-column-trigger {
        flex: 0 0 320px;
        max-width: 320px;
        background: transparent;
        border: 2px dashed var(--mud-palette-lines-default);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        opacity: 0.6;
        transition: opacity 0.2s, background 0.2s;
        min-height: 200px;
    }
    
    .add-column-trigger:hover { opacity: 1; background: var(--mud-palette-surface); border-color: var(--mud-palette-primary); }
    .add-column-icon { font-size: 48px; margin-bottom: 8px; color: var(--mud-palette-primary); }

    .column-content::-webkit-scrollbar { width: 6px; }
    .column-content::-webkit-scrollbar-track { background: transparent; }
    .column-content::-webkit-scrollbar-thumb { background: var(--mud-palette-primary); border-radius: 3px; }
    .column-content::-webkit-scrollbar-thumb:hover { background: var(--mud-palette-primary); filter: brightness(1.1); }
    .column-content::-webkit-scrollbar-button { display: none; }
    .column-content::-webkit-scrollbar-corner { background: transparent; }

    .board-container::-webkit-scrollbar { height: 6px; }
    .board-container::-webkit-scrollbar-track { background: rgba(0, 0, 0, 0.05); border-radius: 3px; }
    .board-container::-webkit-scrollbar-thumb { background: var(--mud-palette-primary); border-radius: 3px; transition: filter 0.2s; }
    .board-container::-webkit-scrollbar-thumb:hover { filter: brightness(1.15); }
    .board-container::-webkit-scrollbar-thumb:active { filter: brightness(1.2); }
    .board-container::-webkit-scrollbar-button { display: none; }
    .board-container::-webkit-scrollbar-corner { background: transparent; }

    .action-bar {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 8px 12px;
        margin-bottom: 12px;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .vertical-action-bar {
        display: flex;
        flex-direction:column;
        height: 100%;
        align-items: center;
        gap: 12px;
        padding: 8px 12px;
        margin-bottom: 12px;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .participants-bar {
        display: flex;
        align-items: center;
        padding: 8px 12px;
        margin-bottom: 16px;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 8px;
    }

    .today-events-alert {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        width: 100%;
    }

    .today-events-header {
        display: flex;
        align-items: center;
    }

    .today-events-list {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
    }

    ::deep .today-events-list .mud-chip {
        color: var(--mud-palette-text-primary);
    }

    .sync-status-bar.visible {
        transform: translateX(-50%) translateY(0);
        opacity: 1;
    }
    
    .logs-container {
        width: 100%;
        height: calc(100vh - 200px);
        overflow: auto;
        padding: 16px;
    }

    .item-steps-progress {
        margin-top: 8px;
    }

    .mud-tooltip {
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
    }

</style>

@code {
    // ============================================
    // PROPIEDADES
    // ============================================
    [CascadingParameter]
    private EventCallback<string>? BottomNavCallback { get; set; }

    [Parameter]
    public string? BoardId { get; set; }

    private List<TodoColumn> columns = new();
    private Dictionary<string, List<TodoItem>> itemsByColumn = new();
    private bool isLoading = true;
    private TodoBoard? currentBoard;
    private bool isOwner = false;
    private bool canAddTask = true;
    private bool canViewCalendar = true;
    private bool canModifyTask = true;
    private bool canDeleteTask = true;
    private bool canAddColumn = true;
    private bool canEditColumn = true;
    private bool canDeleteColumn = true;
    private bool isParticipant = false;
    private Dictionary<string, string> boardParticipants = new();

    private bool columnLoading = true;

    private string newColumnColor = "#7e6fff";

    private List<CalendarEvent> todayEvents = new();

    // ============================================
    // CICLO DE VIDA
    // ============================================
    private bool _hasLoadedBoard = false;
    private System.Threading.Timer? _permissionCheckTimer;

    private string? _previousBoardId;

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(BoardId))
        {
            if (BoardId != _previousBoardId)
            {
                _previousBoardId = BoardId;
                _hasLoadedBoard = false;
                columnLoading = true;
            }

            if (!_hasLoadedBoard)
            {
                await AuthService.CheckAuthStateAsync();
                await LoadBoardAsync();
                _hasLoadedBoard = true;
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {   
        if (firstRender == false) return;

        BottomNavService.OnBottomNavAction += HandleBottomNavAction;
    }


    public void Dispose()
    {
        BottomNavService.OnBottomNavAction -= HandleBottomNavAction;
        _permissionCheckTimer?.Dispose();
    }

    private async Task HandleBottomNavAction(string action)
    {
        switch (action)
        {
            case "newtask":
                await OpenNewTaskDialogAsync();
                break;
            case "boards":
                SnackbarService.Add("Tableros - proximamente", Severity.Info);
                break;
        }
    }

    // ============================================
    // MÉTODOS DE CARGA
    // ============================================
    private async Task LoadBoardAsync()
    {
        if (string.IsNullOrEmpty(BoardId)) return;

        void NotFound()
        {
            Navigation.NavigateTo("/board/not-found", forceLoad: true);
            return;            
        }

        columnLoading = true;
        isLoading = true;
        columns = new List<TodoColumn>();
        itemsByColumn.Clear();
        await InvokeAsync(StateHasChanged);

        try
        {
            if (!AuthService.IsAuthenticated || AuthService.CurrentUser == null)
            {
                Navigation.NavigateTo("/", forceLoad: true);
                return;
            }

            // await Task.Delay(500);

            currentBoard = await BoardService.GetBoardAsync(BoardId);
            if (currentBoard == null)
            {
                NotFound();
                return;
            }

            isOwner = currentBoard?.User == AuthService.CurrentUser.Id;

            bool isParticipant = currentBoard?.Participants.ContainsKey(AuthService.CurrentUser.Id) ?? false;
            if (!isOwner && !isParticipant)
            {
                NotFound();
                return;
            }

            var perms = BoardUtils.GetUserPermissions(currentBoard, AuthService.CurrentUser.Id);
            canAddTask = perms.CanAddTasks;
            canModifyTask = perms.CanModifyTasks;
            canDeleteTask = perms.CanDeleteTasks;
            canViewCalendar = perms.CanViewCalendar;
            canAddColumn = perms.CanAddColumn;
            canEditColumn = perms.CanEditColumn;
            canDeleteColumn = perms.CanDeleteColumn;

            if (isOwner && string.IsNullOrEmpty(currentBoard.OwnerName))
            {
                currentBoard.OwnerName = AuthService.CurrentUser.Username;
                await BoardService.UpdateBoardAsync(currentBoard);
            }

            AuthService.SetLastVisitedBoard(BoardId);

            boardParticipants = BoardUtils.GetParticipantsDictionary(currentBoard);

            columns = new List<TodoColumn>(currentBoard.Columns);
            itemsByColumn.Clear();
            foreach (var column in columns)
            {
                var columnItems = currentBoard.Items.Where(i => i.ColumnId == column.Id).OrderBy(i => i.Order).ToList();
                itemsByColumn[column.Id] = new List<TodoItem>(columnItems);
            }

            todayEvents = currentBoard.Events
                .Where(e => e.EventDate.Date == DateTime.Today)
                .ToList();

        }
        catch (Exception ex)
        {
            SnackbarService.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
            columnLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private List<TodoItem> GetColumnItems(string columnId) =>
        itemsByColumn.TryGetValue(columnId, out var items) ? items : new List<TodoItem>();

    private int GetColumnItemCount(string columnId) => GetColumnItems(columnId).Count;

    private async Task<bool> CheckCanAddTask()
    {
        if (!canAddTask)
        {
            SnackbarService.Add("No tienes permiso para añadir tareas", Severity.Warning);
            return false;
        }
        return true;
    }

    private async Task<bool> CheckCanModifyTask()
    {
        if (!canModifyTask)
        {
            SnackbarService.Add("No tienes permiso para modificar tareas", Severity.Warning);
            return false;
        }
        return true;
    }

    private async Task<bool> CheckCanDeleteTask()
    {
        if (!canDeleteTask)
        {
            SnackbarService.Add("No tienes permiso para eliminar tareas", Severity.Warning);
            return false;
        }
        return true;
    }

    // ============================================
    // OPERACIONES DE PARTICIPANTES
    // ============================================
    private async Task OpenAddParticipantsDialog()
    {
        if (!isOwner || string.IsNullOrEmpty(BoardId) || currentBoard == null) return;

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small
        };

        var parameters = new DialogParameters<AddParticipantsDialog>();
        parameters.Add(x => x.ExistingParticipantIds, currentBoard.Participants.Keys.ToList());

        var dialog = await DialogService.ShowAsync<AddParticipantsDialog>("Añadir participantes", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: List<(string Id, string Name)> selectedParticipants })
        {
            if (selectedParticipants.Count == 0) return;

            await ParticipantsService.AddParticipantsAsync(BoardId, currentBoard, selectedParticipants, AuthService.CurrentUser?.Username ?? "");
            
            StateHasChanged();
            SnackbarService.Add("Participantes añadidos", Severity.Success);
        }
    }

    private async Task RemoveParticipant(string participantId)
    {
        if (!isOwner || string.IsNullOrEmpty(BoardId) || currentBoard == null) return;

        var allItems = itemsByColumn.Values.SelectMany(items => items).ToList();

        if (ParticipantsService.HasIncompleteSteps(participantId, allItems))
        {
            SnackbarService.Add("El usuario no se puede quitar del tablero porque tiene tareas asignadas sin completar", Severity.Error);
            return;
        }

        await ParticipantsService.RemoveParticipantAsync(BoardId, currentBoard, participantId, allItems, StateHasChanged);
        
        SnackbarService.Add("Participante removido", Severity.Info);
    }

    private async Task ConfirmRemoveParticipant(string participantId, string participantName)
    {
        if (!isOwner) return;

        var allItems = itemsByColumn.Values.SelectMany(items => items).ToList();

        if (ParticipantsService.HasIncompleteSteps(participantId, allItems))
        {
            SnackbarService.Add("El usuario no se puede quitar del tablero porque tiene tareas asignadas sin completar", Severity.Error);
            return;
        }

        var parameters = new DialogParameters<DeletionConfirmDialog>();
        parameters.Add(x => x.ContentText, $"¿Estás seguro de que deseas remover a {participantName} del tablero?");
        parameters.Add(x => x.ButtonText, "Remover");
        parameters.Add(x => x.Color, Color.Error);

        var dialog = await DialogService.ShowAsync<DeletionConfirmDialog>("Remover participante", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await RemoveParticipant(participantId);
        }
    }

    // ============================================
    // NAVEGACIÓN A OTRAS PÁGINAS
    // ============================================
    private void NavigateToLogs()
    {
        Navigation.NavigateTo($"/board/{BoardId}/logs");
    }

    private void NavigateToSchedule()
    {
        _ = CheckCanViewCalendar();
    }

    private async Task CheckCanViewCalendar()
    {
        if (isOwner) 
        {
            Navigation.NavigateTo($"/board/{BoardId}/schedule");
            return;
        }
        
        var board = await BoardService.GetBoardAsync(BoardId);
        if (board == null) return;
        
        var currentUserId = AuthService.CurrentUser?.Id ?? "";
        if (board.User == currentUserId) 
        {
            Navigation.NavigateTo($"/board/{BoardId}/schedule");
            return;
        }
        
        if (board.ParticipantPermissions != null && 
            board.ParticipantPermissions.TryGetValue(currentUserId, out var perms))
        {
            if (!perms.CanViewCalendar)
            {
                SnackbarService.Add("No tienes permiso para ver el calendario", Severity.Warning);
                return;
            }
            Navigation.NavigateTo($"/board/{BoardId}/schedule");
            return;
        }
        
        SnackbarService.Add("No tienes permiso para ver el calendario", Severity.Warning);
    }

    private void NavigateToSettings()
    {
        Navigation.NavigateTo($"/board/{BoardId}/settings");
    }

    // ============================================
    // OPERACIONES DE COLUMNAS
    // ============================================
    private async Task AddColumnAsync()
    {
        if (string.IsNullOrEmpty(BoardId)) return;
        if (!canAddColumn && !isOwner)
        {
            SnackbarService.Add("No tienes permisos para añadir columnas", Severity.Warning);
            return;
        }

        var parameters = new DialogParameters<InputDialog>();
        parameters.Add(x => x.Title, "Nueva Columna");
        parameters.Add(x => x.ContentText, "Nombre de la columna:");
        parameters.Add(x => x.Placeholder, "Nombre...");
        parameters.Add(x => x.ButtonText, "Crear");

        var dialog = await DialogService.ShowAsync<InputDialog>("Nueva Columna", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: string name } && !string.IsNullOrWhiteSpace(name))
        {
            var col = await TodoService.AddColumnAsync(BoardId, name, newColumnColor);
            if (col != null)
            {
                columns.Add(col);
                itemsByColumn[col.Id] = new List<TodoItem>();
                StateHasChanged();
                SnackbarService.Add($"Columna '{col.Name}' creada", Severity.Success);
            }
        }
    }

    private async Task OpenNewTaskDialogAsync()
    {
        if (!await CheckCanAddTask()) return;
        
        if (string.IsNullOrEmpty(BoardId) || !columns.Any())
        {
            SnackbarService.Add("Primero crea una columna", Severity.Warning);
            return;
        }

        var parameters = new DialogParameters<NewTaskDialog>();
        parameters.Add(x => x.Columns, columns);
        parameters.Add(x => x.Participants, BoardUtils.GetParticipantsDictionary(currentBoard));

        var dialog = await DialogService.ShowAsync<NewTaskDialog>("Nueva Tarea", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: TodoItem newItem })
        {
            var success = await TodoService.AddItemAsync(BoardId, newItem);
            if (success)
            {
                await LogService.AddLogAsync(new LogItem
                {
                    Action = DatabaseAction.Crear, 
                    BoardId = BoardId,
                    Message = $"Añade tarea {newItem.Title}",
                    User = AuthService.CurrentUser!.Username
                });

                if (!itemsByColumn.ContainsKey(newItem.ColumnId))
                {
                    itemsByColumn[newItem.ColumnId] = new List<TodoItem>();
                }
                itemsByColumn[newItem.ColumnId].Add(newItem);
                StateHasChanged();
                SnackbarService.Add("Tarea agregada", Severity.Success);
            }
        }
    }

    private async Task OnDeleteBoardButtonClick()
    {
        if (currentBoard == null) return;

        var dialogParams = new DialogParameters<SecureDeletionConfirmDialog>();
        dialogParams.Add(x => x.ContentText, "¿Seguro que desea borrar el tablero con todo su contenido? La accion es irreversible.");
        dialogParams.Add(x => x.RequestedItem, currentBoard.Name);
        dialogParams.Add(x => x.ButtonText, "Borrar tablero");

        var dialog = await DialogService.ShowAsync<SecureDeletionConfirmDialog>("Borrar el tablero", dialogParams, new DialogOptions
        {
            CloseOnEscapeKey = false
        });
        var result = await dialog.Result;

        if (result is {Canceled : false, Data : true})
        {
            var deletionResult = await BoardService.DeleteBoardAsync(currentBoard.Id);

            if (deletionResult == true)
            {
                Navigation.NavigateTo("/", forceLoad: true);
                return;
            }

            SnackbarService.Add("No se pudo eliminar el tablero debido a un error inesperado, intenta luego", Severity.Error);
        }
    }

