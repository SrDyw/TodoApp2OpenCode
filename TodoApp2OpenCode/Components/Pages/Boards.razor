@page "/board"
@inject NavigationManager Navigation
@inject IAuthService AuthService
@inject IBoardService BoardService
@inject IDialogService DialogService
@inject ISnackbar SnackbarService

<style>
    .boards-page {
        min-height: 100vh;
        background: linear-gradient(135deg, var(--mud-palette-background) 0%, var(--mud-palette-surface) 100%);
        padding: 40px 20px 200px;
    }

    .welcome-section {
        max-width: 900px;
        margin: 0 auto 60px;
        text-align: center;
    }

    .welcome-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 16px;
        color: var(--mud-palette-text-primary);
    }

    .welcome-subtitle {
        font-size: 1.1rem;
        color: var(--mud-palette-text-secondary);
        margin-bottom: 32px;
        line-height: 1.6;
    }

    .action-buttons {
        display: flex;
        justify-content: center;
        gap: 16px;
        flex-wrap: wrap;
    }

    .boards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 20px;
        max-width: 1200px;
        margin: 0 auto 80px;
    }

    .board-card {
        background: var(--mud-palette-surface);
        border-radius: 12px;
        padding: 20px;
        border: 1px solid var(--mud-palette-lines-default);
        cursor: pointer;
        transition: all 0.2s;
        text-align: left;
    }

    .board-card:hover {
        transform: translateY(-4px);
        border-color: var(--mud-palette-primary);
        box-shadow: 0 8px 24px rgba(126, 111, 255, 0.15);
    }

    .board-card-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--mud-palette-text-primary);
        margin-bottom: 8px;
    }

    .board-card-meta {
        font-size: 0.85rem;
        color: var(--mud-palette-text-secondary);
    }

    .landing-section {
        max-width: 1200px;
        margin: 0 auto;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 24px;
        margin-bottom: 60px;
    }

    .feature-card {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 16px;
        padding: 32px 24px;
        transition: all 0.3s ease;
    }

    .feature-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 16px 48px rgba(126, 111, 255, 0.12);
        border-color: var(--mud-palette-primary);
    }

    .feature-icon-wrapper {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        background: linear-gradient(135deg, rgba(126, 111, 255, 0.15) 0%, rgba(126, 111, 255, 0.05) 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
    }

    .feature-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--mud-palette-text-primary);
        margin-bottom: 12px;
    }

    .feature-description {
        color: var(--mud-palette-text-secondary);
        font-size: 0.95rem;
        line-height: 1.6;
    }

    .cta-section {
        background: linear-gradient(135deg, var(--mud-palette-primary) 0%, #9f85ff 100%);
        border-radius: 24px;
        padding: 48px;
        text-align: center;
        color: white;
    }

    .cta-title {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 16px;
    }

    .cta-description {
        font-size: 1.1rem;
        opacity: 0.9;
        margin-bottom: 32px;
        line-height: 1.6;
    }

    .cta-button {
        background: white !important;
        color: var(--mud-palette-primary) !important;
        font-weight: 600;
        padding: 12px 32px;
        border-radius: 12px;
    }

    .section-label {
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--mud-palette-primary);
        margin-bottom: 12px;
    }
</style>

<div class="boards-page">
    <div class="welcome-section">
        <h1 class="welcome-title">Bienvenido, @(AuthService.CurrentUser?.Username ?? "Usuario")</h1>
        <p class="welcome-subtitle">
            Organiza tus tareas de forma visual e intuitiva con tableros Kanban. 
            Crea columnas, arrastra tareas entre ellas y mantén tu productividad al máximo.
        </p>
        <div class="action-buttons">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="CreateNewBoard">
                Crear nuevo tablero
            </MudButton>
        </div>
    </div>

    @if (userBoards.Any())
    {
        <MudText Typo="Typo.h4" Style="text-align:center; margin-bottom: 16px">Tus tableros</MudText>
        <div class="boards-grid">
            @foreach (var board in userBoards)
            {
                <div class="board-card" @onclick="@(() => NavigateToBoard(board.Id))">
                    <div class="board-card-title">@board.Name</div>
                    <div class="board-card-meta">
                        @(board.Columns?.Count ?? 0) columnas · @(board.Items?.Count ?? 0) tareas
                    </div>
                    <MudChip T="string" Icon="@Icons.Material.Filled.Person" Style="margin-top:8px">@board.OwnerName</MudChip>
                </div>
            }
        </div>
    }

    <div class="landing-section">
        <MudText Typo="Typo.h4" Style="text-align:center; margin-bottom: 16px">Funcionalidades</MudText>

        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon-wrapper">
                    <MudIcon Icon="@Icons.Material.Filled.ViewKanban" Size="Size.Large" Color="Color.Primary" />
                </div>
                <div class="feature-title">Tableros Visuales</div>
                <div class="feature-description">
                    Crea tableros ilimitados para organizar tus proyectos. Cada tablero tiene columnas personalizables que puedes nombrar y colorizar.
                </div>
            </div>

            <div class="feature-card">
                <div class="feature-icon-wrapper">
                    <MudIcon Icon="@Icons.Material.Filled.SwapVert" Size="Size.Large" Color="Color.Primary" />
                </div>
                <div class="feature-title">Drag & Drop</div>
                <div class="feature-description">
                    Arrastra tareas entre columnas con un clic. Reordena tus columnas y tareas de forma fluida e intuitiva.
                </div>
            </div>

            <div class="feature-card">
                <div class="feature-icon-wrapper">
                    <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Color="Color.Primary" />
                </div>
                <div class="feature-title">Colaboración</div>
                <div class="feature-description">
                    Añade participantes a tus tableros. Asigna tareas, sigue el progreso y trabaja en equipo en tiempo real.
                </div>
            </div>

            <div class="feature-card">
                <div class="feature-icon-wrapper">
                    <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Large" Color="Color.Primary" />
                </div>
                <div class="feature-title">Calendario</div>
                <div class="feature-description">
                    Programa eventos y tareas con fechas. Visualiza tu agenda en el calendario integrado de cada tablero.
                </div>
            </div>

            <div class="feature-card">
                <div class="feature-icon-wrapper">
                    <MudIcon Icon="@Icons.Material.Filled.Notifications" Size="Size.Large" Color="Color.Primary" />
                </div>
                <div class="feature-title">Notificaciones</div>
                <div class="feature-description">
                    Recibe alertas cuando te añadan a un tablero o evento. Mantente informado de todo lo que pasa.
                </div>
            </div>

            <div class="feature-card">
                <div class="feature-icon-wrapper">
                    <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Size="Size.Large" Color="Color.Primary" />
                </div>
                <div class="feature-title">Permisos Granulares</div>
                <div class="feature-description">
                    Controla qué pueden hacer cada participante. Define quién puede añadir, editar o eliminar tareas y columnas.
                </div>
            </div>
        </div>

        <div class="cta-section">
            <div class="cta-title">¿Listo para empezar?</div>
            <div class="cta-description">
                Crea un tablero y comienza a organizar tus proyectos de forma visual
            </div>
            <MudButton Variant="Variant.Filled" Class="cta-button" StartIcon="@Icons.Material.Filled.Add" OnClick="CreateNewBoard">
                Crear Tablero
            </MudButton>
        </div>
    </div>
</div>

@code {
    private List<TodoBoard> userBoards = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.CheckAuthStateAsync();

        if (AuthService.CurrentUser != null)
        {
            userBoards = await BoardService.GetUserBoardsAsync(AuthService.CurrentUser.Id);
        }
        else
        {
            Navigation.NavigateTo("/");
        }

        isLoading = false;
    }

    private void NavigateToBoard(string boardId)
    {
        Navigation.NavigateTo($"/board/{boardId}", forceLoad: true);
    }

    private async Task CreateNewBoard()
    {
        if (AuthService.CurrentUser == null)
        {
            SnackbarService.Add("Incia sesión para poder disfrutar de los servicios de Kanvax", Severity.Warning);
            return;
        }

        var parameters = new DialogParameters<NewBoardDialog>();
        parameters.Add(x => x.UserId, AuthService.CurrentUser?.Id);
        parameters.Add(x => x.IsInitialBoard, false);

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small
        };

        var dialog = await DialogService.ShowAsync<NewBoardDialog>("Crear Tablero", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: TodoBoard board })
        {
            Navigation.NavigateTo($"/board/{board.Id}", forceLoad: true);
        }
    }
}