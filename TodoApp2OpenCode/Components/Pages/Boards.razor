@page "/board"
@inject NavigationManager Navigation
@inject IAuthService AuthService
@inject IBoardService BoardService
@inject IDialogService DialogService
@inject ISnackbar SnackbarService

<style>
    .boards-page {
        min-height: 100vh;
        background: linear-gradient(135deg, var(--mud-palette-background) 0%, var(--mud-palette-surface) 100%);
        padding: 40px 20px 200px;
    }

    .welcome-section {
        max-width: 900px;
        margin: 0 auto 60px;
        text-align: center;
    }

    .welcome-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 16px;
        color: var(--mud-palette-text-primary);
    }

    .welcome-subtitle {
        font-size: 1.1rem;
        color: var(--mud-palette-text-secondary);
        margin-bottom: 32px;
        line-height: 1.6;
    }

    .action-buttons {
        display: flex;
        justify-content: center;
        gap: 16px;
        flex-wrap: wrap;
    }

    .boards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 20px;
        max-width: 1200px;
        margin: 0 auto 80px;
    }

    .board-card {
        background: var(--mud-palette-surface);
        border-radius: 12px;
        padding: 20px;
        border: 1px solid var(--mud-palette-lines-default);
        cursor: pointer;
        transition: all 0.2s;
        text-align: left;
    }

    .board-card:hover {
        transform: translateY(-4px);
        border-color: var(--mud-palette-primary);
        box-shadow: 0 8px 24px rgba(126, 111, 255, 0.15);
    }

    .board-card-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--mud-palette-text-primary);
        margin-bottom: 8px;
    }

    .board-card-meta {
        font-size: 0.85rem;
        color: var(--mud-palette-text-secondary);
    }

    .board-card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 12px;
    }

    .owner-info {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .participant-avatars :deep(.mud-avatar-group .mud-avatar) {
        margin-left: -8px !important;
    }

</style>

<div class="boards-page">
    <div class="welcome-section">
        <h1 class="welcome-title">Bienvenido, @(AuthService.CurrentUser?.Username ?? "Usuario")</h1>
        <p class="welcome-subtitle">
            Organiza tus tareas de forma visual e intuitiva con tableros Kanban. 
            Crea columnas, arrastra tareas entre ellas y mantén tu productividad al máximo.
        </p>
        <div class="action-buttons">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="CreateNewBoard">
                Crear nuevo tablero
            </MudButton>
        </div>
    </div>

    @if (userBoards.Any())
    {
        <MudText Typo="Typo.h4" Style="text-align:center; margin-bottom: 16px">Tus tableros</MudText>
        <div class="boards-grid">
            @foreach (var board in userBoards)
            {
                <div class="board-card" @onclick="@(() => NavigateToBoard(board.Id))">
                    <div class="board-card-title">@board.Name</div>
                    <div class="board-card-meta">
                        @(board.Columns?.Count ?? 0) columnas · @(board.Items?.Count ?? 0) tareas
                    </div>
                    <div class="board-card-footer">
                        <div class="owner-info">
                            <MudAvatar Color="Color.Primary" Size="Size.Small">
                                @if (!string.IsNullOrEmpty(_ownerImages.GetValueOrDefault(board.User)))
                                {
                                    <img src="@($"data:image/jpeg;base64,{_ownerImages[board.User]}")" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" />
                                }
                                else
                                {
                                    @GetUserInitial(board.OwnerName)
                                }
                            </MudAvatar>
                            <MudText Typo="Typo.body2">@board.OwnerName</MudText>
                        </div>
                        @if (board.Participants != null && board.Participants.Any())
                        {
                            var participantIds = board.Participants.Keys.Take(5).ToList();
                            <MudAvatarGroup Max="4" Spacing="3" MaxColor="Color.Primary" Class="participant-avatars">
                                @foreach (var pid in participantIds)
                                {
                                    <MudAvatar Color="Color.Secondary" Size="Size.Small">
                                        @if (!string.IsNullOrEmpty(_participantImages.GetValueOrDefault(pid)))
                                        {
                                            <img src="@($"data:image/jpeg;base64,{_participantImages[pid]}")" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" />
                                        }
                                        else
                                        {
                                            @GetUserInitial(board.Participants.GetValueOrDefault(pid))
                                        }
                                    </MudAvatar>
                                }
                            </MudAvatarGroup>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<TodoBoard> userBoards = new();
    private bool isLoading = true;
    private Dictionary<string, string?> _ownerImages = new();
    private Dictionary<string, string?> _participantImages = new();

    protected override async Task OnInitializedAsync()
    {
        await AuthService.CheckAuthStateAsync();

        if (AuthService.CurrentUser != null)
        {
            userBoards = await BoardService.GetUserBoardsAsync(AuthService.CurrentUser.Id);
            await LoadParticipantImagesAsync();
        }
        else
        {
            Navigation.NavigateTo("/");
        }

        isLoading = false;
    }

    private async Task LoadParticipantImagesAsync()
    {
        foreach (var board in userBoards)
        {
            if (!string.IsNullOrEmpty(board.User) && !_ownerImages.ContainsKey(board.User))
            {
                _ownerImages[board.User] = await AuthService.GetUserProfileImageAsync(board.User);
            }

            if (board.Participants != null)
            {
                foreach (var pid in board.Participants.Keys)
                {
                    if (!_participantImages.ContainsKey(pid))
                    {
                        _participantImages[pid] = await AuthService.GetUserProfileImageAsync(pid);
                    }
                }
            }
        }
    }

    private string GetUserInitial(string? userName)
    {
        if (string.IsNullOrEmpty(userName)) return "?";
        return userName.Length > 0 ? userName[0].ToString().ToUpper() : "?";
    }

    private void NavigateToBoard(string boardId)
    {
        Navigation.NavigateTo($"/board/{boardId}", forceLoad: true);
    }

    private async Task CreateNewBoard()
    {
        if (AuthService.CurrentUser == null)
        {
            SnackbarService.Add("Incia sesión para poder disfrutar de los servicios de Kanvax", Severity.Warning);
            return;
        }

        var parameters = new DialogParameters<NewBoardDialog>();
        parameters.Add(x => x.UserId, AuthService.CurrentUser?.Id);
        parameters.Add(x => x.IsInitialBoard, false);

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small
        };

        var dialog = await DialogService.ShowAsync<NewBoardDialog>("Crear Tablero", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: TodoBoard board })
        {
            Navigation.NavigateTo($"/board/{board.Id}", forceLoad: true);
        }
    }
}