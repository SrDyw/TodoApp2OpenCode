@inject IJSRuntime JSRuntime

@if (_isVisible)
{
    <div class="splash-overlay">
        <div class="splash-content">
            <div class="splash-logo">
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Size="Size.Large" Style="font-size: 80px; color: var(--mud-palette-primary);" />
            </div>
            <MudText Typo="Typo.h3" Class="splash-title" Style="font-weight: 800; letter-spacing: -1px;">
                @Config.AppName
            </MudText>
            <div class="splash-loading">
                <MudProgressCircular Color="Color.Primary" Size="Size.Medium" Indeterminate="true" />
            </div>
        </div>
    </div>
}

<style>
    .splash-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: linear-gradient(135deg, #1a1a27 0%, #12121c 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }

    .splash-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 24px;
    }

    .splash-logo {
        animation: pulse 2s ease-in-out infinite;
    }

    .splash-title {
        background: linear-gradient(90deg, #7e6fff 0%, #a5a0f0 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .splash-loading {
        margin-top: 16px;
    }

    @@keyframes pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.05); }
    }
</style>

