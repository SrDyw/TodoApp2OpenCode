@using TodoApp2OpenCode.Services
@using TodoApp2OpenCode.Components.Dialogs
@using Microsoft.AspNetCore.Components.Web

@inject IDialogService DialogService
@inject TodoService TodoService
@inject IBoardService BoardService
@inject ILogService LogService
@inject IAuthService AuthService
@inject ISnackbar SnackbarService

<div class="board-column @(IsDropTarget ? "drop-zone-hover" : "")"
     style="--column-color: @Column.Color;"
     data-column-id="@Column.Id"
     @ondragover="HandleDragOver"
     @ondrop="HandleDrop"
     @ondragenter="HandleDragEnter"
     @ondragleave="HandleDragLeave">
    
    <div class="column-header column-drag-handle">
        <div class="column-title-area" @onmousedown="@(CanEdit ? (e) => StartColumnDrag.InvokeAsync(e) : null)">
            @if (CanEdit)
            {
                <MudIcon Icon="@Icons.Material.Filled.DragIndicator" Size="Size.Small" Class="mr-1 column-drag-icon" />
            }
            <div class="column-color-dot" style="background-color: @Column.Color;"></div>
            <MudText Typo="Typo.h6" Class="column-title">@Column.Name</MudText>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="ml-1">
                @ItemCount
            </MudChip>
        </div>
        
        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Dense="true" Edge="Edge.End">
            @if (CanEdit)
            {
                <MudMenuItem OnClick="EditColumnAsync">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                        <span>Editar</span>
                    </MudStack>
                </MudMenuItem>
            }
            @if (CanDelete)
            {
                <MudDivider />
                <MudMenuItem OnClick="DeleteColumnAsync" Class="text-danger">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" />
                        <span>Eliminar</span>
                    </MudStack>
                </MudMenuItem>
            }
        </MudMenu>
    </div>
    
    <div class="column-content">
        @foreach (var item in Items)
        {
            <TodoCard 
                BoardId="@BoardId"
                Item="@item"
                CanModify="@CanModifyItems"
                CanDelete="@CanDeleteItems"
                OnStartDrag="@(item => StartItemDrag.InvokeAsync(item))"
                OnItemHover="@((itemId) => OnItemHover.InvokeAsync(itemId))"
                ItemUpdated="OnItemUpdated"
                ItemDeleted="OnItemDeleted" />
        }
    </div>
</div>

<style>
    .board-column {
        flex: 0 0 320px;
        max-width: 320px;
        background: var(--mud-palette-surface);
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        max-height: 100%;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        transition: transform 0.2s, box-shadow 0.2s;
    }
    
    .board-column.drop-zone-hover {
        background: color-mix(in srgb, var(--mud-palette-primary) 10%, transparent);
    }
    
    .column-header {
        padding: 16px;
        border-bottom: 1px solid var(--mud-palette-divider);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--mud-palette-surface);
        border-radius: 12px 12px 0 0;
    }
    
    .column-drag-handle { cursor: grab; }
    .column-drag-handle:active { cursor: grabbing; }
    
    .column-title-area {
        display: flex;
        align-items: center;
        gap: 8px;
        flex: 1;
        min-width: 0;
    }
    
    .column-color-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    
    .column-title {
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    
    .column-drag-icon { opacity: 0.5; cursor: grab; }
    .column-header:hover .column-drag-icon { opacity: 1; }
    
    .column-content {
        flex: 1;
        overflow-y: scroll;
        padding: 12px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        min-height: 100px;
        height: 100%;
    }
    .text-strikethrough { text-decoration: line-through; color: var(--mud-palette-text-disabled); }
    
    .item-steps-progress {
        margin-top: 8px;
    }
</style>

@code {
    [Parameter]
    public string BoardId { get; set; } = string.Empty;

    [Parameter]
    public TodoColumn Column { get; set; } = null!;

    [Parameter]
    public List<TodoItem> Items { get; set; } = new();

    [Parameter]
    public bool CanEdit { get; set; }

    [Parameter]
    public bool CanDelete { get; set; }

    [Parameter]
    public bool CanModifyItems { get; set; }

    [Parameter]
    public bool CanDeleteItems { get; set; }

    [Parameter]
    public bool IsDropTarget { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> StartColumnDrag { get; set; }

    [Parameter]
    public EventCallback<TodoItem> StartItemDrag { get; set; }

    [Parameter]
    public EventCallback<string> OnDrop { get; set; }

    [Parameter]
    public EventCallback<string> OnDragEnter { get; set; }

    [Parameter]
    public EventCallback OnDragLeave { get; set; }

    [Parameter]
    public EventCallback<string> OnItemHover { get; set; }

    [Parameter]
    public EventCallback ColumnUpdated { get; set; }

    [Parameter]
    public EventCallback ColumnDeleted { get; set; }

    [Parameter]
    public EventCallback ItemUpdated { get; set; }

    [Parameter]
    public EventCallback ItemDeleted { get; set; }

    private int ItemCount => Items.Count;

    private async Task EditColumnAsync()
    {
        if (string.IsNullOrEmpty(BoardId)) return;
        
        var defaultColumnName = Column.Name;

        var editing = new TodoColumn { Id = Column.Id, Name = Column.Name, Color = Column.Color, CreatedAt = Column.CreatedAt, UpdatedAt = Column.UpdatedAt };
        var parameters = new DialogParameters<EditColumnDialog>();
        parameters.Add(x => x.Column, editing);

        var dialog = await DialogService.ShowAsync<EditColumnDialog>("Editar Columna", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: EditColumnDialog.EditColumnResult editResult })
        {
            if (string.IsNullOrWhiteSpace(editResult.NewName) == false)
            {
                await LogService.AddLogAsync(new LogItem
                {
                    Action = DatabaseAction.Actualizar,
                    BoardId = BoardId,
                    Message = $"Actualiza columna {defaultColumnName} -> {editResult.NewName}",
                    User = AuthService.CurrentUser?.Username ?? ""
                });
            }
            if (string.IsNullOrWhiteSpace(editResult.NewColor) == false)
            {
                await LogService.AddLogAsync(new LogItem
                {
                    Action = DatabaseAction.Actualizar,
                    BoardId = BoardId,
                    Message = $"Actualiza color de la columna a {editResult.NewColor}",
                    User = AuthService.CurrentUser?.Username ?? ""
                });
            }

            await BoardService.UpdateColumnAsync(BoardId, editing);
            SnackbarService.Add("Columna actualizada", Severity.Success);
            await ColumnUpdated.InvokeAsync();
        }
    }

    private async Task DeleteColumnAsync()
    {
        if (string.IsNullOrEmpty(BoardId)) return;

        var count = Items.Count;
        var msg = count > 0 ? $"¿Eliminar '{Column.Name}' y sus {count} tareas?" : $"¿Eliminar '{Column.Name}'?";
        var parameters = new DialogParameters<DeletionConfirmDialog>();
        parameters.Add(x => x.ContentText, msg);
        parameters.Add(x => x.ButtonText, "Eliminar");
        parameters.Add(x => x.Color, Color.Error);

        var dialog = await DialogService.ShowAsync<DeletionConfirmDialog>("Confirmar", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: true })
        {
            await BoardService.DeleteColumnAsync(BoardId, Column.Id);
            SnackbarService.Add("Columna eliminada", Severity.Success);
            await ColumnDeleted.InvokeAsync();
        }
    }

    private async Task OnItemUpdated()
    {
        await ItemUpdated.InvokeAsync();
    }

    private async Task OnItemDeleted()
    {
        await ItemDeleted.InvokeAsync();
    }

    private void HandleDragOver(DragEventArgs e)
    {
        e.DataTransfer!.DropEffect = "move";
    }

    private async Task HandleDrop()
    {
        if (OnDrop.HasDelegate)
        {
            await OnDrop.InvokeAsync(Column.Id);
        }
    }

    private async Task HandleDragEnter()
    {
        if (OnDragEnter.HasDelegate)
        {
            await OnDragEnter.InvokeAsync(Column.Id);
        }
    }

    private async Task HandleDragLeave()
    {
        if (OnDragLeave.HasDelegate)
        {
            await OnDragLeave.InvokeAsync();
        }
    }
}