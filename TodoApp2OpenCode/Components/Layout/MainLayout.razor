@inherits LayoutComponentBase
@inject IDialogService DialogService
@inject ISnackbar SnackbarService
@inject IAuthService AuthService
@inject INotificationService NotificationService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<MudThemeProvider Theme="@_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
@if (_isLoading)
{
    <SplashScreen />
}
@if (!_isLoading)
{
<MudLayout>
    <style>
        .board-page-bg {
            min-height: 100vh;
            background-image: 
                linear-gradient(rgba(128, 128, 128, 0.04) 1px, transparent 1px),
                linear-gradient(90deg, rgba(128, 128, 128, 0.04) 1px, transparent 1px);
            background-size: 40px 40px;
        }
    </style>
    <style>
        .notifications-list {
            max-height: 300px;
            overflow-y: auto;
        }
        .app-navbar {
            backdrop-filter: blur(10px);
        }
        
        .app-footer {
            background: var(--mud-palette-surface);
            border-top: 1px solid var(--mud-palette-lines-default);
            padding: 16px 0;
            margin-top: auto;
            z-index: 2000;
            padding-right: 24px;
        }
        
        .user-menu-avatar {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        
        .user-avatar-wrapper {
            overflow: hidden;
        }
        
        .user-avatar-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
        }
    </style>
    <MudAppBar Elevation="3" Class="app-navbar">
            @if (AuthService.CurrentUser != null)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
            }
            @* <MudText Typo="Typo.h5" Class="ml-3 cursor-pointer" @onclick="@((e) => Navigation.NavigateTo("/board"))">@Config.AppName</MudText> *@
            <div class="cursor-pointer">
                <AppLogo Typo="Typo.h5" OnClick="@(() => Navigation.NavigateTo("/board"))" />
            </div>
        <MudSpacer />
        
        @if (IsAuthenticated)
        {
            <MudMenu AnchorOrigin="Origin.BottomRight"
                     TransformOrigin="Origin.TopRight">
                <ActivatorContent>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="cursor-pointer">
                        <MudAvatar Color="Color.Primary" Size="Size.Medium" Class="user-avatar-wrapper">
                            @if (!string.IsNullOrEmpty(_profileImageBase64))
                            {
                                <img src="@($"data:image/jpeg;base64,{_profileImageBase64}")" class="user-avatar-img" />
                            }
                            else
                            {
                                @GetAvatarInitial()
                            }
                        </MudAvatar>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2" Class="font-weight-bold">
                                @(string.IsNullOrWhiteSpace(AuthService.CurrentUser?.Name) ? CurrentUsername : AuthService.CurrentUser?.Name)
                            </MudText>
                            @if (!string.IsNullOrWhiteSpace(AuthService.CurrentUser?.Name))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @@@CurrentUsername
                                </MudText>
                            }
                        </MudStack>
                        <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" Color="Color.Inherit" />
                    </MudStack>
                </ActivatorContent>
                <ChildContent>
                <MudMenuItem OnClick="NavigateToProfile">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Size="Size.Small" />
                        <span>Mi Perfil</span>
                    </MudStack>
                </MudMenuItem>
                <MudMenuItem OnClick="NavigateToMySchedule">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.EventNote" Size="Size.Small" />
                        <span>Mi Calendario</span>
                    </MudStack>
                </MudMenuItem>
                <MudDivider />
                <MudMenuItem OnClick="Logout">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Logout" Size="Size.Small" Color="Color.Error" />
                        <span>Cerrar Sesión</span>
                    </MudStack>
                </MudMenuItem>
                </ChildContent>
            </MudMenu>
            <MudBadge Content="@UnreadNotificationCount" 
                      Color="Color.Error" 
                      Visible="@(UnreadNotificationCount > 0)"
                      Class="mr-3"
                        Overlap>
                <MudMenu Icon="@Icons.Material.Filled.Notifications" 
                         Color="Color.Inherit"
                         AnchorOrigin="Origin.BottomRight"
                         TransformOrigin="Origin.TopRight">
                    <MudText Style="padding: 16px">Notificaciones</MudText>
                    <MudDivider />
                    @if (Notifications.Any())
                    {
                        <div class="notifications-list">
                        @foreach (var notification in Notifications.Take(10))
                        {
                            <MudMenuItem OnClick="@(() => OnNotificationClick(notification))">
                                <MudStack Spacing="1" Style="@(notification.IsRead ? "" : "border-left: 3px solid var(--mud-palette-primary); padding-left: 8px;")">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width: 100%;">
                                        <MudText Typo="Typo.body2" Style="@(notification.IsRead ? "color: var(--mud-palette-text-secondary);" : "font-weight: bold;")">
                                            @notification.Title
                                            @if (!notification.IsRead)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="ml-1">Nuevo</MudChip>
                                            }
                                        </MudText>
                                        <MudStack Row="true" Spacing="0">
                                            @if (!notification.IsRead)
                                            {
                                                <MudIconButton Icon="@Icons.Material.Filled.MarkEmailRead" 
                                                               Size="Size.Small" 
                                                               Color="Color.Default"
                                                               Title="Marcar como leída"
                                                               OnClick="@(() => MarkNotificationAsRead(notification))"
                                                               StopPropagation="true" />
                                            }
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                                           Size="Size.Small" 
                                                           Color="Color.Error"
                                                           OnClick="@(() => DeleteNotification(notification))"
                                                           StopPropagation="true" />
                                        </MudStack>
                                    </MudStack>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @notification.Message
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                        @notification.CreatedAt.ToString("dd/MM HH:mm")
                                    </MudText>
                                </MudStack>
                            </MudMenuItem>
                        }
                        @if (Notifications.Count > 10)
                        {
                            <MudMenuItem Disabled="true">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    +@(Notifications.Count - 10) más...
                                </MudText>
                            </MudMenuItem>
                        }
                        </div>
                    }
                    else
                    {
                        <MudMenuItem Disabled="true">
                            <MudText Color="Color.Secondary">Sin notificaciones</MudText>
                        </MudMenuItem>
                    }
                    @if (Notifications.Any())
                    {
                        <MudDivider />
                        <MudMenuItem OnClick="DeleteAllNotifications">
                            <MudText Color="Color.Error">Borrar todas</MudText>
                        </MudMenuItem>
                        <MudMenuItem OnClick="MarkAllAsRead">
                            <MudText Color="Color.Primary">Marcar todas como leídas</MudText>
                        </MudMenuItem>
                    }
                </MudMenu>
            </MudBadge>
            
        }
        else
        {
            @if (PrivateConfig.ALLOW_CREATE_ACCOUNT)
            {
                <MudButton Color="Color.Inherit" 
                           Variant="Variant.Text"
                           OnClick="OpenRegisterDialog"
                           Class="mr-2">
                    Registrarse
                </MudButton>
            }
            <MudButton Color="Color.Primary" 
                       Variant="Variant.Filled"
                       OnClick="OpenLoginDialog">
                Iniciar Sesión
            </MudButton>
        }
        
        <MudIconButton Icon="@(DarkLightModeButtonIcon)" Color="Color.Inherit" OnClick="@DarkModeToggle" />
    </MudAppBar>
    @if (AuthService.CurrentUser != null)
    {
        <MudDrawer id="nav-drawer" @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
            <NavMenu />
        </MudDrawer>
    }
    <MudMainContent Class="pt-16 pa-4 board-page-bg">
        @Body
    </MudMainContent>
    
    <footer class="app-footer">
        <MudStack Row="true" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.caption" Color="Color.Primary">
                © @DateTime.Now.Year @Config.AppName - Organiza tu trabajo
            </MudText>
            <MudLink Href="https://github.com/SrDyw/TodoApp2OpenCode" 
                        Typo="Typo.caption" 
                        Color="Color.Primary"
                        Target="Target.Blank"
                        Underline="Underline.None">
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.IosShare" Size="Size.Small" />
                    <span>GitHub</span>
                </MudStack>
            </MudLink>
        </MudStack>
    </footer>
</MudLayout>
    
}


<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _isLoading = true;
    private bool _drawerOpen = true;
    private bool _isDarkMode = true;
    private bool IsAuthenticated => AuthService.IsAuthenticated;
    private string CurrentUsername => AuthService.CurrentUser?.Username ?? "Usuario";
    private string? _profileImageBase64;
    private MudTheme? _theme = null;
    private List<Notification> Notifications = new();
    private int UnreadNotificationCount = 0;

    protected override async Task OnInitializedAsync()
    {
        base.OnInitialized();

        _theme = new()
        {
            PaletteLight = _lightPalette,
            PaletteDark = _darkPalette,
            LayoutProperties = new LayoutProperties()
        };

        await LoadThemePreference();
        AuthService.SetAuthStateChangedCallback(OnAuthStateChanged);
        await AuthService.CheckAuthStateAsync();

        if (AuthService.CurrentUser != null)
        {
            _profileImageBase64 = await AuthService.GetUserProfileImageAsync(AuthService.CurrentUser.Id);
        }

        await LoadNotifications();

        var t = new System.Timers.Timer(500);
        t.Elapsed += (e, s) =>
        {
            _isLoading = false;
            InvokeAsync(StateHasChanged);
            t.Stop();
        };
        t.Start();

        var notificationTimer = new System.Timers.Timer(5000);
        notificationTimer.Elapsed += async (e, s) =>
        {
            if (AuthService.CurrentUser != null && AuthService.IsAuthenticated)
            {
                await InvokeAsync(async () =>
                {
                    Notifications = await NotificationService.GetAllAsync(AuthService.CurrentUser.Id);
                    var (msg, count) = await NotificationService.GetUnreadCountAsync(AuthService.CurrentUser.Id);
                    if (count != -1)
                    {
                        UnreadNotificationCount = count;
                        StateHasChanged();
                    }
                });
            }
        };
        notificationTimer.Start();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender == false) return;
        await LoadDrawerStatus();

        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadNotifications()
    {
        if (AuthService.CurrentUser != null)
        {
            Notifications = await NotificationService.GetAllAsync(AuthService.CurrentUser.Id);
            var (msg, count) = await NotificationService.GetUnreadCountAsync(AuthService.CurrentUser.Id);
            if (count != -1)
            {
                UnreadNotificationCount = count;
            }
        }
    }

    private async Task LoadDrawerStatus()
    {
        try
        {
            var val = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", "flowboard_drawer");
            if (string.IsNullOrWhiteSpace(val) == false)
                _drawerOpen = val == "true";
        }
        catch {}
    }

    private async Task LoadThemePreference()
    {
        try
        {
            var isDarkMode = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", "flowboard_theme");
            if (!string.IsNullOrEmpty(isDarkMode))
            {
                _isDarkMode = isDarkMode == "dark";
            }
        }
        catch
        {
        }
    }

    private async Task SaveThemePreference()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "flowboard_theme", _isDarkMode ? "dark" : "light");
        }
        catch
        {
        }
    }

    private void OnAuthStateChanged(Models.User? user)
    {
        InvokeAsync(async () =>
        {
            // StateHasChanged();
            if (user != null)
            {
                await LoadNotifications();
            }
            else
            {
                Notifications.Clear();
                UnreadNotificationCount = 0;
            }
        });
    }

    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
        JSRuntime.InvokeVoidAsync("localStorage.setItem", "flowboard_drawer", _drawerOpen);
    }

    private async Task DarkModeToggle()
    {
        _isDarkMode = !_isDarkMode;
        await SaveThemePreference();
    }

    private async Task OpenLoginDialog()
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<LoginDialog>("Iniciar Sesión", options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: true })
        {
            Navigation.NavigateTo("/board", forceLoad: true);
        }
    }

    private async Task OpenRegisterDialog()
    {
        if (!PrivateConfig.ALLOW_CREATE_ACCOUNT) return;
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<RegisterDialog>("Crear Cuenta", options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: true })
        {
            Navigation.NavigateTo("/board", forceLoad: true);
        }
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();

        Navigation.NavigateTo("/", forceLoad: true);
    }

    private void NavigateToCalendar()
    {
        var lastBoardId = AuthService.GetLastVisitedBoard();
        if (!string.IsNullOrEmpty(lastBoardId))
        {
            Navigation.NavigateTo($"/board/{lastBoardId}/schedule", forceLoad: true);
        }
        else
        {
            Navigation.NavigateTo("/board", forceLoad: true);
        }
    }

    private void NavigateToMySchedule()
    {
        Navigation.NavigateTo("/my-schedule", forceLoad: true);
    }

    private void NavigateToProfile()
    {
        Navigation.NavigateTo("/profile", forceLoad: true);
    }

    private async Task OnNotificationClick(Notification notification)
    {
        if (!notification.IsRead)
        {
            await NotificationService.MarkAsReadAsync(notification.Id);
            notification.IsRead = true;
            var (msg, notificationCount) = await NotificationService.GetUnreadCountAsync(AuthService.CurrentUser?.Id ?? "");

            if (notificationCount != -1)
            {
                UnreadNotificationCount = notificationCount;
                StateHasChanged();
            }
        }

        if (!string.IsNullOrEmpty(notification.NavigateTo))
        {
            Navigation.NavigateTo(notification.NavigateTo, forceLoad: false);
        }
    }

    private async Task MarkAllAsRead()
    {
        if (AuthService.CurrentUser != null)
        {
            await NotificationService.MarkAllAsReadAsync(AuthService.CurrentUser.Id);
            foreach (var n in Notifications)
            {
                n.IsRead = true;
            }
            UnreadNotificationCount = 0;
            StateHasChanged();
        }
    }

    private async Task DeleteNotification(Notification notification)
    {
        var parameters = new DialogParameters<DeletionConfirmDialog>();
        parameters.Add(x => x.ContentText, $"¿Eliminar la notificación '{notification.Title}'?");
        parameters.Add(x => x.ButtonText, "Eliminar");
        parameters.Add(x => x.Color, Color.Error);

        var dialog = await DialogService.ShowAsync<DeletionConfirmDialog>("Confirmar", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: true })
        {
            await NotificationService.DeleteAsync(notification.Id);
            Notifications.Remove(notification);
            if (!notification.IsRead)
            {
                var (msg, notificationCount) = await NotificationService.GetUnreadCountAsync(AuthService.CurrentUser?.Id ?? "");

                if (notificationCount != -1)
                {
                    UnreadNotificationCount = notificationCount;
                }
            }
            StateHasChanged();
        }
    }

    private async Task MarkNotificationAsRead(Notification notification)
    {
        if (notification.IsRead) return;
        
        await NotificationService.MarkAsReadAsync(notification.Id);
        notification.IsRead = true;
        var (msg, notificationCount) = await NotificationService.GetUnreadCountAsync(AuthService.CurrentUser?.Id ?? "");

        if (notificationCount != -1)
        {
            UnreadNotificationCount = notificationCount;
        }
        StateHasChanged();
    }

    private async Task DeleteAllNotifications()
    {
        var parameters = new DialogParameters<DeletionConfirmDialog>();
        parameters.Add(x => x.ContentText, "¿Eliminar todas las notificaciones?");
        parameters.Add(x => x.ButtonText, "Eliminar todas");
        parameters.Add(x => x.Color, Color.Error);

        var dialog = await DialogService.ShowAsync<DeletionConfirmDialog>("Confirmar", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: true } && AuthService.CurrentUser != null)
        {
            await NotificationService.DeleteAllAsync(AuthService.CurrentUser.Id);
            Notifications.Clear();
            UnreadNotificationCount = 0;
            StateHasChanged();
        }
    }

    private readonly PaletteLight _lightPalette = new()
    {
        Black = "#110e2d",
        AppbarText = "#424242",
        AppbarBackground = "rgba(255,255,255,0.8)",
        DrawerBackground = "#ffffff",
        GrayLight = "#e8e8e8",
        GrayLighter = "#f9f9f9",
    };

    private readonly PaletteDark _darkPalette = new()
    {
        Primary = "#7e6fff",
        Surface = "#1e1e2d",
        Background = "#1a1a27",
        BackgroundGray = "#151521",
        AppbarText = "#92929f",
        AppbarBackground = "rgba(26,26,39,0.8)",
        DrawerBackground = "#1a1a27",
        ActionDefault = "#74718e",
        ActionDisabled = "#9999994d",
        ActionDisabledBackground = "#605f6d4d",
        TextPrimary = "#b2b0bf",
        TextSecondary = "#92929f",
        TextDisabled = "#ffffff33",
        DrawerIcon = "#92929f",
        DrawerText = "#92929f",
        GrayLight = "#2a2833",
        GrayLighter = "#1e1e2d",
        Info = "#4a86ff",
        Success = "#3dcb6c",
        Warning = "#ffb545",
        Error = "#ff3f5f",
        LinesDefault = "#33323e",
        TableLines = "#33323e",
        Divider = "#292838",
        OverlayLight = "#1e1e2d80",
    };

    public string DarkLightModeButtonIcon => _isDarkMode switch
    {
        true => Icons.Material.Filled.LightMode,
        false => Icons.Material.Filled.DarkMode,
    };

    private string GetAvatarInitial()
    {
        var name = AuthService.CurrentUser?.Name ?? AuthService.CurrentUser?.Username ?? "?";
        return name.Length > 0 ? name[0].ToString().ToUpper() : "?";
    }
}
