@using TodoApp2OpenCode.Services
@inject IDialogService DialogService
@inject ISnackbar SnackbarService
@inject TodoService TodoService

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-4">Asignar fecha a: @Item.Title</MudText>
        
        <MudDatePicker Label="Fecha" 
                       @bind-Date="selectedDate"
                       DateFormat="dd/MM/yyyy"
                       MinDate="DateTime.Today.AddDays(-365)"
                       MaxDate="DateTime.Today.AddDays(365)"
                       Class="mb-4" />
        
        <MudTimePicker Label="Hora (opcional)" 
                       @bind-Time="selectedTime"
                       AmPm="false"
                       OkButton="true"
                       CancelButton="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" 
                   Variant="Variant.Filled" 
                   OnClick="Submit"
                   Disabled="@(selectedDate == null)">
            Asignar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public TodoItem Item { get; set; } = null!;
    
    [Parameter]
    public string BoardId { get; set; } = string.Empty;

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    private DateTime? selectedDate;
    private TimeSpan? selectedTime;

    protected override void OnInitialized()
    {
        if (Item.DueDate.HasValue)
        {
            selectedDate = Item.DueDate.Value.Date;
            selectedTime = Item.DueDate.Value.TimeOfDay;
        }
        else
        {
            selectedDate = DateTime.Today;
        }
    }

    private async Task Submit()
    {
        if (selectedDate.HasValue)
        {
            var dueDate = selectedDate.Value;
            
            if (selectedTime.HasValue)
            {
                dueDate = dueDate.Add(selectedTime.Value);
            }
            else
            {
                dueDate = dueDate.AddHours(9);
            }

            var success = await TodoService.UpdateItemDueDateAsync(BoardId, Item.Id, dueDate);
            
            if (success)
            {
                SnackbarService.Add("Fecha asignada correctamente", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                SnackbarService.Add("Error al asignar la fecha", Severity.Error);
            }
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
