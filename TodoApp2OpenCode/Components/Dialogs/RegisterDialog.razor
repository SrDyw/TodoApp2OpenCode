@inject IAuthService AuthService
<MudCard>
    <MudCardMedia Image="https://images.unsplash.com/photo-1552664730-d307ca884978?w=500&h=200&fit=crop" Height="160" />
    <MudCardContent>
        <MudText Typo="Typo.h5" Class="mb-3" Style="font-weight: 600;">Crear Cuenta</MudText>
        <MudStack Spacing="2">
            <MudTextField @bind-Value="Username" 
                          Label="Nombre de usuario" 
                          Variant="Variant.Outlined"
                          Required="true"
                          Placeholder="Tu nombre"
                          Margin="Margin.Dense"
                          AutoFocus="true"
                          Immediate="true" />
            
            <MudTextField @bind-Value="Email" 
                          Label="Email" 
                          Variant="Variant.Outlined"
                          Required="true"
                          InputType="InputType.Email"
                          Placeholder="tu@email.com"
                          Margin="Margin.Dense"
                          Immediate="true" />
            
            <MudTextField @bind-Value="Password" 
                          Label="Contraseña" 
                          Variant="Variant.Outlined"
                          Required="true"
                          InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                          OnAdornmentClick="TogglePasswordVisibility"
                          HelperText="Mínimo 6 caracteres"
                          Margin="Margin.Dense"
                          Immediate="true" />
            
            <MudTextField @bind-Value="ConfirmPassword" 
                          Label="Confirmar contraseña" 
                          Variant="Variant.Outlined"
                          Required="true"
                          InputType="@(_showConfirmPassword ? InputType.Text : InputType.Password)"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_showConfirmPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                          OnAdornmentClick="ToggleConfirmPasswordVisibility"
                          Error="@_passwordMismatch"
                          ErrorText="Las contraseñas no coinciden"
                          Margin="Margin.Dense"
                          Immediate="true" />
            
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Class="my-2">
                    @ErrorMessage
                </MudAlert>
            }
        </MudStack>
    </MudCardContent>
    <MudCardActions Class="justify-end pa-4">
        <MudButton Variant="Variant.Text" 
                   Color="Color.Default"
                   OnClick="Cancel"
                   Class="mr-2">
            Cancelar
        </MudButton>
        <MudButton Color="Color.Primary" 
                   Variant="Variant.Filled" 
                   OnClick="Submit"
                   Disabled="@IsLoading"
                   Class="px-4">
            @if (IsLoading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Crear Cuenta
        </MudButton>
    </MudCardActions>
</MudCard>

@code {
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    private string Username { get; set; } = string.Empty;
    private string Email { get; set; } = string.Empty;
    private string Password { get; set; } = string.Empty;
    private string ConfirmPassword { get; set; } = string.Empty;
    
    private bool _showPassword = false;
    private bool _showConfirmPassword = false;
    private bool _passwordMismatch => !string.IsNullOrEmpty(ConfirmPassword) && Password != ConfirmPassword;
    private bool IsLoading = false;
    private string ErrorMessage { get; set; } = string.Empty;

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private void ToggleConfirmPasswordVisibility()
    {
        _showConfirmPassword = !_showConfirmPassword;
    }

    private async Task Submit()
    {
        if (Password != ConfirmPassword)
        {
            ErrorMessage = "Las contraseñas no coinciden";
            return;
        }

        IsLoading = true;
        ErrorMessage = string.Empty;
        StateHasChanged();

        var (success, error) = await AuthService.RegisterAsync(Username, Email, Password);

        IsLoading = false;

        if (success)
        {
            MudDialog?.Close(DialogResult.Ok(true));
        }
        else
        {
            ErrorMessage = error ?? "Error desconocido";
            StateHasChanged();
        }
    }

    private void Cancel() => MudDialog?.Cancel();
}
