@inject IAuthService AuthService
<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_searchText" 
                         Label="Buscar usuario" 
                         AutoFocus
                         Variant="Variant.Outlined"
                         Placeholder="Escribe para buscar..."
                         DebounceInterval="300"
                         OnDebounceIntervalElapsed="PerformSearch"
                         Adornment="Adornment.Start"
                         AdornmentIcon="@Icons.Material.Filled.Search"
                         Immediate="true" />

            @if (_isSearching)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            }
            else if (_searchResults.Any())
            {
                <MudText Typo="Typo.subtitle2">Resultados:</MudText>
                <div class="search-results">
                    @foreach (var user in _searchResults)
                    {
                        <MudButton FullWidth="true" 
                                   Color="Color.Default"
                                   OnClick="@(() => SelectUser(user))"
                                   Class="search-result-item">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width: 100%;">
                                <div>
                                    <MudText>@user.Username</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@user.Email</MudText>
                                </div>
                                <MudIcon Icon="@Icons.Material.Filled.Add" Color="Color.Primary" />
                            </MudStack>
                        </MudButton>
                        <MudDivider/>
                    }
                </div>
            }
            else if (!string.IsNullOrEmpty(_searchText) && _searchText.Length >= 2)
            {
                <MudText Color="Color.Secondary">No se encontraron usuarios</MudText>
            }

            @if (_selectedUsers.Any())
            {
                <MudDivider Class="my-2" />
                <MudText Typo="Typo.subtitle2">Participantes seleccionados:</MudText>
                <div class="selected-users">
                    @foreach (var user in _selectedUsers)
                    {
                        <MudChip T="string" 
                                 Color="Color.Primary" 
                                 Variant="Variant.Outlined"
                                 OnClose="@(() => RemoveUser(user))">
                            @user.Username
                        </MudChip>
                    }
                </div>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@(!_selectedUsers.Any())">
            Añadir @(_selectedUsers.Count) participante(s)
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .selected-users {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .search-results {
        max-height: 200px;
        overflow-y: auto;
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 8px;
    }

    .search-result-item {
        justify-content: flex-start;
        text-transform: none;
        border-radius: 0;
    }

    .search-result-item:last-child {
        border-bottom: none;
    }
</style>

@code {
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public List<string> ExistingParticipantIds { get; set; } = new();

    private string _searchText = string.Empty;
    private bool _isSearching = false;
    private List<UserInfo> _searchResults = new();
    private List<SelectedUser> _selectedUsers = new();

    private class SelectedUser
    {
        public string Id { get; set; } = "";
        public string Username { get; set; } = "";
        public string Email { get; set; } = "";
    }

    private async Task PerformSearch()
    {
        if (string.IsNullOrWhiteSpace(_searchText) || _searchText.Length < 2)
        {
            _searchResults = new List<UserInfo>();
            return;
        }

        _isSearching = true;

        var users = await AuthService.SearchUsersAsync(_searchText);
        // var existingIds = _selectedUsers.Select(u => u.Id).Concat(ExistingParticipantIds).ToHashSet();
        _searchResults = users;

        _isSearching = false;
    }

    private void SelectUser(UserInfo user)
    {
        if (!_selectedUsers.Any(u => u.Id == user.Id))
        {
            _selectedUsers.Add(new SelectedUser
            {
                Id = user.Id,
                Username = user.Username,
                Email = user.Email
            });
            _searchText = string.Empty;
            _searchResults = new List<UserInfo>();
        }
    }

    private void RemoveUser(SelectedUser user)
    {
        _selectedUsers.Remove(user);
    }

    private void Submit()
    {
        var result = _selectedUsers.Select(u => (u.Id, u.Username)).ToList();
        MudDialog?.Close(DialogResult.Ok(result));
    }

    private void Cancel() => MudDialog?.Cancel();
}
