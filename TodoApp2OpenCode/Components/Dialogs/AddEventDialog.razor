@namespace TodoApp2OpenCode.Components.Dialogs
<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="Title" 
                      Label="Nombre del evento" 
                      Variant="Variant.Outlined" 
                      Required="true" 
                      Class="mb-3" />
        
        <MudTextField @bind-Value="Description" 
                      Label="Descripción" 
                      Variant="Variant.Outlined" 
                      Lines="3" 
                      Class="mb-3" />
        
        <MudDatePicker @bind-Date="EventDate" 
                       Label="Fecha del evento" 
                       Variant="Variant.Outlined" 
                       Required="true" 
                       Class="mb-3" />
        
        <MudButton Variant="Variant.Outlined" 
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.People"
                   OnClick="OpenUserSelection"
                   Class="mb-3">
            @(SelectedParticipants.Any() ? $"{SelectedParticipants.Count} participante(s)" : "Seleccionar participantes")
        </MudButton>

        @if (SelectedParticipants.Any())
        {
            <div class="selected-participants">
                @foreach (var participant in SelectedParticipants)
                {
                    <MudChip T="string" 
                             Color="Color.Primary" 
                             Variant="Variant.Outlined"
                             OnClose="@(() => RemoveParticipant(participant.Key))">
                        @participant.Value
                    </MudChip>
                }
            </div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">
            Cancelar
        </MudButton>
        <MudButton OnClick="Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="@string.IsNullOrWhiteSpace(Title)">
            Crear evento
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .selected-participants {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }
</style>

@code {
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public DateTime? PreSelectedDate { get; set; }

    [Parameter]
    public Dictionary<string, string> AvailableParticipants { get; set; } = new();

    [Inject]
    private IDialogService DialogService { get; set; } = null!;

    public string Title { get; set; } = string.Empty;
    public string? Description { get; set; }
    public DateTime? EventDate { get; set; }
    public Dictionary<string, string> SelectedParticipants { get; set; } = new();

    protected override void OnInitialized()
    {
        EventDate = PreSelectedDate ?? DateTime.Today;
    }

    private async Task OpenUserSelection()
    {
        var parameters = new DialogParameters<UserSelectionDialog>();
        parameters.Add(x => x.Source, AvailableParticipants);
        parameters.Add(x => x.PreSelectedUserIds, new HashSet<string>(SelectedParticipants.Keys));
        
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small
        };

        var dialog = await DialogService.ShowAsync<UserSelectionDialog>("Seleccionar participantes", parameters, options);
        var result = await dialog.Result;
        
        if (result is { Canceled: false, Data: List<(string Id, string Username)> selectedUsers })
        {
            SelectedParticipants = selectedUsers.ToDictionary(u => u.Id, u => u.Username);
        }
    }

    private void RemoveParticipant(string userId)
    {
        SelectedParticipants.Remove(userId);
    }

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(Title) || !EventDate.HasValue)
        {
            return;
        }

        var result = new AddEventResult
        {
            Title = Title,
            Description = Description,
            EventDate = EventDate.Value,
            Participants = new Dictionary<string, string>(SelectedParticipants)
        };

        MudDialog?.Close(DialogResult.Ok(result));
    }

    private void Cancel() => MudDialog?.Cancel();

    public class AddEventResult
    {
        public string Title { get; set; } = string.Empty;
        public string? Description { get; set; }
        public DateTime EventDate { get; set; }
        public Dictionary<string, string> Participants { get; set; } = new();
    }
}