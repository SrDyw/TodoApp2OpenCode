@using TodoApp2OpenCode.Models
@inject IDialogService DialogService
@inject IAuthService AuthService;
@inject ISnackbar Snackbar;

<MudDialog ContentStyle="width: 500px; max-width: 500px;">
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="Title" 
                          Label="Título de la tarea" 
                          Variant="Variant.Outlined" 
                          Required="true"
                          Placeholder="¿Qué necesitas hacer?"
                          Immediate="true"/>
            
            <MudSelect @bind-Value="SelectedColumnId" 
                       Label="Columna" 
                       Variant="Variant.Outlined"
                       Required="true">
                @foreach (var column in Columns)
                {
                    <MudSelectItem Value="@column.Id">
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <div class="column-color-dot" style="background-color: @column.Color;"></div>
                            <span>@column.Name</span>
                        </MudStack>
                    </MudSelectItem>
                }
            </MudSelect>
            
            <MudTextField @bind-Value="Description" 
                          Label="Descripción (opcional)" 
                          Variant="Variant.Outlined"
                          Lines="3"
                          Placeholder="Agrega más detalles..." />
            
            <MudSelect @bind-Value="Priority" 
                       Label="Prioridad" 
                       Variant="Variant.Outlined">
                <MudSelectItem Value="TodoPriority.Normal">
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Remove" Size="Size.Small" Color="Color.Default" />
                        <span>Normal</span>
                    </MudStack>
                </MudSelectItem>
                <MudSelectItem Value="TodoPriority.Low">
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small" Color="Color.Default" />
                        <span>Baja</span>
                    </MudStack>
                </MudSelectItem>
                <MudSelectItem Value="TodoPriority.High">
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small" Color="Color.Error" />
                        <span>Alta</span>
                    </MudStack>
                </MudSelectItem>
            </MudSelect>

            @if (Participants.Any())
            {
                <MudButton Variant="Variant.Outlined" 
                          Color="Color.Default"
                          StartIcon="@Icons.Material.Filled.People"
                          OnClick="OpenUserSelection">
                    Asignar usuarios (@SelectedUserIds.Count)
                </MudButton>

                @if (SelectedUserIds.Any())
                {
                    <div class="selected-users-display">
                        @foreach (var userId in SelectedUserIds)
                        {
                            if (Participants.TryGetValue(userId, out var userName))
                            {
                                <MudChip T="string" 
                                         Color="Color.Primary" 
                                         Variant="Variant.Filled"
                                         OnClose="@(() => RemoveUser(userId))">
                                    @userName
                                </MudChip>
                            }
                        }
                    </div>
                }
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" 
                   Variant="Variant.Filled" 
                   OnClick="Submit"
                   Disabled="@IsSubmitDisabled">
            Crear Tarea
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .column-color-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
    }
    .selected-users-display {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }
</style>

@code {
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public List<TodoColumn> Columns { get; set; } = new();

    [Parameter]
    public Dictionary<string, string> Participants { get; set; } = new();

    private string Title { get; set; } = string.Empty;
    private string? SelectedColumnId { get; set; }
    private string Description { get; set; } = string.Empty;
    private TodoPriority Priority { get; set; } = TodoPriority.Normal;
    private HashSet<string> SelectedUserIds = new();

    private bool IsSubmitDisabled => string.IsNullOrWhiteSpace(Title) || string.IsNullOrWhiteSpace(SelectedColumnId);

    protected override void OnInitialized()
    {
        if (Columns.Any())
        {
            SelectedColumnId = Columns.First().Id;
        }
    }

    private async Task OpenUserSelection()
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Medium
        };

        var parameters = new DialogParameters<UserSelectionDialog>();
        parameters.Add(x => x.Source, Participants);
        parameters.Add(x => x.PreSelectedUserIds, SelectedUserIds);

        var dialog = await DialogService.ShowAsync<UserSelectionDialog>("Seleccionar usuarios", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: List<(string Id, string Name)> selectedUsers })
        {
            SelectedUserIds = selectedUsers.Select(u => u.Id).ToHashSet();
        }
    }

    private void RemoveUser(string userId)
    {
        SelectedUserIds.Remove(userId);
    }

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(Title) || string.IsNullOrWhiteSpace(SelectedColumnId))
            return;

        if (AuthService.CurrentUser == null)
        {
            Snackbar.Add("Para crear un nuevo tablero primero inicia sesión", Severity.Warning);
            return;
        }

        var assignedUsers = new Dictionary<string, string>();
        foreach (var userId in SelectedUserIds)
        {
            if (Participants.TryGetValue(userId, out var userName))
            {
                assignedUsers[userId] = userName;
            }
        }

        var item = new TodoItem
        {
            Title = Title.Trim(),
            Description = string.IsNullOrWhiteSpace(Description) ? null : Description.Trim(),
            ColumnId = SelectedColumnId,
            Priority = Priority,
            AssignedUsers = assignedUsers
        };

        MudDialog?.Close(DialogResult.Ok(item));
    }

    private void Cancel() => MudDialog?.Cancel();
}
