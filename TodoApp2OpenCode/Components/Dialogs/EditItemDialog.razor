@namespace TodoApp2OpenCode.Components.Dialogs
@inject IDialogService DialogService

<MudDialog ContentStyle="width: 500px; max-width: 500px;">
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="Item.Title"
                          Label="Título de la tarea"
                          Variant="Variant.Outlined"
                          Required="true"
                          Immediate="true"
                          Adornment="Adornment.Start"/>
            
            <MudTextField @bind-Value="Item.Description"
                          Label="Descripción (opcional)"
                          Variant="Variant.Outlined"
                          Lines="3"
                          Adornment="Adornment.Start"/>
            
            <MudSelect @bind-Value="Item.Priority"
                       Label="Prioridad"
                       Variant="Variant.Outlined">
                <MudSelectItem Value="TodoPriority.Low">
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Default" Size="Size.Small" />
                        <span>Baja</span>
                    </MudStack>
                </MudSelectItem>
                <MudSelectItem Value="TodoPriority.Normal">
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Remove" Color="Color.Info" Size="Size.Small" />
                        <span>Normal</span>
                    </MudStack>
                </MudSelectItem>
                <MudSelectItem Value="TodoPriority.High">
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowUp" Color="Color.Error" Size="Size.Small" />
                        <span>Alta</span>
                    </MudStack>
                </MudSelectItem>
            </MudSelect>

            <div class="steps-section">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Pasos de la tarea</MudText>
                
                @foreach (var step in editingSteps)
                {
                    <div class="step-row">
                        <MudCheckBox T="bool" 
                                     Value="step.IsCompleted"
                                     ValueChanged="(v) => OnStepCheckChanged(step, v)"
                                     Dense="true" />
                        <MudTextField @bind-Value="step.Name"
                                      Placeholder="Nombre del paso"
                                      Variant="Variant.Outlined"
                                      Dense="true"
                                      Class="step-name-field" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                       Size="Size.Small" 
                                       Color="Color.Error"
                                       OnClick="@(() => RemoveStep(step))" />
                    </div>
                }

                <MudButton Variant="Variant.Text" 
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="AddStep"
                           Class="mt-2">
                    Añadir paso
                </MudButton>

                @if (editingSteps.Any())
                {
                    <div class="steps-progress mt-3">
                        <MudText Typo="Typo.caption">
                            Progreso: @CompletedStepsCount de @TotalStepsCount pasos 
                            (@ProgressPercentage.ToString("F0")%)
                        </MudText>
                        <MudProgressLinear Value="@ProgressPercentage" Color="Color.Primary" />
                        @{
                            var nextStep = editingSteps.FirstOrDefault(s => !s.IsCompleted);
                        }
                        @if (nextStep != null)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Primary" Class="mt-1">
                                Paso actual: @nextStep.Name
                            </MudText>
                        }
                    </div>
                }
            </div>

            @if (Participants.Any())
            {
                <MudButton Variant="Variant.Outlined" 
                          Color="Color.Default"
                          StartIcon="@Icons.Material.Filled.People"
                          OnClick="OpenUserSelection">
                    Asignar usuarios (@SelectedUserIds.Count)
                </MudButton>

                @if (SelectedUserIds.Any())
                {
                    <div class="selected-users-display">
                        @foreach (var userId in SelectedUserIds)
                        {
                            if (AllParticipants.TryGetValue(userId, out var userName))
                            {
                                <MudChip T="string" 
                                         Color="Color.Primary" 
                                         Variant="Variant.Filled"
                                         OnClose="@(() => RemoveUser(userId))">
                                    @userName
                                </MudChip>
                            }
                        }
                    </div>
                }
            }
            
            <MudSelect @bind-Value="selectedColumnId"
                       Label="Columna"
                       Variant="Variant.Outlined">
                @foreach (var column in Columns)
                {
                    <MudSelectItem Value="column.Id">
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <div style="width: 12px; height: 12px; border-radius: 50%; background-color: @column.Color;"></div>
                            <span>@column.Name</span>
                        </MudStack>
                    </MudSelectItem>
                }
            </MudSelect>
            
            <MudStack Row="true" Spacing="2" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Creada: @Item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @(Item.IsCompleted ? "✅ Completada" : "⏳ Pendiente")
                </MudText>
            </MudStack>
        </MudStack>
    </DialogContent>
    
    <DialogActions>
        <MudButton OnClick="Cancel"
                   Variant="Variant.Text">
            Cancelar
        </MudButton>
        
        <MudButton OnClick="Submit"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Save"
                   Disabled="@string.IsNullOrWhiteSpace(Item.Title)">
            Guardar
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .selected-users-display {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }
    .steps-section {
        padding: 12px;
        background: var(--mud-palette-surface);
        border-radius: 8px;
        border: 1px solid var(--mud-palette-lines-default);
    }
    .step-row {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
    }
    .step-name-field {
        flex: 1;
    }
    .steps-progress {
        padding-top: 8px;
        border-top: 1px solid var(--mud-palette-lines-default);
    }
</style>

@code {
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public TodoItem Item { get; set; } = new();

    [Parameter]
    public List<TodoColumn> Columns { get; set; } = new();

    [Parameter]
    public Dictionary<string, string> Participants { get; set; } = new();

    private Dictionary<string, string> AllParticipants { get; set; } = new();
    private string selectedColumnId = string.Empty;
    private HashSet<string> SelectedUserIds = new();
    private IEnumerable<string> InitialAssignedUsers = [];
    private List<TodoStep> editingSteps = new();
    private int previousStepCount = 0;
    private int previousCurrentStepIndex = -1;

    protected override void OnInitialized()
    {
        selectedColumnId = Item.ColumnId;
        AllParticipants = new Dictionary<string, string>(Participants);

        if (Item.AssignedUsers != null)
        {
            SelectedUserIds = new HashSet<string>(Item.AssignedUsers.Keys);
            InitialAssignedUsers = Item.AssignedUsers.Keys;
        }

        editingSteps = Item.Steps?.Select(s => new TodoStep { Id = s.Id, Name = s.Name, IsCompleted = s.IsCompleted }).ToList() ?? new List<TodoStep>();
        previousStepCount = editingSteps.Count;
        previousCurrentStepIndex = Item.CurrentStepIndex;
    }

    private void OnStepCheckChanged(TodoStep step, bool isChecked)
    {
        int stepIndex = editingSteps.IndexOf(step);
        
        if (isChecked)
        {
            for (int i = 0; i <= stepIndex; i++)
            {
                editingSteps[i].IsCompleted = true;
            }
            var nextUncompleted = editingSteps.FindIndex(s => !s.IsCompleted);
            Item.CurrentStepIndex = nextUncompleted >= 0 ? nextUncompleted : editingSteps.Count - 1;
        }
        else
        {
            for (int i = stepIndex; i < editingSteps.Count; i++)
            {
                editingSteps[i].IsCompleted = false;
            }
            Item.CurrentStepIndex = stepIndex > 0 ? stepIndex - 1 : -1;
        }
    }

    private void AddStep()
    {
        editingSteps.Add(new TodoStep { Name = "" });
    }

    private void RemoveStep(TodoStep step)
    {
        int removedIndex = editingSteps.IndexOf(step);
        editingSteps.Remove(step);
        
        if (Item.CurrentStepIndex >= removedIndex && Item.CurrentStepIndex > 0)
        {
            Item.CurrentStepIndex--;
        }
        else if (Item.CurrentStepIndex == removedIndex)
        {
            Item.CurrentStepIndex = -1;
        }
    }

    private int CompletedStepsCount => editingSteps.Count(s => s.IsCompleted);
    private int TotalStepsCount => editingSteps.Count;
    private double ProgressPercentage => TotalStepsCount > 0 ? (double)CompletedStepsCount / TotalStepsCount * 100 : 0;

    private async Task OpenUserSelection()
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Medium
        };

        var parameters = new DialogParameters<UserSelectionDialog>();
        parameters.Add(x => x.Source, Participants);
        parameters.Add(x => x.PreSelectedUserIds, SelectedUserIds);

        var dialog = await DialogService.ShowAsync<UserSelectionDialog>("Seleccionar usuarios", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: List<(string Id, string Name)> selectedUsers })
        {
            SelectedUserIds = selectedUsers.Select(u => u.Id).ToHashSet();
        }
    }

    private void RemoveUser(string userId)
    {
        SelectedUserIds.Remove(userId);
    }

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(Item.Title))
        {
            return;
        }

        Item.UpdatedAt = DateTime.Now;

        var assignedUsers = new Dictionary<string, string>();
        foreach (var userId in SelectedUserIds)
        {
            if (AllParticipants.TryGetValue(userId, out var userName))
            {
                assignedUsers[userId] = userName;
            }
        }
        Item.AssignedUsers = assignedUsers;

        Item.Steps = editingSteps.Where(s => !string.IsNullOrWhiteSpace(s.Name)).ToList();

        var intersect = InitialAssignedUsers.Intersect(SelectedUserIds);
        var removedUsers = InitialAssignedUsers.Where(x => !intersect.Contains(x));
        var addedUsers = SelectedUserIds.Where(x => !intersect.Contains(x));

        var result = new EditItemResult
        {
            Item = Item,
            ColumnChanged = Item.ColumnId != selectedColumnId,
            NewColumnId = selectedColumnId,
            RemovedUsers = removedUsers ?? [],
            AddedUsers = addedUsers ?? [],
            StepsChanged = Item.Steps.Count != previousStepCount || Item.CurrentStepIndex != previousCurrentStepIndex
        };

        Item.ColumnId = selectedColumnId;

        MudDialog?.Close(DialogResult.Ok(result));
    }

    private void Cancel() => MudDialog?.Cancel();

    public class EditItemResult
    {
        public TodoItem Item { get; set; } = new();
        public bool ColumnChanged { get; set; }
        public string NewColumnId { get; set; } = string.Empty;
        public IEnumerable<string> RemovedUsers { get; set; } = [];
        public IEnumerable<string> AddedUsers { get; set; } = [];
        public bool StepsChanged { get; set; }
    }
}
