@namespace TodoApp2OpenCode.Components.Dialogs
@inject IDialogService DialogService

<!--
    Diálogo para editar una tarea existente.
    Permite modificar título, descripción, prioridad y columna.
-->

<MudDialog ContentStyle="width: 500px; max-width: 500px;">
    <DialogContent>
        <MudStack Spacing="3">
            <!-- Campo de título -->
            <MudTextField @bind-Value="Item.Title"
                          Label="Título de la tarea"
                          Variant="Variant.Outlined"
                          Required="true"
                          Immediate="true"
                          Adornment="Adornment.Start"/>
            
            <!-- Campo de descripción -->
            <MudTextField @bind-Value="Item.Description"
                          Label="Descripción (opcional)"
                          Variant="Variant.Outlined"
                          Lines="3"
                          Adornment="Adornment.Start"/>
            
            <!-- Selector de prioridad -->
            <MudSelect @bind-Value="Item.Priority"
                       Label="Prioridad"
                       Variant="Variant.Outlined">
                <MudSelectItem Value="TodoPriority.Low">
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Default" Size="Size.Small" />
                        <span>Baja</span>
                    </MudStack>
                </MudSelectItem>
                <MudSelectItem Value="TodoPriority.Normal">
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Remove" Color="Color.Info" Size="Size.Small" />
                        <span>Normal</span>
                    </MudStack>
                </MudSelectItem>
                <MudSelectItem Value="TodoPriority.High">
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowUp" Color="Color.Error" Size="Size.Small" />
                        <span>Alta</span>
                    </MudStack>
                </MudSelectItem>
            </MudSelect>

            @if (Participants.Any())
            {
                <MudButton Variant="Variant.Outlined" 
                          Color="Color.Default"
                          StartIcon="@Icons.Material.Filled.People"
                          OnClick="OpenUserSelection">
                    Asignar usuarios (@SelectedUserIds.Count)
                </MudButton>

                @if (SelectedUserIds.Any())
                {
                    <div class="selected-users-display">
                        @foreach (var userId in SelectedUserIds)
                        {
                            if (AllParticipants.TryGetValue(userId, out var userName))
                            {
                                <MudChip T="string" 
                                         Color="Color.Primary" 
                                         Variant="Variant.Filled"
                                         OnClose="@(() => RemoveUser(userId))">
                                    @userName
                                </MudChip>
                            }
                        }
                    </div>
                }
            }
            
            <!-- Selector de columna -->
            <MudSelect @bind-Value="selectedColumnId"
                       Label="Columna"
                       Variant="Variant.Outlined">
                @foreach (var column in Columns)
                {
                    <MudSelectItem Value="column.Id">
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <div style="width: 12px; height: 12px; border-radius: 50%; background-color: @column.Color;"></div>
                            <span>@column.Name</span>
                        </MudStack>
                    </MudSelectItem>
                }
            </MudSelect>
            
            <!-- Metadatos (solo lectura) -->
            <MudStack Row="true" Spacing="2" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Creada: @Item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @(Item.IsCompleted ? "✅ Completada" : "⏳ Pendiente")
                </MudText>
            </MudStack>
        </MudStack>
    </DialogContent>
    
    <DialogActions>
        <MudButton OnClick="Cancel"
                   Variant="Variant.Text">
            Cancelar
        </MudButton>
        
        <MudButton OnClick="Submit"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Save"
                   Disabled="@string.IsNullOrWhiteSpace(Item.Title)">
            Guardar
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .selected-users-display {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }
</style>

@code {
    /// <summary>
    /// Referencia al diálogo.
    /// </summary>
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    /// <summary>
    /// Tarea a editar.
    /// </summary>
    [Parameter]
    public TodoItem Item { get; set; } = new();

    /// <summary>
    /// Lista de columnas disponibles.
    /// </summary>
    [Parameter]
    public List<TodoColumn> Columns { get; set; } = new();

    /// <summary>
    /// Diccionario de participantes del tablero (Id -> Username).
    /// </summary>
    [Parameter]
    public Dictionary<string, string> Participants { get; set; } = new();

    /// <summary>
    /// Diccionario de todos los usuarios disponibles (para edición).
    /// </summary>
    private Dictionary<string, string> AllParticipants { get; set; } = new();

    /// <summary>
    /// ID de la columna seleccionada (para el selector).
    /// </summary>
    private string selectedColumnId = string.Empty;

    /// <summary>
    /// IDs de usuarios seleccionados.
    /// </summary>
    private HashSet<string> SelectedUserIds = new();

    private IEnumerable<string> InitialAssignedUsers = [];

    protected override void OnInitialized()
    {
        selectedColumnId = Item.ColumnId;

        AllParticipants = new Dictionary<string, string>(Participants);

        if (Item.AssignedUsers != null)
        {
            SelectedUserIds = new HashSet<string>(Item.AssignedUsers.Keys);
            InitialAssignedUsers = Item.AssignedUsers.Keys;
        }
    }

    private async Task OpenUserSelection()
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Medium
        };

        var parameters = new DialogParameters<UserSelectionDialog>();
        parameters.Add(x => x.Source, Participants);
        parameters.Add(x => x.PreSelectedUserIds, SelectedUserIds);

        var dialog = await DialogService.ShowAsync<UserSelectionDialog>("Seleccionar usuarios", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: List<(string Id, string Name)> selectedUsers })
        {
            SelectedUserIds = selectedUsers.Select(u => u.Id).ToHashSet();
        }
    }

    private void RemoveUser(string userId)
    {
        SelectedUserIds.Remove(userId);
    }

    /// <summary>
    /// Guarda los cambios de la tarea.
    /// </summary>
    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(Item.Title))
        {
            return;
        }

        Item.UpdatedAt = DateTime.Now;

        var assignedUsers = new Dictionary<string, string>();
        foreach (var userId in SelectedUserIds)
        {
            if (AllParticipants.TryGetValue(userId, out var userName))
            {
                assignedUsers[userId] = userName;
            }
        }
        Item.AssignedUsers = assignedUsers;

        var intersect = InitialAssignedUsers
            .Intersect(SelectedUserIds);

        var removedUsers = InitialAssignedUsers
            .Where(x => 
                intersect.Any(intersectItem => intersectItem == x) == false
            );

        var addedUsers = SelectedUserIds
            .Where(x => 
                intersect.Any(intersectItem => intersectItem == x) == false
            );

        var result = new EditItemResult
        {
            Item = Item,
            ColumnChanged = Item.ColumnId != selectedColumnId,
            NewColumnId = selectedColumnId,
            RemovedUsers = removedUsers ?? [],
            AddedUsers = addedUsers ?? []
        };

        Item.ColumnId = selectedColumnId;



        MudDialog?.Close(DialogResult.Ok(result));
    }

    /// <summary>
    /// Cancela la edición.
    /// </summary>
    private void Cancel() => MudDialog?.Cancel();

    public class EditItemResult
    {
        public TodoItem Item { get; set; } = new();
        public bool ColumnChanged { get; set; }
        public string NewColumnId { get; set; } = string.Empty;
        public IEnumerable<string> RemovedUsers { get; set; } = [];
        public IEnumerable<string> AddedUsers { get; set; } = [];
    }
}
