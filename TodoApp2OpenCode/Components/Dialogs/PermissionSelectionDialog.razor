@inject IBoardService BoardService
@inject NavigationManager Navigation
<MudDialog ContentStyle="width: 400px; max-width: 400px;">
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.h6">Gestionar Permisos</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Selecciona los permisos para este usuario
            </MudText>
            
            <MudDivider />
            
            <MudText Typo="Typo.subtitle2">General</MudText>
            
            <MudCheckBox T="bool" @bind-Value="_canViewCalendar" Label="Ver calendario" Color="Color.Primary" />
            
            <MudDivider />
            
            <MudText Typo="Typo.subtitle2">Tareas</MudText>
            
            <MudCheckBox T="bool" @bind-Value="_canAddTasks" Label="Añadir tareas" Color="Color.Primary" />
            <MudCheckBox T="bool" @bind-Value="_canModifyTasks" Label="Modificar tareas" Color="Color.Primary" />
            <MudCheckBox T="bool" @bind-Value="_canDeleteTasks" Label="Eliminar tareas" Color="Color.Primary" />
            
            <MudDivider />
            
            <MudText Typo="Typo.subtitle2">Eventos</MudText>
            
            <MudCheckBox T="bool" @bind-Value="_canAddEvents" Label="Añadir eventos" Color="Color.Primary" />
            <MudCheckBox T="bool" @bind-Value="_canModifyEvents" Label="Modificar eventos" Color="Color.Primary" />
            <MudCheckBox T="bool" @bind-Value="_canDeleteEvents" Label="Eliminar eventos" Color="Color.Primary" />
            
            <MudDivider />
            
            <MudText Typo="Typo.subtitle2">Columnas</MudText>
            
            <MudCheckBox T="bool" @bind-Value="_canAddColumn" Label="Añadir columnas" Color="Color.Primary" />
            <MudCheckBox T="bool" @bind-Value="_canEditColumn" Label="Modificar/Mover columnas" Color="Color.Primary" />
            <MudCheckBox T="bool" @bind-Value="_canDeleteColumn" Label="Eliminar columnas" Color="Color.Primary" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" 
                   Variant="Variant.Filled" 
                   OnClick="Submit">
            Guardar Permisos
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public string BoardId { get; set; } = "";

    [Parameter]
    public string UserId { get; set; } = "";

    [Parameter]
    public BoardPermissions? CurrentPermissions { get; set; }

    private bool _canViewCalendar = false;
    private bool _canAddTasks = false;
    private bool _canModifyTasks = false;
    private bool _canDeleteTasks = false;
    private bool _canAddEvents = false;
    private bool _canModifyEvents = false;
    private bool _canDeleteEvents = false;
    private bool _canAddColumn = false;
    private bool _canEditColumn = false;
    private bool _canDeleteColumn = false;

    protected override void OnInitialized()
    {
        if (CurrentPermissions != null)
        {
            _canViewCalendar = CurrentPermissions.CanViewCalendar;
            _canAddTasks = CurrentPermissions.CanAddTasks;
            _canModifyTasks = CurrentPermissions.CanModifyTasks;
            _canDeleteTasks = CurrentPermissions.CanDeleteTasks;
            _canAddEvents = CurrentPermissions.CanAddEvents;
            _canModifyEvents = CurrentPermissions.CanModifyEvents;
            _canDeleteEvents = CurrentPermissions.CanDeleteEvents;
            _canAddColumn = CurrentPermissions.CanAddColumn;
            _canEditColumn = CurrentPermissions.CanEditColumn;
            _canDeleteColumn = CurrentPermissions.CanDeleteColumn;
        }
    }

    private async Task Submit()
    {
        var permissions = new BoardPermissions
        {
            CanViewCalendar = _canViewCalendar,
            CanAddTasks = _canAddTasks,
            CanModifyTasks = _canModifyTasks,
            CanDeleteTasks = _canDeleteTasks,
            CanAddEvents = _canAddEvents,
            CanModifyEvents = _canModifyEvents,
            CanDeleteEvents = _canDeleteEvents,
            CanAddColumn = _canAddColumn,
            CanEditColumn = _canEditColumn,
            CanDeleteColumn = _canDeleteColumn
        };

        if (!string.IsNullOrEmpty(BoardId) && !string.IsNullOrEmpty(UserId))
        {
            await BoardService.UpdateParticipantPermissionsAsync(BoardId, UserId, permissions);
        }

        MudDialog?.Close(DialogResult.Ok(permissions));
        
        Navigation.Refresh(forceReload: true);
    }

    private void Cancel() => MudDialog?.Cancel();
}
