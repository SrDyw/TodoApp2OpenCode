@namespace TodoApp2OpenCode.Components.Dialogs
<MudDialog ContentStyle="max-height: 80vh; overflow-y: auto;">
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-3">Actividades para el @Date.ToString("dd/MM/yyyy")</MudText>
        
        @if (!EventsForDay.Any() && !ItemsForDay.Any())
        {
            <MudText Color="Color.Default" Class="pa-4 text-center">
                No hay actividades para este día
            </MudText>
        }
        
        @if (EventsForDay.Any())
        {
            <MudText Typo="Typo.subtitle2" Color="Color.Success" Class="mb-2">
                Eventos
            </MudText>
            
            @foreach (var evt in EventsForDay)
            {
                <div class="event-card">
                    <div class="event-content">
                        <div class="event-icon-wrapper">
                            <MudIcon Icon="@Icons.Material.Filled.Event" 
                                     Size="Size.Medium" 
                                     Color="Color.Success" />
                        </div>
                        <div class="event-details">
                            <MudText Typo="Typo.body1" Class="event-title">
                                @evt.Title
                            </MudText>
                            @if (!string.IsNullOrEmpty(evt.Description))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="event-description">
                                    @evt.Description
                                </MudText>
                            }
                            
                            @if (evt.Participants != null && evt.Participants.Any())
                            {
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mt-2">
                                    <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" Color="Color.Primary" />
                                    <MudText Typo="Typo.caption">
                                        @string.Join(", ", evt.Participants.Values)
                                    </MudText>
                                </MudStack>
                            }
                        </div>
                    </div>
                    <div class="event-actions">
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowForward" 
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       Title="Ir al evento"
                                       OnClick="() => GoToEvent(evt)" />
                    </div>
                </div>
            }
            
            <MudDivider Class="my-4" />
        }
        
        @if (ItemsForDay.Any())
        {
            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">
                Tareas
            </MudText>
            
            @foreach (var item in ItemsForDay)
            {
                <div class="day-detail-item @(item.IsCompleted ? "completed" : "") @(item.Priority == TodoPriority.High ? "high-priority" : "")">
                    <div class="item-header">
                        <MudIcon Icon="@(item.IsCompleted ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)" 
                                 Size="Size.Small" 
                                 Class="item-indicator"
                                 Color="@(item.IsCompleted ? Color.Success : (item.Priority == TodoPriority.High ? Color.Error : Color.Default))" />
                        <MudText Typo="Typo.body1" Class="item-title">
                            @item.Title
                        </MudText>
                        @if (item.Priority == TodoPriority.High)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Class="ml-2">
                                Alta
                            </MudChip>
                        }
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowForward" 
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       Title="Ir a la tarea"
                                       Class="ml-auto"
                                       OnClick="() => GoToItem(item)" />
                    </div>
                    
                    @if (!string.IsNullOrEmpty(item.Description))
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="item-description mt-2">
                            @item.Description
                        </MudText>
                    }
                </div>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">
            Cerrar
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .event-card {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 12px 16px;
        margin-bottom: 8px;
        background: var(--mud-palette-surface);
        border-radius: 8px;
        border: 1px solid transparent;
        transition: all 0.15s ease;
    }

    .event-card:hover {
        background: var(--mud-palette-action-hover);
        border-color: var(--mud-palette-lines-default);
    }

    .event-content {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        flex: 1;
        min-width: 0;
    }

    .event-icon-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        background: rgba(76, 175, 80, 0.12);
        border-radius: 8px;
        flex-shrink: 0;
    }

    .event-details {
        flex: 1;
        min-width: 0;
    }

    .event-title {
        font-weight: 500;
        color: var(--mud-palette-text-primary);
    }

    .event-description {
        margin-top: 2px;
        color: var(--mud-palette-text-secondary);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .event-actions {
        flex-shrink: 0;
        margin-left: 8px;
    }

    .day-detail-item {
        padding: 16px;
        margin-bottom: 16px;
        background: var(--mud-palette-background);
        border-radius: 12px;
        border: 1px solid var(--mud-palette-lines-default);
    }

    .day-detail-item.completed {
        opacity: 0.7;
    }

    .day-detail-item.high-priority {
        border-left: 4px solid var(--mud-palette-error);
    }

    .item-header {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .item-indicator {
        color: var(--mud-palette-primary);
    }

    .day-detail-item.high-priority .item-indicator {
        color: var(--mud-palette-error);
    }

    .item-title {
        flex: 1;
        font-weight: 500;
    }

    .day-detail-item.completed .item-title {
        text-decoration: line-through;
        color: var(--mud-palette-text-disabled);
    }

    .item-description {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public DateTime Date { get; set; }

    [Parameter]
    public List<TodoItem> Items { get; set; } = new();

    [Parameter]
    public List<CalendarEvent> Events { get; set; } = new();

    private List<TodoItem> ItemsForDay => Items.Where(i => 
        i.DueDate?.Date == Date.Date ||
        (i.StartDate.HasValue && i.EndDate.HasValue && Date.Date >= i.StartDate.Value.Date && Date.Date <= i.EndDate.Value.Date) ||
        (i.StartDate.HasValue && !i.EndDate.HasValue && Date.Date >= i.StartDate.Value.Date)
    ).ToList();

    private List<CalendarEvent> EventsForDay => Events.Where(e => e.EventDate.Date == Date.Date).ToList();

    private void GoToEvent(CalendarEvent evt)
    {
        if (!string.IsNullOrEmpty(evt.TodoBoardId))
        {
            MudDialog.Close(DialogResult.Ok($"/board/{evt.TodoBoardId}/schedule?date={evt.EventDate:dd-MM-yyyy}"));
        }
    }

    private void GoToItem(TodoItem item)
    {
        if (!string.IsNullOrEmpty(item.TodoBoardId))
        {
            MudDialog.Close(DialogResult.Ok($"/board/{item.TodoBoardId}?itemId={item.Id}"));
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
