<MudText @onclick="(e) => OnClick?.Invoke()" Typo="Typo" Class="splash-title" Style="font-weight: 800; letter-spacing: -1px;">
    @Config.AppName
</MudText>
<style>
    .splash-title {
        background: linear-gradient(90deg, #7e6fff 0%, #a5a0f0 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
</style>
@code {
    [Parameter]
    public Typo Typo { get; set; } = Typo.h3;
    [Parameter]
    public Action? OnClick { get; set; }
}
